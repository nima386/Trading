}catch(_){}

KDOM.setClick('back-btn', ()=>{
  navigate(prevScreen);
});
KDOM.setClick('profile-back-btn', ()=>{
  navigate(prevScreen && prevScreen !== 'profile' ? prevScreen : 'training');
});

