      stroke-dasharray="600" stroke-dashoffset="600"
      stroke-linecap="round" stroke-linejoin="round"
      filter="url(#ecg-glow)"
      style="animation: ecg-draw 1.8s cubic-bezier(0.4,0,0.2,1) forwards;"/>
    <!-- dot at heartbeat peak -->
    <circle cx="42" cy="30" r="5" fill="#ff2d55" opacity="0"/>
    <circle cx="117" cy="30" r="5" fill="#ff6b00" opacity="0"/>
