function initEmptyTrainingPlan(startDate){
  return {
    name:'',
    weekMode:'single',
    startDate: startDate,
    endDate: null,
    rolling:{
      startDate: startDate,
      endDate: null,
      days:[]
    },
    weeks:{
      'A':{ label:'A', sortOrder:0, days: buildEmptyWeekDays() }
    }
  };
}
function buildEmptyTrainingDay(label='Trainingstag'){
  return {
    label,
    isRest: false,
    muscleGroups:[],
    dailyExercises:[]
  };
}
function buildEmptyWeekDays(){
  const days={};
  for(let d=0;d<7;d++){
    days[String(d)] = buildEmptyTrainingDay();
  }
  return days;
}

function normalizeDailyExercise(ex={}, index=0){
  return {
    id: ex.id || genId(),
    name: String(ex.name || 'Tagesübung').trim() || 'Tagesübung',
    icon: cleanUiIcon(ex.icon, '💪'),
    timeOfDay: normalizeTimeOfDay(ex.timeOfDay || ex.time || 'morning', 'morning'),
    target: Math.max(1, parseInt(ex.target ?? ex.goal ?? 50) || 50),
    step: Math.max(1, parseInt(ex.step ?? ex.increment ?? 5) || 5),
    unit: String(ex.unit || 'Wdh').trim() || 'Wdh',
    sortOrder: ex.sortOrder ?? index,
    isArchived: !!ex.isArchived
  };
}

function ensureDailyExercisesForDay(day){
  if(!day) return [];
  if(!Array.isArray(day.dailyExercises)) day.dailyExercises = [];
  day.dailyExercises = day.dailyExercises.map((ex,index)=>normalizeDailyExercise(ex,index));
  return day.dailyExercises;
}

function normalizeTrainingPlanDay(day){
  const safeDay = day && typeof day === 'object' ? day : buildEmptyTrainingDay();
  safeDay.label = String(safeDay.label || (safeDay.isRest ? 'Ruhetag' : 'Trainingstag')).trim() || 'Trainingstag';
  safeDay.isRest = !!safeDay.isRest;
  if(!Array.isArray(safeDay.muscleGroups)) safeDay.muscleGroups = [];
  safeDay.muscleGroups = safeDay.muscleGroups.map((mg,index)=>mg && typeof mg === 'object' ? mg : {
    id: genId(),
    name: 'Muskelgruppe',
    icon: '💪',
    color: '#FF6B00',
    sortOrder: index,
    exercises: [],
    isArchived: false
  });
  safeDay.muscleGroups.forEach((mg,index)=>{
    mg.id = mg.id || genId();
    mg.name = String(mg.name || 'Muskelgruppe').trim() || 'Muskelgruppe';
    mg.icon = cleanUiIcon(mg.icon, '💪');
    mg.color = mg.color || '#FF6B00';
    mg.timeOfDay = normalizeTimeOfDay(mg.timeOfDay || mg.time || 'morning', 'morning');
    mg.sortOrder = mg.sortOrder ?? index;
    mg.isArchived = !!mg.isArchived;
    if(!Array.isArray(mg.exercises)) mg.exercises = [];
    mg.exercises = mg.exercises.map((ex, exIndex)=>ex && typeof ex === 'object' ? ex : {
      id: genId(),
      name: 'Übung',
      targetSets: 3,
      repsMin: 8,
      repsMax: 12,
      restSeconds: 90,
      sortOrder: exIndex,
      isArchived: false
    });
    mg.exercises.forEach((ex, exIndex)=>{
      ex.id = ex.id || genId();
      ex.name = String(ex.name || 'Übung').trim() || 'Übung';
      ex.targetSets = Math.max(1, parseInt(ex.targetSets ?? ex.sets ?? 3) || 3);
      ex.repsMin = Math.max(1, parseInt(ex.repsMin ?? ex.rMin ?? 8) || 8);
      ex.repsMax = Math.max(ex.repsMin, parseInt(ex.repsMax ?? ex.rMax ?? 12) || 12);
      ex.restSeconds = Math.max(15, parseInt(ex.restSeconds ?? ex.rest ?? 90) || 90);
      ex.timeOfDay = ex.timeOfDay === 'inherit' ? 'inherit' : normalizeTimeOfDay(ex.timeOfDay || ex.time || 'inherit', mg.timeOfDay);
      ex.sortOrder = ex.sortOrder ?? exIndex;
      ex.isArchived = !!ex.isArchived;
    });
  });
  ensureDailyExercisesForDay(safeDay);
  return safeDay;
}

function cloneTrainingPlanDay(day){
  return normalizeTrainingPlanDay(JSON.parse(JSON.stringify(day || buildEmptyTrainingDay())));
}

function ensureRollingPlan(seedDays=false){
  const tp = S.trainingPlan;
  if(!tp) return null;
  if(!tp.rolling || typeof tp.rolling !== 'object') tp.rolling = {};
  tp.rolling.startDate = tp.rolling.startDate || tp.startDate || S.planConfig?.startDate || todayStr;
  tp.rolling.endDate = tp.rolling.endDate ?? tp.endDate ?? null;
  if(!Array.isArray(tp.rolling.days)) tp.rolling.days = [];
  if(!tp.rolling.days.length){
    if(seedDays){
      const sourceDays = tp.weeks?.A?.days || buildEmptyWeekDays();
      tp.rolling.days = Array.from({length:7},(_,index)=>cloneTrainingPlanDay(sourceDays[String(index)] || buildEmptyTrainingDay()));
    }
  } else {
    tp.rolling.days = tp.rolling.days.map(day=>normalizeTrainingPlanDay(day));
  }
  return tp.rolling;
}

function ensureTrainingPlanWeeks(){
  const tp = S.trainingPlan;
  if(!tp) return;
  Object.keys(tp.weeks||{}).forEach(wk=>{
    if(!tp.weeks[wk].days) tp.weeks[wk].days = buildEmptyWeekDays();
    for(let d=0;d<7;d++){
      const dk=String(d);
      tp.weeks[wk].days[dk] = normalizeTrainingPlanDay(tp.weeks[wk].days[dk]);
    }
  });
  ensureRollingPlan();
}
function tpWeekList(){
  const tp = S.trainingPlan;
  if(!tp?.weeks) return [];
  return Object.keys(tp.weeks)
    .map(k=>tp.weeks[k])
    .filter(w=>!w.isArchived)
    .sort((a,b)=>a.sortOrder-b.sortOrder)
    .map(w=>w.label);
}
function syncPlanConfigFromTrainingPlan(){
  const weeks = tpWeekList();
  if(!S.planConfig) S.planConfig = {};
  if(weeks.length) S.planConfig.weekIds = weeks;
  if(S.trainingPlan?.startDate) S.planConfig.startDate = S.trainingPlan.startDate;
  S.planConfig.singleWeekMode = (S.planConfig.weekIds || []).length <= 1;
}
function syncTrainingPlanFromPlanConfig(){
  if(!S.trainingPlan) return;
  const weeks = (S.planConfig?.weekIds || ['A','B']).filter(Boolean);
  weeks.forEach((wk, index)=>{
    if(!S.trainingPlan.weeks[wk]){
      S.trainingPlan.weeks[wk] = {
        label:wk,
        sortOrder:index,
        days: buildEmptyWeekDays()
      };
    } else {
      S.trainingPlan.weeks[wk].isArchived = false;
      S.trainingPlan.weeks[wk].sortOrder = S.trainingPlan.weeks[wk].sortOrder ?? index;
    }
  });
  if(S.planConfig?.startDate) S.trainingPlan.startDate = S.planConfig.startDate;
}
function buildWeekDaysFromLegacyPlan(source){
  const days = {};
  for(let tpIndex=0;tpIndex<7;tpIndex++){
    const jsDow = (tpIndex + 1) % 7;
    const p = source?.[jsDow] || {};
    days[String(tpIndex)] = {
      label:p.label || (p.type === 'rest' ? 'Ruhetag' : 'Trainingstag'),
      isRest:p.type === 'rest',
      dailyExercises:[],
      muscleGroups:(p.muscles || []).map((name, index)=>({
        id:genId(), name, icon:MUSCLE_META[name]?.icon || '💪',
        color:MUSCLE_META[name]?.color || '#FF6B00',
        sortOrder:index, exercises:[], isArchived:false
      }))
    };
  }
  return days;
}
function tpDay(weekLabel, dayIndex){
  return S.trainingPlan?.weeks?.[weekLabel]?.days?.[String(dayIndex)];
}
function tpMg(weekLabel, dayIndex, mgId){
  return tpDay(weekLabel,dayIndex)?.muscleGroups?.find(m=>m.id===mgId);
}
function tpEx(weekLabel, dayIndex, mgId, exId){
  return tpMg(weekLabel,dayIndex,mgId)?.exercises?.find(e=>e.id===exId);
}
function genId(){ return 'tp_'+Date.now()+'_'+Math.random().toString(36).slice(2,7); }
function weekModeToWeeks(mode){
  if(mode==='single') return ['A'];
  if(mode==='ab')  return ['A','B'];
  if(mode==='abc') return ['A','B','C'];
  return tpWeekList();
}
function restHint(avg){
  if(avg<=5)  return '💪 Empfohlen für Kraft: 180s';
  if(avg<=8)  return '🏋️ Empfohlen für Hypertrophie: 120s';
  if(avg<=12) return '🔥 Empfohlen für Hypertrophie: 90s';
  return '- Empfohlen für Ausdauer/Pump: 60s';
}
function restDefault(avg){
  if(avg<=5)  return 180;
  if(avg<=8)  return 120;
  if(avg<=12) return 90;
  return 60;
}

// ---------------------------------------------------------------
// TRAINING PLAN - NAVIGATION STATE
// ---------------------------------------------------------------
let tpActiveWeek = 'A';
let ddActiveWeek = 'A';
let ddActiveDay  = 0;
let ddActiveMode = 'week';
let ddActiveRollingIndex = 0;
let _tpPrev = 'profile';
let profileActiveWeek = 'A';

function openTrainingPlanScreen(){
  ensureTrainingPlanWeeks();
  tpActiveWeek = tpWeekList()[0] || 'A';
  _tpPrev = currentScreen;
  const toEl = activateScreen('training-plan');
  if(!toEl) return;
  prevScreen = currentScreen;
  currentScreen = 'training-plan';
  renderTrainingPlanScreen();
}
function closeTrainingPlanScreen(){
  const target = _tpPrev || 'profile';
  activateScreen(target);
  currentScreen = target;
  updateBottomNav(target);
  if(target==='profile') renderProfile();
  else if(target==='training') renderTraining();
}
function openDayDetailScreen(weekLabel, dayIdx){
  ddActiveMode = 'week';
  ddActiveWeek = weekLabel;
  ddActiveDay  = dayIdx;
  const toEl = activateScreen('day-detail');
  if(!toEl) return;
  prevScreen = currentScreen;
  currentScreen = 'day-detail';
  renderDayDetailScreen();
}
function openRollingDayDetailScreen(dayIdx){
  ddActiveMode = 'rolling';
  ddActiveRollingIndex = dayIdx;
  const toEl = activateScreen('day-detail');
  if(!toEl) return;
  prevScreen = currentScreen;
  currentScreen = 'day-detail';
  renderDayDetailScreen();
}
function closeDayDetailScreen(){
  activateScreen('training-plan');
  currentScreen = 'training-plan';
  updateBottomNav('training-plan');
  renderTrainingPlanScreen();
}
function getDayDetailDay(){
  if(ddActiveMode === 'rolling'){
    const rolling = ensureRollingPlan(true);
    if(!rolling?.days?.length) return null;
    ddActiveRollingIndex = Math.max(0, Math.min(ddActiveRollingIndex, rolling.days.length - 1));
    return rolling.days[ddActiveRollingIndex];
  }
  return tpDay(ddActiveWeek, ddActiveDay);
}
function getDayDetailMuscle(mgId){
  return getDayDetailDay()?.muscleGroups?.find(m=>m.id===mgId);
}
function getDayDetailExercise(mgId, exId){
  return getDayDetailMuscle(mgId)?.exercises?.find(e=>e.id===exId);
}
function getRollingDisplayDate(index){
  const rolling = ensureRollingPlan(true);
  const start = parseDateKey(rolling?.startDate || S.trainingPlan?.startDate || todayStr);
  const d = new Date(start);
  d.setDate(start.getDate() + index);
  return d;
}

function openSelectedPlanDayEditor(){
  const rolling = rollingInfoForDate(selectedDate);
  if(rolling){
    _tpPrev = 'training';
    openTrainingPlanScreen();
    requestAnimationFrame(()=>openRollingDayDetailScreen(rolling.index));
    return;
  }
  const {week, dow} = getPlanForDate(selectedDate);
  const tpIndex = dow === 0 ? 6 : dow - 1;
  tpActiveWeek = week;
  _tpPrev = 'training';
  openTrainingPlanScreen();
  requestAnimationFrame(()=>openDayDetailScreen(week, tpIndex));
}

function renderRollingPlanEditor(body){
  const rolling = ensureRollingPlan(true);
  const meta = document.createElement('div');
  meta.className = 'tp-section';
  meta.innerHTML = `
    <div class="tp-kicker">// Fortlaufend</div>
    <div class="tp-rolling-meta">
      <label class="tp-rolling-date">
        <span>Startdatum</span>
        <input class="tp-input" id="tp-rolling-start" type="date" value="${escapeHtml(rolling.startDate || todayStr)}">
      </label>
      <div class="tp-day-muscles" style="max-width:none;">Tag 1 startet am Startdatum. Danach wiederholt sich die Sequenz automatisch bis zum Plan-Ende.</div>
    </div>
  `;
  body.appendChild(meta);
  meta.querySelector('#tp-rolling-start')?.addEventListener('change',e=>{
    const key = e.target.value || todayStr;
    rolling.startDate = key;
    S.trainingPlan.startDate = key;
    if(!S.planConfig) S.planConfig = {};
    S.planConfig.startDate = key;
    syncPlanConfigFromTrainingPlan();
    saveState(S);
    renderTrainingPlanScreen();
    if(currentScreen === 'training') renderTraining();
  });

  const rows = document.createElement('div');
  rows.className = 'tp-day-rows';
  rows.style.marginBottom = '12px';
  rolling.days.forEach((day,index)=>{
    const displayDate = getRollingDisplayDate(index);
    const tpDow = (displayDate.getDay() + 6) % 7;
    const mgs = (day.muscleGroups||[]).filter(m=>!m.isArchived);
    const mgPreview = mgs.slice(0,3).map(m=>m.name).join(' · ')
      + (mgs.length>3?` +${mgs.length-3} mehr`:'');
    const row = document.createElement('div');
    row.className = 'tp-day-row'+(day.isRest?' is-rest':'');
    row.innerHTML = `
      <div class="tp-day-abbr">${TP_DAY_ABBR[tpDow]}</div>
      <div class="tp-day-info">
        <div class="tp-day-label-text${day.isRest?' rest-lbl':''}">Tag ${index + 1} · ${day.isRest?'☾ ':''}${escapeHtml(day.label||'Trainingstag')}</div>
        ${!day.isRest && mgPreview?`<div class="tp-day-muscles">${escapeHtml(mgPreview.toUpperCase())}</div>`:`<div class="tp-day-muscles">${TP_DAY_NAMES[tpDow].toUpperCase()}</div>`}
      </div>
      ${rolling.days.length > 1 ? `<button class="tp-day-del" type="button" data-rolling-del="${index}" aria-label="Tag löschen">×</button>` : '<div class="tp-chevron">›</div>'}
    `;
    row.addEventListener('click',e=>{
      if(e.target.closest('[data-rolling-del]')) return;
      openRollingDayDetailScreen(index);
    });
    row.querySelector('[data-rolling-del]')?.addEventListener('click',e=>{
      e.stopPropagation();
      showConfirm(
        `Tag ${index + 1} entfernen?`,
        'Der Sequenz-Tag wird aus dem Fortlaufend-Muster entfernt. Bisherige Logs bleiben erhalten.',
        [
          {label:'Entfernen', cls:'danger', cb:()=>{
            rolling.days.splice(index, 1);
            if(!rolling.days.length) rolling.days.push(buildEmptyTrainingDay());
            saveState(S);
            renderTrainingPlanScreen();
            if(currentScreen === 'training') renderTraining();
          }},
          {label:'Abbrechen', cls:'ghost', cb:()=>{}},
        ]
      );
    });
    rows.appendChild(row);
  });
  const addRow = document.createElement('div');
  addRow.className = 'tp-day-row rolling-add';
  addRow.innerHTML = '<div>＋ Tag hinzufügen</div>';
  addRow.addEventListener('click',()=>{
    rolling.days.push(buildEmptyTrainingDay());
    saveState(S);
    renderTrainingPlanScreen();
  });
  rows.appendChild(addRow);
  body.appendChild(rows);
}

function activePlanStartDate(){
  const tp = S.trainingPlan;
  return tp?.weekMode === 'rolling'
    ? (tp.rolling?.startDate || tp.startDate || S.planConfig?.startDate || todayStr)
    : (tp?.startDate || S.planConfig?.startDate || todayStr);
}

function activePlanEndDate(){
  const tp = S.trainingPlan;
  return tp?.weekMode === 'rolling'
    ? (tp.rolling?.endDate || tp.endDate || null)
    : (tp?.endDate || null);
}

function setTrainingPlanEndDate(key){
  if(!S.trainingPlan) return;
  S.trainingPlan.endDate = key || null;
  if(S.trainingPlan.weekMode === 'rolling'){
    const rolling = ensureRollingPlan(true);
    rolling.endDate = key || null;
  }
}

// ---------------------------------------------------------------
// RENDER: TRAINING PLAN SCREEN
// ---------------------------------------------------------------
function renderTrainingPlanScreen(){
  const tp = S.trainingPlan;
  if(!tp) return;
  const weekLabels = tpWeekList();
  if(!weekLabels.includes(tpActiveWeek)) tpActiveWeek = weekLabels[0] || 'A';

  const body = document.getElementById('tp-body');
  body.innerHTML = '';

  // -- Plan Name --
  const sec1 = document.createElement('div');
  sec1.innerHTML = `
    <div class="tp-kicker">// Plan-Name</div>
    <input class="tp-input" id="tp-plan-name" type="text"
      placeholder="z. B. PPL · Push Pull Legs" maxlength="50"
      value="${(tp.name||'').replace(/"/g,'&quot;')}">
  `;
  sec1.style.marginBottom='12px';
  body.appendChild(sec1);
  const nameIn = sec1.querySelector('#tp-plan-name');
  nameIn.addEventListener('input',()=>{
    tp.name = nameIn.value.trim();
    saveState(S);
  });
  nameIn.addEventListener('blur',()=>{ tp.name=nameIn.value.trim(); saveState(S); });

  // -- Wochen-Modus --
  const sec2 = document.createElement('div');
  sec2.className = 'tp-section';
  sec2.innerHTML = `
    <div class="tp-kicker">// Wochen-Modus</div>
    <div class="wm-pills">
      <div class="wm-pill${tp.weekMode==='single'?' active':''}" data-mode="single">Einzelwoche</div>
      <div class="wm-pill${tp.weekMode==='ab'?' active':''}" data-mode="ab">A + B</div>
      <div class="wm-pill${tp.weekMode==='abc'?' active':''}" data-mode="abc">A + B + C</div>
      <div class="wm-pill${tp.weekMode==='custom'?' active':''}" data-mode="custom">Eigene-</div>
      <div class="wm-pill${tp.weekMode==='rolling'?' active':''}" data-mode="rolling">Fortlaufend</div>
    </div>
  `;
  body.appendChild(sec2);
  sec2.querySelectorAll('.wm-pill').forEach(pill=>{
    pill.addEventListener('click',()=>handleWeekModeChange(pill.dataset.mode));
  });

  if(tp.weekMode === 'rolling'){
    renderRollingPlanEditor(body);
  } else {
    // -- Wochen-Tabs --
    const tabRow = document.createElement('div');
    tabRow.className = 'tp-week-tabs';
    weekLabels.forEach(wk=>{
      const t = document.createElement('div');
      t.className = 'tp-wtab'+(wk===tpActiveWeek?' active':'');
      t.innerHTML = `Woche ${wk}${wk!=='A' && weekLabels.length>1?'<span class="wtab-del">×</span>':''}`;
      t.addEventListener('click',e=>{
        if(e.target.classList.contains('wtab-del')){
          handleDeleteWeek(wk); return;
        }
        tpActiveWeek=wk; renderTrainingPlanScreen();
      });
      tabRow.appendChild(t);
    });
    if(tp.weekMode==='custom'){
      const addT = document.createElement('div');
      addT.className = 'tp-wtab add-tab';
      const nextLabel = String.fromCharCode(65+weekLabels.length);
      addT.textContent = `+ Woche ${nextLabel}`;
      addT.addEventListener('click',()=>handleAddWeek(nextLabel));
      tabRow.appendChild(addT);
    }
    body.appendChild(tabRow);

    // -- Tages-Liste --
    const dayRows = document.createElement('div');
    dayRows.className = 'tp-day-rows';
    dayRows.style.marginBottom='12px';
    for(let d=0;d<7;d++){
      const day = tpDay(tpActiveWeek, d);
      if(!day) continue;
      const mgs = (day.muscleGroups||[]).filter(m=>!m.isArchived);
      const mgPreview = mgs.slice(0,3).map(m=>m.name).join(' · ')
        + (mgs.length>3?` +${mgs.length-3} mehr`:'');

      const row = document.createElement('div');
      row.className = 'tp-day-row'+(day.isRest?' is-rest':'');
      row.innerHTML = `
        <div class="tp-day-abbr">${TP_DAY_ABBR[d]}</div>
        <div class="tp-day-info">
          <div class="tp-day-label-text${day.isRest?' rest-lbl':''}">${day.isRest?'☾ ':''} ${day.label||'Trainingstag'}</div>
          ${!day.isRest && mgPreview?`<div class="tp-day-muscles">${mgPreview.toUpperCase()}</div>`:''}
        </div>
        <div class="tp-chevron">›</div>
      `;
      row.addEventListener('click',()=>openDayDetailScreen(tpActiveWeek, d));
      dayRows.appendChild(row);
    }
    body.appendChild(dayRows);
  }

  // -- Plan-Laufzeit --
  const durSec = document.createElement('div');
  durSec.className = 'tp-section';
  const start = parseDateKey(activePlanStartDate());
  const endKey = activePlanEndDate();
  const end   = endKey ? parseDateKey(endKey) : null;
  const today = new Date();
  let progHtml = '';
  if(end){
    const total = end-start;
    const done  = today-start;
    const pct   = Math.min(100,Math.max(0,Math.round((done/total)*100)));
    const weekN = Math.floor(done/(7*24*3600*1000))+1;
    const totalW= Math.round(total/(7*24*3600*1000));
    progHtml = `
      <div class="tp-prog-bar"><div class="tp-prog-fill" style="width:${pct}%"></div></div>
      <div class="tp-prog-labels">
        <span>${start.toLocaleDateString('de-DE',{day:'numeric',month:'short',year:'numeric'})}</span>
        <span>${end.toLocaleDateString('de-DE',{day:'numeric',month:'short',year:'numeric'})}</span>
      </div>
      <div class="tp-prog-info">${pct}% · Woche ${Math.min(weekN,totalW)} von ${totalW}</div>
    `;
  }
  const durWeeks = end ? Math.round((end-start)/(7*24*3600*1000)) : null;
  const durChips = [4,6,8,12,16];
  durSec.innerHTML = `
    <div class="tp-kicker">// Plan-Laufzeit</div>
    <div class="tp-dur-chips">
      ${durChips.map(w=>`<div class="tp-dur-chip${durWeeks===w?' active':''}" data-weeks="${w}">${w} Wochen</div>`).join('')}
      <div class="tp-dur-chip${!end?' active':''}" data-weeks="0">Dauerhaft</div>
    </div>
    <div class="tp-cal-btn" id="tp-cal-btn">
      <span class="tp-cal-icon">📅</span>
      <span class="tp-cal-txt">Enddatum im Kalender wählen</span>
      <span class="tp-cal-date">${end?end.toLocaleDateString('de-DE',{day:'numeric',month:'short',year:'numeric'}):''}</span>
    </div>
    ${progHtml}
  `;
  body.appendChild(durSec);

  durSec.querySelectorAll('.tp-dur-chip').forEach(chip=>{
    chip.addEventListener('click',()=>{
      const w = parseInt(chip.dataset.weeks);
      if(w===0){ setTrainingPlanEndDate(null); }
      else{
        const d = parseDateKey(activePlanStartDate());
        d.setDate(d.getDate()+w*7);
        setTrainingPlanEndDate(dateKey(d));
      }
      saveState(S); renderTrainingPlanScreen();
    });
  });
  const calBtn = durSec.querySelector('#tp-cal-btn');
  if(calBtn){
    calBtn.addEventListener('click',()=>openPlanEndCalendar());
  }
}

let planCalMonth = new Date(today.getFullYear(), today.getMonth(), 1);

function openPlanEndCalendar(){
  const end = activePlanEndDate() ? parseDateKey(activePlanEndDate()) : today;
  planCalMonth = new Date(end.getFullYear(), end.getMonth(), 1);
  renderPlanEndCalendar();
  document.getElementById('plan-calendar-overlay')?.classList.add('open');
}

function closePlanEndCalendar(){
  document.getElementById('plan-calendar-overlay')?.classList.remove('open');
}

function renderPlanEndCalendar(){
  const grid = document.getElementById('plan-cal-grid');
  if(!grid) return;
  const title = document.getElementById('plan-cal-title');
  const hint = document.getElementById('plan-cal-hint');
  const year = planCalMonth.getFullYear();
  const month = planCalMonth.getMonth();
  if(title) title.textContent = `${DE_MONTHS[month]} ${year}`;
  grid.innerHTML = '';

  const first = new Date(year, month, 1);
  const offset = (first.getDay() + 6) % 7;
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const selected = activePlanEndDate() || '';
  const todayKey = todayStr;

  for(let i=0;i<offset;i++){
    const empty = document.createElement('div');
    empty.className = 'plan-cal-day empty';
    grid.appendChild(empty);
  }

  for(let day=1; day<=daysInMonth; day++){
    const d = new Date(year, month, day);
    const key = dateKey(d);
    const el = document.createElement('button');
    el.type = 'button';
    el.className = 'plan-cal-day' +
      (key === selected ? ' selected' : '') +
      (key === todayKey ? ' today' : '') +
      (d < new Date(today.toDateString()) ? ' disabled' : '');
    el.textContent = day;
    el.addEventListener('click',()=>{
      setTrainingPlanEndDate(key);
      saveState(S);
      closePlanEndCalendar();
      renderTrainingPlanScreen();
      if(currentScreen === 'training') renderTraining();
    });
    grid.appendChild(el);
  }

  if(hint){
    const days = selected ? inclusiveDaysUntil(selected) : null;
    hint.textContent = days ? `${days} Tage bis ${formatShortDate(selected)}` : 'Dauerhaft: keine Resttage-Anzeige.';
  }
}

document.getElementById('plan-cal-prev')?.addEventListener('click',()=>{
  planCalMonth = new Date(planCalMonth.getFullYear(), planCalMonth.getMonth() - 1, 1);
  renderPlanEndCalendar();
});
document.getElementById('plan-cal-next')?.addEventListener('click',()=>{
  planCalMonth = new Date(planCalMonth.getFullYear(), planCalMonth.getMonth() + 1, 1);
  renderPlanEndCalendar();
});
document.getElementById('plan-cal-close')?.addEventListener('click',closePlanEndCalendar);
document.getElementById('plan-cal-clear')?.addEventListener('click',()=>{
  setTrainingPlanEndDate(null);
  saveState(S);
  closePlanEndCalendar();
  renderTrainingPlanScreen();
  if(currentScreen === 'training') renderTraining();
});
document.getElementById('plan-calendar-overlay')?.addEventListener('click',e=>{
  if(e.target.id === 'plan-calendar-overlay') closePlanEndCalendar();
});

// ---------------------------------------------------------------
// TRAINING PLAN - WEEK MODE LOGIC
// ---------------------------------------------------------------
function handleWeekModeChange(newMode){
  const tp = S.trainingPlan;
  const oldMode = tp.weekMode;
  if(newMode===oldMode) return;

  if(newMode === 'rolling'){
    const rolling = ensureRollingPlan(true);
    rolling.startDate = rolling.startDate || tp.startDate || S.planConfig?.startDate || todayStr;
    rolling.endDate = rolling.endDate ?? tp.endDate ?? null;
    tp.weekMode = newMode;
    syncPlanConfigFromTrainingPlan();
    saveState(S);
    renderTrainingPlanScreen();
    renderProfile();
    if(currentScreen === 'training') renderTraining();
    return;
  }

  const oldWeeks = tpWeekList();
  const newWeeks = weekModeToWeeks(newMode);

  if(newWeeks.length > oldWeeks.length){
    // Adding weeks
    const toAdd = newWeeks.filter(w=>!oldWeeks.includes(w));
    let pending = [...toAdd];
    function addNext(){
      if(!pending.length){ tp.weekMode=newMode; syncPlanConfigFromTrainingPlan(); saveState(S); renderTrainingPlanScreen(); renderProfile(); return; }
      const wk = pending.shift();
      showConfirm(
        `Woche ${wk} anlegen`,
        `Soll Woche A als Vorlage für Woche ${wk} kopiert werden?`,
        [
          {label:'Ja, kopieren', cls:'fire', cb:()=>{ addWeek(wk,true); addNext(); }},
          {label:'Nein, leer starten', cls:'ghost', cb:()=>{ addWeek(wk,false); addNext(); }},
          {label:'Abbrechen', cls:'ghost', cb:()=>{}},
        ]
      );
    }
    addNext();
  } else if(newWeeks.length < oldWeeks.length){
    const toRemove = oldWeeks.filter(w=>!newWeeks.includes(w));
    showConfirm(
      `Woche${toRemove.length>1?'n':''} ${toRemove.join(', ')} entfernen`,
      `Woche${toRemove.length>1?'n':''} ${toRemove.join(', ')} werden archiviert. Alle bisherigen Logs bleiben erhalten.`,
      [
        {label:'Entfernen', cls:'danger', cb:()=>{
          toRemove.forEach(w=>{ if(tp.weeks[w]) tp.weeks[w].isArchived=true; });
          tp.weekMode=newMode;
          if(toRemove.includes(tpActiveWeek)) tpActiveWeek=newWeeks[0]||'A';
          if(toRemove.includes(profileActiveWeek)) profileActiveWeek=newWeeks[0]||'A';
          syncPlanConfigFromTrainingPlan();
          saveState(S); renderTrainingPlanScreen(); renderProfile();
        }},
        {label:'Abbrechen', cls:'ghost', cb:()=>{}},
      ]
    );
  } else {
    tp.weekMode=newMode; syncPlanConfigFromTrainingPlan(); saveState(S); renderTrainingPlanScreen(); renderProfile();
  }
}
function addWeek(label, copyFromA){
  const tp = S.trainingPlan;
  const sortOrder = Object.keys(tp.weeks).length;
  if(copyFromA && tp.weeks['A']){
    tp.weeks[label] = JSON.parse(JSON.stringify(tp.weeks['A']));
    tp.weeks[label].label = label;
    tp.weeks[label].sortOrder = sortOrder;
    // New IDs
    (tp.weeks[label].days?Object.values(tp.weeks[label].days):[]).forEach(day=>{
      (day.muscleGroups||[]).forEach(mg=>{ mg.id=genId(); (mg.exercises||[]).forEach(ex=>{ ex.id=genId(); }); });
    });
  } else {
    tp.weeks[label] = { label, sortOrder, days: buildEmptyWeekDays() };
  }
  syncPlanConfigFromTrainingPlan();
}
function handleAddWeek(label){
  showConfirm(
    `Woche ${label} anlegen`,
    `Soll Woche A als Vorlage für Woche ${label} kopiert werden?`,
    [
      {label:'Ja, kopieren', cls:'fire', cb:()=>{ addWeek(label,true); tpActiveWeek=label; profileActiveWeek=label; saveState(S); renderTrainingPlanScreen(); renderProfile(); }},
      {label:'Nein, leer starten', cls:'ghost', cb:()=>{ addWeek(label,false); tpActiveWeek=label; profileActiveWeek=label; saveState(S); renderTrainingPlanScreen(); renderProfile(); }},
      {label:'Abbrechen', cls:'ghost', cb:()=>{}},
    ]
  );
}
function handleDeleteWeek(wk){
  showConfirm(
    `Woche ${wk} entfernen`,
    `Woche ${wk} wird archiviert. Alle bisherigen Logs bleiben erhalten.`,
    [
      {label:'Entfernen', cls:'danger', cb:()=>{
        S.trainingPlan.weeks[wk].isArchived=true;
        if(tpActiveWeek===wk){ const wks=tpWeekList(); tpActiveWeek=wks[0]||'A'; }
        if(profileActiveWeek===wk){ const wks=tpWeekList(); profileActiveWeek=wks[0]||'A'; }
        if(tpWeekList().length<=1) S.trainingPlan.weekMode='single';
        syncPlanConfigFromTrainingPlan();
        saveState(S); renderTrainingPlanScreen(); renderProfile();
      }},
      {label:'Abbrechen', cls:'ghost', cb:()=>{}},
    ]
  );
}

// ---------------------------------------------------------------
// RENDER: DAY DETAIL SCREEN
// ---------------------------------------------------------------
function renderDayDetailDailyExercises(body, day){
  const exs = ensureDailyExercisesForDay(day)
    .filter(ex=>!ex.isArchived)
    .sort((a,b)=>(a.sortOrder ?? 0) - (b.sortOrder ?? 0));
  const sec = document.createElement('div');
  sec.className = 'tp-section';
  const rows = exs.map(ex=>`
    <div class="daily-plan-row" data-daily-edit="${escapeHtml(ex.id)}">
      <span class="daily-plan-icon">${escapeHtml(cleanUiIcon(ex.icon, '💪'))}</span>
      <span class="daily-plan-name">${escapeHtml(ex.name)}</span>
      <span class="daily-plan-meta">${timeOfDayMeta(ex.timeOfDay).icon} ${timeOfDayMeta(ex.timeOfDay).label} · ${Math.max(1, parseInt(ex.target)||1)} ${escapeHtml(ex.unit)} · +${Math.max(1, parseInt(ex.step)||1)}</span>
      <span class="daily-plan-del" data-daily-del="${escapeHtml(ex.id)}">×</span>
    </div>`).join('');
  sec.innerHTML = `
    <div class="tp-kicker">// über den tag</div>
    <div class="daily-plan-block">
      ${rows || '<div class="daily-plan-row" style="cursor:default;color:var(--text-muted);">Noch keine Tagesübungen</div>'}
      <div class="add-daily-row" id="add-daily-exercise">＋ Tagesübung hinzufügen</div>
    </div>
  `;
  body.appendChild(sec);
  sec.querySelector('#add-daily-exercise')?.addEventListener('click',()=>openTpDailyModal(null));
  sec.querySelectorAll('[data-daily-edit]').forEach(row=>{
    row.addEventListener('click',e=>{
      if(e.target.closest('[data-daily-del]')) return;
      openTpDailyModal(row.dataset.dailyEdit);
    });
  });
  sec.querySelectorAll('[data-daily-del]').forEach(btn=>{
    btn.addEventListener('click',e=>{
      e.stopPropagation();
      const ex = ensureDailyExercisesForDay(day).find(item=>item.id===btn.dataset.dailyDel);
      if(!ex) return;
      showConfirm(
        'Tagesübung archivieren?',
        `"${ex.name}" verschwindet aus diesem Tag. Bisherige Tageswerte bleiben im Verlauf erhalten.`,
        [
          {label:'Archivieren', cls:'danger', cb:()=>{ ex.isArchived=true; saveState(S); renderDayDetailScreen(); }},
          {label:'Abbrechen', cls:'ghost', cb:()=>{}},
        ]
      );
    });
  });
}

function renderDayDetailScreen(){
  const day = getDayDetailDay();
  if(!day) return;

  // Header
  if(ddActiveMode === 'rolling'){
    const displayDate = getRollingDisplayDate(ddActiveRollingIndex);
    const tpDow = (displayDate.getDay() + 6) % 7;
    document.getElementById('dd-header-title').textContent =
      `Tag ${ddActiveRollingIndex + 1} · ${TP_DAY_NAMES[tpDow]}`;
  } else {
    document.getElementById('dd-header-title').textContent =
      `${TP_DAY_NAMES[ddActiveDay]} · Woche ${ddActiveWeek}`;
  }
  const toggle = document.getElementById('dd-rest-toggle');
  toggle.checked = !!day.isRest;
  toggle.onchange = ()=>{
    day.isRest = toggle.checked;
    if(day.isRest && !day.label?.includes('Ruhetag')) day.label='Ruhetag';
    if(!day.isRest && day.label==='Ruhetag') day.label='Trainingstag';
    saveState(S); renderDayDetailScreen();
  };

  const body = document.getElementById('dd-body');
  body.innerHTML = '';

  // -- Label Input --
  const labelSec = document.createElement('div');
  labelSec.className = 'tp-section';
  labelSec.style.opacity = day.isRest?'0.55':'1';
  labelSec.innerHTML = `
    <div class="tp-kicker">// Tages-Bezeichnung</div>
    <input class="tp-input" id="dd-label-input" type="text"
      placeholder="z. B. Push Day, Pull Day, Kraft A..."
      maxlength="30" value="${(day.label||'').replace(/"/g,'&quot;')}">
    <div class="dd-chips">
      ${['Push','Pull','Beine','Oberkörper','Cardio','Kraft','Mobility','Pause']
        .map(c=>`<span class="dd-chip" data-val="${c}">${c}</span>`).join('')}
    </div>
  `;
  body.appendChild(labelSec);
  const labelIn = labelSec.querySelector('#dd-label-input');
  labelIn.addEventListener('input',()=>{
    day.label = labelIn.value.trim() || 'Trainingstag';
    saveState(S);
  });
  labelIn.addEventListener('blur',()=>{ day.label=labelIn.value.trim()||'Trainingstag'; saveState(S); renderTrainingPlanScreen(); });
  labelSec.querySelectorAll('.dd-chip').forEach(chip=>{
    chip.addEventListener('click',()=>{
      labelIn.value=chip.dataset.val; day.label=chip.dataset.val; saveState(S);
    });
  });

  if(day.isRest){ body.style.pointerEvents='none'; return; }
  body.style.pointerEvents='';
  renderDayDetailDailyExercises(body, day);

  // -- Muskelgruppen --
  const mgsEl = document.createElement('div');
  mgsEl.className = 'mg-blocks';
  const mgs = (day.muscleGroups||[]).filter(m=>!m.isArchived);

  mgs.forEach(mg=>{
    const exs = (mg.exercises||[]).filter(e=>!e.isArchived);
    const block = document.createElement('div');
    block.className = 'mg-block';

    // Header
    const hdr = document.createElement('div');
    hdr.className = 'mg-header-row';
    hdr.innerHTML = `
      <span class="mg-drag-h">::</span>
      <span class="mg-icon-h">${mg.icon||'💪'}</span>
      <span class="mg-name-h">${mg.name}</span>
      <span class="mg-count-h">${timeOfDayMeta(mg.timeOfDay).icon} ${timeOfDayMeta(mg.timeOfDay).short} · ${exs.length} Übung${exs.length!==1?'en':''}</span>
      <span class="mg-del-h" data-mgid="${mg.id}">×</span>
    `;
    hdr.querySelector('.mg-del-h').addEventListener('click',e=>{
      e.stopPropagation();
      showConfirm(
        'Muskelgruppe löschen?',
        `${mg.icon} ${mg.name} enthält ${exs.length} Übung${exs.length!==1?'en':''}. Alle Übungen werden archiviert.`,
        [
          {label:'Löschen', cls:'danger', cb:()=>{
            mg.isArchived=true; (mg.exercises||[]).forEach(e=>{ e.isArchived=true; });
            saveState(S); renderDayDetailScreen();
          }},
          {label:'Abbrechen', cls:'ghost', cb:()=>{}},
        ]
      );
    });
    block.appendChild(hdr);

    // Exercises
    const exWrap = document.createElement('div');
    exWrap.className = 'mg-exercises';
    exs.forEach(ex=>{
      const exRow = document.createElement('div');
      exRow.className = 'ex-row-tp';
      exRow.innerHTML = `
        <span class="ex-drag-h">::</span>
        <span class="ex-name-h">${ex.name}</span>
        <span class="ex-sets-h">${ex.timeOfDay && ex.timeOfDay !== 'inherit' ? timeOfDayMeta(ex.timeOfDay).icon + ' ' + timeOfDayMeta(ex.timeOfDay).short + ' · ' : ''}${ex.targetSets}×${ex.repsMin}-${ex.repsMax}</span>
        <span class="ex-rest-h">${ex.restSeconds}s</span>
        <span class="ex-del-h" data-exid="${ex.id}" data-mgid="${mg.id}">×</span>
      `;
      exRow.addEventListener('click',e=>{
        if(e.target.classList.contains('ex-del-h')){ e.stopPropagation(); return; }
        openTpExModal(mg.id, ex.id);
      });
      exRow.querySelector('.ex-del-h').addEventListener('click',e=>{
        e.stopPropagation();
        showConfirm(
          'Übung archivieren?',
          `"${ex.name}" wird archiviert. Alle bisherigen Logs bleiben erhalten.`,
          [
            {label:'Archivieren', cls:'danger', cb:()=>{ ex.isArchived=true; saveState(S); renderDayDetailScreen(); }},
            {label:'Abbrechen', cls:'ghost', cb:()=>{}},
          ]
        );
      });
      exWrap.appendChild(exRow);
    });

    // Add exercise row
    const addExRow = document.createElement('div');
    addExRow.className = 'add-ex-row-tp';
    addExRow.innerHTML = `+ Übung zu ${mg.name} hinzufügen`;
    addExRow.addEventListener('click',()=>openTpExModal(mg.id, null));
    exWrap.appendChild(addExRow);
    block.appendChild(exWrap);
    mgsEl.appendChild(block);
  });

  body.appendChild(mgsEl);

  // -- + Muskelgruppe --
  const addMgBlock = document.createElement('div');
  addMgBlock.className = 'add-mg-block';
  addMgBlock.innerHTML = '+ Muskelgruppe hinzufügen';
  addMgBlock.addEventListener('click',()=>openTpMgModal());
  body.appendChild(addMgBlock);
}

