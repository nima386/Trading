let _activeSettingsSheet = null;
function openSettingsSheet(id){
  const overlay = document.getElementById('settings-overlay');
  const shell = document.getElementById('settings-shell');
  const backdrop = document.getElementById('settings-sheet-backdrop');
  const sheet = document.getElementById(id);
  if(!overlay || !shell || !backdrop || !sheet) return;
  if(_activeSettingsSheet && _activeSettingsSheet !== sheet) closeSettingsSheet(true);
  _activeSettingsSheet = sheet;
  overlay.classList.add('sheet-open');
  shell.classList.add('settings-pushed');
  backdrop.classList.add('show');
  requestAnimationFrame(()=>requestAnimationFrame(()=>sheet.classList.add('show')));
}

function closeSettingsSheet(flush=true){
  if(flush) flushSettingsAutosave();
  const overlay = document.getElementById('settings-overlay');
  const shell = document.getElementById('settings-shell');
  const backdrop = document.getElementById('settings-sheet-backdrop');
  if(_activeSettingsSheet) _activeSettingsSheet.classList.remove('show');
  if(backdrop) backdrop.classList.remove('show');
  if(shell) shell.classList.remove('settings-pushed');
  if(overlay) overlay.classList.remove('sheet-open');
  _activeSettingsSheet = null;
}

