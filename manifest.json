function kasaiNotificationType(tag='', title=''){
  const key = `${tag} ${title}`.toLowerCase();
  if(key.includes('water') || key.includes('wasser')) return 'water';
  if(key.includes('habit')) return 'habits';
  if(key.includes('plan')) return 'plan';
  if(key.includes('success') || key.includes('erfolg') || key.includes('pr')) return 'success';
  return 'training';
}

