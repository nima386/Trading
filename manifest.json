function updatePasswordStrength(){
  const value = document.getElementById('gate-signup-password')?.value || '';
  const bars = [...document.querySelectorAll('#gate-pw-bars .pw-bar')];
  let score = 0;
  if(value.length >= 8) score++;
  if(/[A-Z]/.test(value) && /[a-z]/.test(value)) score++;
  if(/\d/.test(value)) score++;
  if(/[^A-Za-z0-9]/.test(value)) score++;
  bars.forEach((bar,i)=>{
    bar.className = 'pw-bar' + (i < score ? (score < 2 ? ' weak' : score < 4 ? ' med' : ' strong') : '');
  });
  const label = document.getElementById('gate-pw-label');
  if(label) label.textContent = score >= 4 ? `// stark · ${value.length} zeichen` : score >= 2 ? `// ok · ${value.length} zeichen` : '// zu schwach';
}
function getInitials(name){
  return (name||'').split(/\s+/).filter(Boolean).map(x=>x[0]).join('').slice(0,2).toUpperCase() || 'JM';
