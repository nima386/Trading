function scrollRunElementIntoView(el, behavior='smooth'){
  if(!el) return;
  const sheet = el.closest('.run-form-sheet');
  if(sheet){
    const sheetRect = sheet.getBoundingClientRect();
    const rect = el.getBoundingClientRect();
    const bottomPad = 22;
    const topPad = 18;
    if(rect.bottom > sheetRect.bottom - bottomPad){
      sheet.scrollBy({top: rect.bottom - sheetRect.bottom + bottomPad, behavior});
    } else if(rect.top < sheetRect.top + topPad){
      sheet.scrollBy({top: rect.top - sheetRect.top - topPad, behavior});
    }
    return;
  }
  const body = document.getElementById('run-screen-body') || el.closest('.screen-body');
  if(!body) {
    el.scrollIntoView({behavior, block:'center'});
    return;
  }
  const bodyRect = body.getBoundingClientRect();
  const rect = el.getBoundingClientRect();
  const bottomPad = 18;
  const topPad = 14;
  if(rect.bottom > bodyRect.bottom - bottomPad){
    body.scrollBy({top: rect.bottom - bodyRect.bottom + bottomPad, behavior});
  } else if(rect.top < bodyRect.top + topPad){
    body.scrollBy({top: rect.top - bodyRect.top - topPad, behavior});
  }
}

function scrollRunFormIntoView(){
  const form = document.getElementById('run-form');
  if(!form) return;
  requestAnimationFrame(()=>{
    scrollRunElementIntoView(form, 'smooth');
    setTimeout(()=>scrollRunElementIntoView(form, 'smooth'), 260);
  });
}

function keepRunInputAboveKeyboard(input){
  if(!input) return;
  const run = () => scrollRunElementIntoView(input, 'smooth');
  setTimeout(run, 80);
  setTimeout(run, 260);
  setTimeout(run, 520);
}

function setupRunFormViewportGuards(){
  if(_runFormViewportGuardReady) return;
  const form = document.getElementById('run-form');
  if(!form) return;
  _runFormViewportGuardReady = true;
  form.addEventListener('focusin', event=>{
    if(event.target.matches('input,select,textarea')) keepRunInputAboveKeyboard(event.target);
  });
  window.visualViewport?.addEventListener('resize', ()=>{
    if(currentScreen !== 'run') return;
    const active = document.activeElement;
    if(active && form.contains(active)) keepRunInputAboveKeyboard(active);
  });
}

function resetRunForm(){
  ['run-input-km','run-input-min','run-input-pauses'].forEach(id=>{ const el = document.getElementById(id); if(el) el.value = ''; });
  document.getElementById('run-input-date').value = todayStr;
  document.getElementById('run-input-type').value = 'Easy Run';
  document.getElementById('run-input-pr').checked = false;
  const proofInput = document.getElementById('run-input-proof');
  if(proofInput) proofInput.value = '';
  _pendingRunProofImages = [];
  updateRunProofPreview();
  document.getElementById('run-form-error').textContent = '';
  document.querySelectorAll('#run-form input').forEach(input=>input.classList.remove('invalid'));
}

async function saveRunEntry(){
  const kmEl = document.getElementById('run-input-km');
  const minEl = document.getElementById('run-input-min');
  const pausesEl = document.getElementById('run-input-pauses');
  const dateEl = document.getElementById('run-input-date');
  const typeEl = document.getElementById('run-input-type');
  const errorEl = document.getElementById('run-form-error');
  [kmEl,minEl,pausesEl,dateEl].forEach(el=>el?.classList.remove('invalid'));
  const km = parseNumberInput(kmEl.value);
  const min = parseIntegerInput(minEl.value);
  const pauses = Math.max(0, parseInt(pausesEl?.value || 0) || 0);
  const runDate = dateEl.value;
  const type = RUN_TYPES.includes(typeEl.value) ? typeEl.value : 'Easy Run';
  let error = '';
  if(!km || km <= 0){ kmEl.classList.add('invalid'); error = 'Distanz muss größer als 0 sein.'; }
  else if(!min || min <= 0){ minEl.classList.add('invalid'); error = 'Dauer muss größer als 0 sein.'; }
  else if(pauses > 99){ pausesEl?.classList.add('invalid'); error = 'Bitte maximal 99 Pausen eintragen.'; }
  else if(!runDate || parseDateKey(runDate) > today){ dateEl.classList.add('invalid'); error = 'Datum darf nicht in der Zukunft liegen.'; }
  if(error){
    errorEl.textContent = error;
    return;
  }
  S.runs.unshift({
    id: crypto?.randomUUID ? crypto.randomUUID() : genClientId('run'),
    date: runDate,
    km,
    min,
    type,
    pr: document.getElementById('run-input-pr').checked,
    pauses,
    proofImages: normalizeRunProofImages(_pendingRunProofImages),
    notes: '',
    createdAt: new Date().toISOString()
  });
  S.runTracker.formOpen = false;
  saveState(S);
  resetRunForm();
  renderRunTracker();
  if(authSession?.user){
    try{ await flushStateSync(); }catch(error){ console.warn('Run sync failed', error); }
  }
}

