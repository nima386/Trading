const notificationTimers = [];
const KASAI_WEB_PUSH_PUBLIC_KEY = window.KASAI_WEB_PUSH_PUBLIC_KEY || '';

function clearNotificationTimers(){
  while(notificationTimers.length) clearTimeout(notificationTimers.pop());
}

function notificationPermission(){
  return 'Notification' in window ? Notification.permission : 'unsupported';
}

function supportsNativeWebPush(){
  return 'serviceWorker' in navigator && 'PushManager' in window && 'Notification' in window;
}

function urlBase64ToUint8Array(base64String){
  const padding = '='.repeat((4 - base64String.length % 4) % 4);
  const base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
  const rawData = atob(base64);
  return Uint8Array.from([...rawData].map(char=>char.charCodeAt(0)));
}

async function ensureNativePushSubscription(){
  if(!supportsNativeWebPush()){
    if(S.settings) S.settings.webPushStatus = 'unsupported';
    return null;
  }
  if(!KASAI_WEB_PUSH_PUBLIC_KEY){
    if(S.settings) S.settings.webPushStatus = 'missing_vapid_key';
    return null;
  }
  const reg = await navigator.serviceWorker.ready;
  let subscription = await reg.pushManager.getSubscription();
  if(!subscription){
    subscription = await reg.pushManager.subscribe({
      userVisibleOnly: true,
      applicationServerKey: urlBase64ToUint8Array(KASAI_WEB_PUSH_PUBLIC_KEY)
    });
  }
  if(S.settings){
    S.settings.webPushStatus = 'subscribed';
    S.settings.webPushSubscription = subscription.toJSON();
  }
  return subscription;
}

async function requestNotificationPermission(){
  if(!('Notification' in window)){
    setAuthStatus('Benachrichtigungen werden auf diesem Gerät nicht unterstützt.', 'error');
    return 'unsupported';
  }
  const result = await Notification.requestPermission();
  normalizeNotificationSettings().permissionAsked = true;
  if(result === 'granted'){
    try{ await ensureNativePushSubscription(); }catch(error){ console.warn('Native web push subscription skipped', error); }
  }
  saveState(S);
  updateNotificationPermissionButton();
  scheduleNotifications();
  return result;
}

