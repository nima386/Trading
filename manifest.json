function setRunDetailProofStatus(text, tone='muted'){
  const el = document.getElementById('run-detail-proof-status');
  if(!el) return;
  el.textContent = text || '';
  el.style.color = tone === 'error' ? '#ff8fa0' : tone === 'ok' ? 'rgba(100,220,130,.78)' : 'rgba(255,255,255,.36)';
}

async function handleRunDetailProofFiles(runId, files, input){
  const run = (S.runs || []).find(item=>String(item.id) === String(runId));
  if(!run) return;
  const existing = normalizeRunProofImages(run.proofImages || []);
  const slots = Math.max(0, RUN_PROOF_LIMIT - existing.length);
  const selected = Array.from(files || []).slice(0, slots);
  if(input) input.value = '';
  if(!slots){
    setRunDetailProofStatus(`Maximal ${RUN_PROOF_LIMIT} Bilder pro Lauf.`, 'error');
    return;
  }
  if(!selected.length){
    setRunDetailProofStatus('');
    return;
  }
  try{
    setRunDetailProofStatus('Bilder werden komprimiert ...');
    const images = [];
    for(const file of selected) images.push(await compressRunProofFile(file));
    run.proofImages = normalizeRunProofImages([...existing, ...images]);
    run.updatedAt = new Date().toISOString();
    saveState(S);
    renderRunTracker();
    openRunDetail(runId);
    setRunDetailProofStatus('Beweisbilder gespeichert.', 'ok');
    if(authSession?.user){
      try{ await flushStateSync(); }catch(error){ console.warn('Run proof sync failed', error); }
    }
  }catch(error){
    setRunDetailProofStatus(error?.message || 'Bild konnte nicht geladen werden.', 'error');
  }
}

function openRunDetail(runId){
  const run = (S.runs || []).find(item=>String(item.id) === String(runId));
  if(!run) return;
  const overlay = ensureRunDetailOverlay();
  const content = document.getElementById('run-detail-content');
  const km = Number(run.km || 0);
  const min = Number(run.min || 0);
  const pace = km ? (min/km).toFixed(1) : '-';
  const d = parseDateKey(run.date);
  const pauses = Math.max(0, parseInt(run.pauses || 0) || 0);
  const images = normalizeRunProofImages(run.proofImages || []);
  const proofSlots = Math.max(0, RUN_PROOF_LIMIT - images.length);
  const gallery = images.length
    ? `<div class="run-proof-gallery">${images.map(img=>`<img src="${img.dataUrl}" alt="${escapeHtml(img.name || 'Beweisbild')}">`).join('')}</div>`
    : '<div class="run-proof-none">Keine Beweisbilder hinterlegt.</div>';
  content.innerHTML = `
    <div class="overlay-head" style="padding:0;margin-bottom:10px;">
      <div>
        <div class="kicker">// laufdetails</div>
        <div class="overlay-title">Run vom ${String(d.getDate()).padStart(2,'0')}.${String(d.getMonth()+1).padStart(2,'0')}</div>
      </div>
      <button class="overlay-close" type="button" data-run-detail-close>×</button>
    </div>
    <div class="run-detail-hero">
      <div class="run-detail-km">${km.toFixed(1)} km</div>
      <div class="run-detail-meta">${escapeHtml(run.type || 'Easy Run')} · ${Math.round(min)} min${run.pr ? ' · PR' : ''}</div>
    </div>
    <div class="run-detail-grid">
      <div class="run-detail-stat"><strong>${pace}</strong><span>min/km</span></div>
      <div class="run-detail-stat"><strong>${pauses}</strong><span>Pausen</span></div>
      <div class="run-detail-stat"><strong>${images.length}</strong><span>Bilder</span></div>
    </div>
    <div class="run-card-title">Beweisbilder</div>
    ${gallery}
    <div class="run-detail-proof-uploader">
      <label>
        <input data-run-detail-proof data-run-id="${escapeHtml(run.id)}" type="file" accept="image/*" multiple ${proofSlots ? '' : 'disabled'}>
        <div class="run-detail-proof-copy">
          <strong>${proofSlots ? 'Beweisbilder nachtragen' : 'Limit erreicht'}</strong>
          <span>${proofSlots ? `Noch ${proofSlots} Upload${proofSlots === 1 ? '' : 's'} möglich` : `Maximal ${RUN_PROOF_LIMIT} Bilder gespeichert`}</span>
        </div>
        <div class="run-detail-proof-action">${proofSlots ? 'Upload' : 'Voll'}</div>
      </label>
      <div class="run-detail-proof-status" id="run-detail-proof-status"></div>
    </div>
  `;
  overlay.classList.add('show');
}

