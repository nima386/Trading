  });
}

// KASAI Run Tracker - embedded Training section
const RUN_TYPES = ['Easy Run','Tempo','Long Run','Intervall'];
const RUN_PROOF_LIMIT = 3;
const _runWeekAnimatedSignatures = new Set();
let _pendingRunProofImages = [];
let _runFormViewportGuardReady = false;

function normalizeRunProofImages(images=[]){
  if(!Array.isArray(images)) return [];
  return images
    .map((img, index)=>{
      if(typeof img === 'string') return {id:`proof_${index}`, dataUrl:img, name:'Beweisbild', createdAt:new Date().toISOString()};
      if(!img || typeof img !== 'object' || !img.dataUrl) return null;
      return {
        id: img.id || genClientId('proof'),
        dataUrl: String(img.dataUrl),
        name: img.name || 'Beweisbild',
        type: img.type || '',
        createdAt: img.createdAt || new Date().toISOString()
      };
    })
    .filter(Boolean)
    .slice(0, RUN_PROOF_LIMIT);
}

function runProofPreviewMarkup(images=_pendingRunProofImages){
  const normalized = normalizeRunProofImages(images);
  if(!normalized.length) return '<div class="run-proof-empty">Optional · Screenshot hochladen</div>';
  return normalized.map(img=>`<img class="run-proof-thumb" src="${img.dataUrl}" alt="${escapeHtml(img.name || 'Beweisbild')}">`).join('');
}

function updateRunProofPreview(){
  const preview = document.getElementById('run-proof-preview');
  if(preview) preview.innerHTML = runProofPreviewMarkup();
}

function compressRunProofFile(file){
  return new Promise((resolve,reject)=>{
    if(!file || !file.type?.startsWith('image/')){
      reject(new Error('Bitte nur Bilder hochladen.'));
      return;
    }
    const reader = new FileReader();
    reader.onerror = () => reject(new Error('Bild konnte nicht gelesen werden.'));
    reader.onload = () => {
      const img = new Image();
      img.onerror = () => reject(new Error('Bild konnte nicht verarbeitet werden.'));
      img.onload = () => {
        const maxSide = 1200;
        const scale = Math.min(1, maxSide / Math.max(img.width, img.height));
        const canvas = document.createElement('canvas');
        canvas.width = Math.max(1, Math.round(img.width * scale));
        canvas.height = Math.max(1, Math.round(img.height * scale));
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
        resolve({
          id: genClientId('proof'),
          name: file.name || 'Beweisbild',
          type: 'image/jpeg',
          dataUrl: canvas.toDataURL('image/jpeg', .78),
          createdAt: new Date().toISOString()
        });
      };
      img.src = reader.result;
    };
    reader.readAsDataURL(file);
  });
}

async function handleRunProofFiles(files){
  const input = document.getElementById('run-input-proof');
  const errorEl = document.getElementById('run-form-error');
  const selected = Array.from(files || []).slice(0, RUN_PROOF_LIMIT);
  if(errorEl) errorEl.textContent = '';
  if(!selected.length){
    _pendingRunProofImages = [];
    updateRunProofPreview();
    return;
  }
  try{
    _pendingRunProofImages = [];
    updateRunProofPreview();
    const images = [];
    for(const file of selected) images.push(await compressRunProofFile(file));
    _pendingRunProofImages = images;
    updateRunProofPreview();
  }catch(error){
    if(errorEl) errorEl.textContent = error?.message || 'Bild konnte nicht geladen werden.';
    _pendingRunProofImages = [];
    updateRunProofPreview();
  }finally{
    if(input) input.value = '';
  }
}

function runMonthDate(){
  const offset = S.runTracker?.monthOffset || 0;
  return new Date(today.getFullYear(), today.getMonth() + offset, 1);
}
function runMonthKey(date){ return `${date.getFullYear()}-${String(date.getMonth()+1).padStart(2,'0')}`; }
function runsForMonth(monthDate=runMonthDate()){
  const key = runMonthKey(monthDate);
  return (S.runs || []).filter(run=>String(run.date || '').startsWith(key));
}
function sumRunsByDate(runs){
  return runs.reduce((acc, run)=>{
    if(!acc[run.date]) acc[run.date] = {km:0, min:0, count:0, pauses:0};
    acc[run.date].km += Number(run.km || 0);
    acc[run.date].min += Number(run.min || 0);
    acc[run.date].count += 1;
    acc[run.date].pauses += Math.max(0, parseInt(run.pauses || 0) || 0);
    return acc;
  }, {});
}
function formatRunMonth(monthDate){ return `${DE_MONTHS[monthDate.getMonth()]} ${monthDate.getFullYear()}`; }

function renderRunTracker(){
  moveRunSectionToScreen();
  if(!S.runTracker) S.runTracker = {chartMode:'km', monthOffset:0, formOpen:false};
  const monthDate = runMonthDate();
  const monthRuns = runsForMonth(monthDate);
  const prevMonthRuns = runsForMonth(new Date(monthDate.getFullYear(), monthDate.getMonth()-1, 1));
  const totalKm = monthRuns.reduce((sum, run)=>sum + Number(run.km || 0), 0);
  const prevKm = prevMonthRuns.reduce((sum, run)=>sum + Number(run.km || 0), 0);
  const runDays = Object.keys(sumRunsByDate(monthRuns)).length;
  const diff = totalKm - prevKm;
  const trend = document.getElementById('run-km-trend');
  document.getElementById('run-month-badge').textContent = `${DE_MONTHS[monthDate.getMonth()].slice(0,3)} ${monthDate.getFullYear()}`;
  document.getElementById('run-total-km').innerHTML = `${totalKm.toFixed(1)}<span>km</span>`;
  document.getElementById('run-days-count').innerHTML = `${runDays}<span>Tage</span>`;
  document.getElementById('run-avg-km').textContent = runDays ? `Ø ${(totalKm/runDays).toFixed(1)} km pro Lauftag` : 'Noch keine Läufe';
  trend.textContent = `${diff >= 0 ? '+' : ''}${diff.toFixed(1)} km vs. letzten Monat`;
  trend.className = 'run-stat-trend ' + (diff >= 0 ? 'up' : 'down');
  document.querySelectorAll('.run-mode-btn').forEach(btn=>btn.classList.toggle('active', btn.dataset.runMode === (S.runTracker.chartMode || 'km')));
  renderRunWeekBars();
  renderRunCalendar(monthDate, monthRuns);
  renderRunList();
  renderRunFormState();
}

function moveRunSectionToScreen(){
  const section = document.getElementById('run-tracker-section');
  const target = document.getElementById('run-screen-body');
  if(section && target && section.parentElement !== target) target.appendChild(section);
}

function renderRunWeekBars(){
  const wrap = document.getElementById('run-week-bars');
  if(!wrap) return;
  const mode = S.runTracker?.chartMode || 'km';
  const monday = new Date(today);
  monday.setDate(today.getDate() - ((today.getDay()+6)%7));
  const days = Array.from({length:7}, (_,i)=>{
    const d = new Date(monday);
    d.setDate(monday.getDate()+i);
    const key = dateKey(d);
    const runs = (S.runs || []).filter(run=>run.date === key);
    return {
      date:d,
      key,
      km:runs.reduce((sum, run)=>sum + Number(run.km || 0), 0),
      min:runs.reduce((sum, run)=>sum + Number(run.min || 0), 0),
      pauses:runs.reduce((sum, run)=>sum + (Math.max(0, parseInt(run.pauses || 0) || 0)), 0)
    };
  });
  const signature = `${mode}|${days.map(day=>`${day.key}:${day.km.toFixed(2)}:${Math.round(day.min)}:${day.pauses}`).join('|')}`;
  const shouldAnimate = !_runWeekAnimatedSignatures.has(signature);
  _runWeekAnimatedSignatures.add(signature);
  wrap.innerHTML = '';
  const max = Math.max(1, ...days.map(day=>mode === 'km' ? day.km : day.min));
  days.forEach((day, index)=>{
    const value = mode === 'km' ? day.km : day.min;
    const isToday = day.key === todayStr;
    const pct = value ? Math.max(8, value / max * 100) : 0;
    const pauseCount = Math.min(6, Math.max(0, parseInt(day.pauses || 0) || 0));
    const pauseMarkup = value && pauseCount ? `
          <div class="run-pause-stack" style="height:${pct}%">
            ${Array.from({length:pauseCount}, (_,i)=>`<i style="animation-delay:${i * 55}ms"></i>`).join('')}
            ${day.pauses > pauseCount ? `<span class="run-pause-more">+${day.pauses - pauseCount}</span>` : ''}
          </div>` : '';
    const col = document.createElement('div');
    col.className = 'run-bar-col';
    col.innerHTML = `
      <div class="run-bar-track ${isToday ? 'today' : ''}">
        ${value ? `<div class="run-bar-val">${mode === 'km' ? value.toFixed(1)+'k' : Math.round(value)+'m'}</div>` : ''}
        <div class="run-bar-fill ${value ? 'has-run' : ''} ${isToday ? 'today' : ''}" style="height:${shouldAnimate ? 0 : pct}%"></div>
        ${pauseMarkup}
      </div>
      <div class="run-bar-day ${isToday ? 'today' : ''}">${TP_DAY_ABBR[index].slice(0,1)}</div>`;
    wrap.appendChild(col);
    if(shouldAnimate){
      requestAnimationFrame(()=>setTimeout(()=>{
        const fill = col.querySelector('.run-bar-fill');
        if(fill) fill.style.height = `${pct}%`;
      }, index * 60));
    }
  });
}

function renderRunCalendar(monthDate, monthRuns){
  const label = document.getElementById('run-calendar-label');
  const grid = document.getElementById('run-cal-grid');
  if(!label || !grid) return;
  label.textContent = formatRunMonth(monthDate);
  grid.innerHTML = '';
  const byDate = sumRunsByDate(monthRuns);
  const y = monthDate.getFullYear();
  const m = monthDate.getMonth();
  const firstDow = (new Date(y,m,1).getDay()+6)%7;
  const daysInMonth = new Date(y,m+1,0).getDate();
  for(let i=0;i<firstDow;i++){
    const empty = document.createElement('div');
    empty.className = 'run-cal-cell empty';
    grid.appendChild(empty);
  }
  for(let day=1; day<=daysInMonth; day++){
    const d = new Date(y,m,day);
    const key = dateKey(d);
    const km = byDate[key]?.km || 0;
    const isFuture = d > today;
    const isToday = key === todayStr;
    let level = 'rest';
    if(isFuture) level = 'future';
    else if(km > 0 && km < 6) level = 'light';
    else if(km >= 6 && km < 10) level = 'medium';
    else if(km >= 10) level = 'heavy';
    const cell = document.createElement('div');
    cell.className = `run-cal-cell ${level} ${isToday ? 'today' : ''}`;
    cell.title = km ? `${km.toFixed(1)} km` : '';
    cell.innerHTML = `${day}${km && !isFuture ? '<span class="run-cal-dot"></span>' : ''}`;
    grid.appendChild(cell);
  }
}

function renderRunList(){
  const list = document.getElementById('run-list');
  if(!list) return;
  const showAll = !!S.runTracker?.showAllRuns;
  const sorted = [...(S.runs || [])].sort((a,b)=>String(b.date).localeCompare(String(a.date)) || String(b.createdAt||'').localeCompare(String(a.createdAt||'')));
  const visible = showAll ? sorted : sorted.slice(0,4);
  const allBtn = document.getElementById('run-show-all');
  if(allBtn) allBtn.textContent = showAll ? 'Weniger' : 'Alle →';
  if(!visible.length){
    list.innerHTML = '<div class="run-empty">Noch keine Läufe. Trag deinen ersten Run ein.</div>';
    return;
  }
  list.innerHTML = visible.map(run=>{
    const km = Number(run.km || 0);
    const min = Number(run.min || 0);
    const pace = km ? (min/km).toFixed(1) : '-';
    const d = parseDateKey(run.date);
    const cls = run.pr ? 'pr' : km >= 10 ? 'good' : 'normal';
    const pauses = Math.max(0, parseInt(run.pauses || 0) || 0);
    const proofCount = normalizeRunProofImages(run.proofImages || []).length;
    const pauseText = pauses ? ` · ${pauses} Pause${pauses === 1 ? '' : 'n'}` : '';
    const proofText = proofCount ? `<span class="run-proof-dot">▣ ${proofCount}</span>` : '';
    return `
      <div class="run-item ${cls}" data-run-detail="${escapeHtml(run.id)}">
        <div class="run-icon">🏃</div>
        <div class="run-info">
          <div class="run-name">${km.toFixed(1)} km${run.pr ? '<span class="run-pr-badge">PR</span>' : ''}${proofText}</div>
          <div class="run-meta">${String(d.getDate()).padStart(2,'0')}.${String(d.getMonth()+1).padStart(2,'0')} · ${escapeHtml(run.type || 'Easy Run')} · ${Math.round(min)} min${pauseText}</div>
        </div>
        <div class="run-right">
          <div class="run-km">${km.toFixed(1)}</div>
          <div class="run-pace">${pace} min/km</div>
        </div>
      </div>`;
  }).join('');
}

