function throwIfSyncFailed(results){
  const failed = results.filter(result=>result?.error);
  if(failed.length){
    const error = new Error(failed.map(result=>result.error?.message || 'Sync failed').join(' | '));
    error.results = failed;
    throw error;
  }
}

