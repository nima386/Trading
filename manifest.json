.sync-debug-card.show{display:block;}
.sync-debug-head{
  display:flex;align-items:center;justify-content:space-between;gap:10px;
  margin-bottom:9px;
}
.sync-debug-title{
  font-size:.72rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;
}
.sync-debug-pill{
  font-family:'JetBrains Mono',monospace;font-size:.52rem;
  color:var(--purple-300);padding:4px 8px;border-radius:999px;
  background:rgba(110,99,242,.12);border:1px solid rgba(110,99,242,.22);
}
.sync-debug-grid{
