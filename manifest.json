function withTimeout(promise, ms, label='Operation'){
  return Promise.race([
    promise,
    new Promise((_, reject)=>setTimeout(()=>reject(new Error(`${label} timeout`)), ms))
  ]);
}

const _SESSION_BACKUP_KEY = 'forge.supabase.auth.backup';
function rememberSupabaseSession(session){
  if(!session?.access_token || !session?.refresh_token || !session?.user) return;
  try{ localStorage.setItem(_SESSION_BACKUP_KEY, JSON.stringify(session)); }catch(_){}
}

function clearSupabaseSessionBackup(){
  try{ localStorage.removeItem(_SESSION_BACKUP_KEY); }catch(_){}
}

function validSupabaseSession(session){
  return session?.access_token && session?.refresh_token && session?.user ? session : null;
}

function readPersistedSupabaseSession(){
  try{
    const stored = JSON.parse(localStorage.getItem('forge.supabase.auth') || 'null');
    const session = validSupabaseSession(stored?.currentSession || stored?.session || stored);
    if(session){
      rememberSupabaseSession(session);
      return session;
    }
  }catch(_){
  }
  try{
    return validSupabaseSession(JSON.parse(localStorage.getItem(_SESSION_BACKUP_KEY) || 'null'));
  }catch(_){
    return null;
  }
}

async function restoreClientAuthSession(client, session){
  if(!client || !validSupabaseSession(session)) return session || null;
  try{
    const expiresAtMs = Number(session.expires_at || 0) * 1000;
    if(expiresAtMs && expiresAtMs < Date.now() + 60000){
      const refreshed = await withTimeout(
        client.auth.refreshSession({refresh_token:session.refresh_token}),
        6500,
        'Supabase refreshSession'
      );
      if(!refreshed.error && refreshed.data?.session){
        rememberSupabaseSession(refreshed.data.session);
        return refreshed.data.session;
      }
      if(refreshed.error) console.warn('Could not refresh persisted Supabase session', refreshed.error);
    }
    const restored = await withTimeout(
      client.auth.setSession({
        access_token: session.access_token,
        refresh_token: session.refresh_token
      }),
      6500,
      'Supabase setSession'
    );
    if(restored?.error){
      console.warn('Could not restore persisted Supabase session', restored.error);
      return session;
    }
    const nextSession = restored?.data?.session || session;
    rememberSupabaseSession(nextSession);
    return nextSession;
  }catch(error){
    console.warn('Persisted Supabase session restore failed', error);
    return session;
  }
}

async function ensureActiveSession(reason='auto'){
  if(_activeSessionPromise) return _activeSessionPromise;
  _activeSessionPromise = (async()=>{
    const client = await ensureForgeSupabaseClient();
    let session = authSession?.user && authSession.access_token ? authSession : null;
    if(client){
      try{
        const result = await withTimeout(client.auth.getSession(), 3500, 'Supabase getSession');
        if(result?.error) console.warn('Could not read Supabase session', result.error);
        else if(result?.data?.session) session = result.data.session;
      }catch(error){
        console.warn('Supabase getSession failed during session restore', {reason, error});
      }
    }
    if(!session) session = readPersistedSupabaseSession();
    if(client && session) session = await restoreClientAuthSession(client, session);
    if(session?.user){
      authSession = session;
      authLoading = false;
      rememberSupabaseSession(session);
      updateAuthUI();
      renderSyncDebug();
      return session;
    }
    return null;
  })().catch(error=>{
    console.warn('Could not ensure active session', {reason, error});
    return null;
  }).finally(()=>{
    _activeSessionPromise = null;
  });
  return _activeSessionPromise;
}

function getDeviceId(){
  const key = 'kasai_device_id';
  try{
    let id = localStorage.getItem(key);
    if(!id){
      id = (crypto?.randomUUID?.() || `kasai-${Date.now()}-${Math.random().toString(16).slice(2)}`);
      localStorage.setItem(key, id);
    }
    return id;
  }catch(_){
    return `kasai-${Date.now()}`;
  }
}

function getDeviceLabel(){
  const ua = navigator.userAgent || '';
  if(/iPhone/i.test(ua)) return 'iPhone';
  if(/iPad/i.test(ua)) return 'iPad';
  if(/Android/i.test(ua)) return 'Android';
  if(/Mac/i.test(ua)) return 'Mac';
  if(/Windows/i.test(ua)) return 'Windows';
  return 'Gerät';
}

function guessSyncArea(){
  const visibleOverlay = document.querySelector('.overlay.show,.overlay.active');
  if(visibleOverlay?.id === 'settings-overlay') return 'settings';
  if(visibleOverlay?.id === 'habit-overlay') return 'habits';
  if(visibleOverlay?.id === 'meal-overlay') return 'nutrition';
  if(visibleOverlay?.id === 'muscle-overlay' || visibleOverlay?.id === 'exercise-overlay') return 'training';
  if(currentScreen === 'profile') return 'profile';
  if(currentScreen === 'nutrition') return 'nutrition';
  if(currentScreen === 'habits') return 'habits';
  if(['training','training-plan','day-detail','exercise'].includes(currentScreen)) return 'training';
  if(currentScreen === 'run') return 'training';
  return 'app';
}

