function subscribeToUserRealtime(userId){
  if(!forgeSupabase || !userId) return;
  if(_userRealtimeChannel){
    try{ forgeSupabase.removeChannel(_userRealtimeChannel); }catch(_){}
    _userRealtimeChannel = null;
  }
  _realtimeStatus = 'connecting';
  renderSyncDebug();
  _userRealtimeChannel = forgeSupabase
    .channel(`kasai-user-state-${userId}`)
    .on('postgres_changes', {
      event: '*',
      schema: 'public',
      table: 'user_app_state',
      filter: `user_id=eq.${userId}`
    }, payload=>{
      const nextState = payload?.new?.state;
      if(!nextState || typeof nextState !== 'object') return;
      if(nextState._sync?.updatedByDevice === getDeviceId()) return;
      const incomingTime = stateTime(nextState, payload.new.updated_at);
      const currentTime = stateTime(S);
      const pendingTime = stateTime(readPendingState()?.state);
      if(incomingTime <= currentTime || incomingTime < pendingTime) return;
      S = nextState;
      normalizeState();
      saveLocalUserState(S);
      setSyncStatus('ok','// live aktualisiert');
      renderAll();
    })
    .subscribe(status=>{
      _realtimeStatus = status === 'SUBSCRIBED' ? 'verbunden' : String(status || 'wartet').toLowerCase();
      renderSyncDebug();
    });
}

async function loadLatestSyncEvent(userId=authSession?.user?.id){
  if(!forgeSupabase || !userId) return;
  try{
    const {data, error} = await forgeSupabase
      .from('user_sync_events')
      .select('created_at,status,area,error_message')
      .eq('user_id', userId)
      .order('created_at', {ascending:false})
      .limit(1)
      .maybeSingle();
    if(error) {
      console.warn('Latest sync event load failed', error);
      return;
    }
    if(data?.status === 'success') _lastSuccessfulSyncAt = data.created_at;
    if(data?.status === 'error') _lastSyncError = data.error_message || '';
    if(data?.area) _lastSyncArea = data.area;
    renderSyncDebug();
  }catch(error){
    console.warn('Latest sync event load failed', error);
  }
}

