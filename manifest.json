// ---------------------------------------------------
// REST TIMER
// ---------------------------------------------------
let _restInt = null;
let _restRemain = 0;

function smartRest(rMin, rMax){
  const avg = (rMin+rMax)/2;
  if(avg <= 5) return 180;
  if(avg <= 8) return 120;
  if(avg <= 12) return 90;
  return 60;
}

function fmtTime(sec){
  const m = Math.floor(sec/60);
  const s = sec%60;
  return `${m}:${String(s).padStart(2,'0')}`;
}

function startRest(seconds){
  clearInterval(_restInt);
  _restRemain = seconds;
  const banner = document.getElementById('rest-timer');
  banner.classList.remove('hidden');
  document.getElementById('rt-time').textContent = fmtTime(_restRemain);
  _restInt = setInterval(()=>{
    _restRemain--;
    if(_restRemain <= 0){
      clearInterval(_restInt);
      document.getElementById('rt-time').textContent = '0:00 -';
      if(navigator.vibrate) navigator.vibrate([120,80,120]);
      setTimeout(()=>banner.classList.add('hidden'), 1800);
      return;
    }
    document.getElementById('rt-time').textContent = fmtTime(_restRemain);
  },1000);
}
function stopRest(){
  clearInterval(_restInt);
  document.getElementById('rest-timer').classList.add('hidden');
}
document.getElementById('rt-plus')?.addEventListener('click',()=>{ _restRemain += 30; document.getElementById('rt-time').textContent = fmtTime(_restRemain); });
document.getElementById('rt-minus')?.addEventListener('click',()=>{ _restRemain = Math.max(5, _restRemain - 30); document.getElementById('rt-time').textContent = fmtTime(_restRemain); });
document.getElementById('rt-skip')?.addEventListener('click',stopRest);

