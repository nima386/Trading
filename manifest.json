function renderTraining(){
  ensureDailyState(selectedDateStr);
  const planInfo = getTodayPlan();
  const {plan, week, dow} = planInfo;
  const dateStr = getActiveDateLabel(selectedDate);
  document.getElementById('train-kicker').textContent = `// ${dateStr}`;
  document.getElementById('train-title').textContent = isSelectedToday() ? trainingHeaderLine : plan.label;
  const weekPill = document.getElementById('calendar-week-pill');
  if(weekPill) weekPill.textContent = `KW ${getISOWeek(selectedDate)}`;

  renderCalendar(dow);
  renderDailyQuote(selectedDate);
  renderTodayCard(plan, week, planInfo);
  renderTimeTaskStructure(plan);
  renderDailyExerciseTrackers();
  renderMuscles(plan);
  renderExerciseList(plan);
}

function getISOWeek(date){
  const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
  const dayNum = d.getUTCDay() || 7;
  d.setUTCDate(d.getUTCDate() + 4 - dayNum);
  const yearStart = new Date(Date.UTC(d.getUTCFullYear(),0,1));
  return Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
}

function renderCalendar(todayDow){
  const strip = document.getElementById('calendar-strip');
  strip.innerHTML = '';
  const start = new Date(selectedDate);
  start.setDate(selectedDate.getDate() - 10);

  for(let i=0;i<21;i++){
    const d = new Date(start);
    d.setDate(start.getDate() + i);
    const dow = d.getDay();
    const dayKey = dateKey(d);
    const dayPlan = getPlanForDate(d).plan;
    const isPast = d < new Date(today.toDateString());
    const hasSession = !!Object.values(S.sessions?.[dayKey] || {}).some(sess=>sess?.sets?.some(set=>set.done));
    const isActive = dayKey === selectedDateStr;
    const isToday = dayKey === todayStr;

    const el = document.createElement('div');
    el.className = 'cal-day' +
      (isActive?' active':'') +
      (isToday?' today':'') +
      (!isActive && hasSession?' done':'') +
      (dayPlan.type==='rest'?' rest':'');
    el.dataset.date = dayKey;
    el.title = isToday ? 'Heute' : dayKey;
    el.innerHTML = `
      <span class="cal-day-name">${DE_DAYS[dow]}</span>
      <span class="cal-day-num">${d.getDate().toString().padStart(2,'0')}</span>
      <span class="cal-dot"></span>`;
    el.addEventListener('click',()=>{
      setSelectedDate(d);
      renderAll();
    });
    strip.appendChild(el);
  }
  requestAnimationFrame(()=>{
    const active = strip.querySelector('.cal-day.active');
    if(!active) return;
    const targetLeft = active.offsetLeft - (strip.clientWidth - active.offsetWidth) / 2;
    strip.scrollTo({
      left: Math.max(0, targetLeft),
      behavior: 'smooth'
    });
  });
}

function renderTodayCard(plan, week, planInfo=null){
  const exs = getExercisesForType(plan.type);
  const muscles = getMusclesForType(plan.type);

  document.getElementById('today-day-label').textContent = plan.label;
  document.getElementById('week-label').textContent = planInfo?.isRolling
    ? `Tag ${planInfo.rollingIndex + 1} / ${planInfo.sequenceLength}`
    : `Woche ${week}`;
  document.getElementById('stat-exercises').textContent = exs.length || '0';
  document.getElementById('stat-duration').textContent = plan.duration ? `~${plan.duration}'` : '-';
  const countdown = document.getElementById('plan-countdown');
  const countdownText = document.getElementById('plan-countdown-text');
  const planEndDate = planInfo?.isRolling ? (S.trainingPlan?.rolling?.endDate || S.trainingPlan?.endDate) : S.trainingPlan?.endDate;
  const daysLeft = planEndDate ? inclusiveDaysUntil(planEndDate) : null;
  if(countdown && countdownText && daysLeft && daysLeft > 0){
    countdownText.textContent = `${daysLeft} Tage bis Plan-Ende`;
    countdown.classList.add('show');
  } else {
    countdown?.classList.remove('show');
  }

  const readEl = document.getElementById('stat-readiness');
  if(S.readiness[selectedDateStr] != null){
    const r = S.readiness[selectedDateStr];
    readEl.textContent = r.toFixed(1);
    readEl.style.color = r >= 7 ? 'var(--green)' : r >= 5 ? 'var(--amber)' : 'var(--red, #f06060)';
  } else {
    readEl.textContent = '-';
    readEl.style.color = 'var(--text-muted)';
  }

  const cta = document.getElementById('start-workout-btn');
  if(S.planConfig?.expired)     cta.textContent = 'Plan abgelaufen - verlängern oder neu anlegen?';
  else if(plan.type==='rest')   cta.textContent = '😴 Ruhetag - Protein, Habits & Erholung';
  else if(!muscles.length)      cta.textContent = '＋ Muskelgruppen anlegen';
  else if(!exs.length)          cta.textContent = '＋ Übungen hinzufügen';
  else                          cta.textContent = 'Training starten →';
}

function renderDailyExerciseTrackers(){
  const section = document.getElementById('daily-ex-section');
  const grid = document.getElementById('daily-ex-grid');
  if(!section || !grid) return;
  const exercises = getDailyExercisesForSelectedDay();
  if(!exercises.length){
    section.classList.remove('show');
    grid.innerHTML = '';
    return;
  }
  section.classList.add('show');
  grid.innerHTML = exercises.map(ex=>{
    const count = getDailyExerciseCount(ex.id);
    const target = Math.max(1, parseInt(ex.target) || 1);
    const pct = Math.min(100, Math.round(count / target * 100));
    const step = Math.max(1, parseInt(ex.step) || 1);
    return `
      <div class="daily-ex-card" data-daily-id="${escapeHtml(ex.id)}">
        <div class="daily-ex-head">
          <div class="daily-ex-icon">${escapeHtml(cleanUiIcon(ex.icon, '💪'))}</div>
          <div class="daily-ex-main">
            <div class="daily-ex-name">${escapeHtml(ex.name)}</div>
            <div class="daily-ex-sub">${timeOfDayMeta(ex.timeOfDay).icon} ${timeOfDayMeta(ex.timeOfDay).label} · Ziel ${target} ${escapeHtml(ex.unit)} · +${step}</div>
          </div>
          <div class="daily-ex-count">${count}</div>
        </div>
        <div class="daily-ex-bar"><div class="daily-ex-fill" style="width:${pct}%"></div></div>
        <div class="daily-ex-actions">
          <button class="daily-ex-plus" type="button" data-daily-add="${escapeHtml(ex.id)}">+${step} ${escapeHtml(ex.unit)}</button>
          <button class="daily-ex-menu" type="button" data-daily-set="${escapeHtml(ex.id)}">⋮</button>
        </div>
      </div>`;
  }).join('');
  grid.querySelectorAll('[data-daily-add]').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const ex = findDailyExerciseForSelectedDay(btn.dataset.dailyAdd);
      if(!ex) return;
      setDailyExerciseCount(ex.id, getDailyExerciseCount(ex.id) + (parseInt(ex.step) || 1));
      saveState(S);
      renderDailyExerciseTrackers();
    });
  });
  grid.querySelectorAll('[data-daily-set]').forEach(btn=>{
    btn.addEventListener('click',()=>openDailyExerciseAmount(btn.dataset.dailySet));
  });
  const editLink = document.getElementById('daily-ex-edit-link');
  if(editLink) editLink.onclick = ()=>openSelectedPlanDayEditor();
}

function getTimeTaskBucketsForSelectedDay(plan){
  const buckets = Object.fromEntries(TIME_OF_DAY_ORDER.map(key=>[key, []]));
  const day = getSelectedTrainingPlanDay();
  if(day && !day.isRest){
    ensureDailyExercisesForDay(day)
      .filter(ex=>!ex.isArchived)
      .forEach(ex=>{
        buckets[normalizeTimeOfDay(ex.timeOfDay)].push({
          kind:'daily',
          id: ex.id,
          icon: cleanUiIcon(ex.icon, '💪'),
          name: ex.name,
          sub: `Ziel ${Math.max(1, parseInt(ex.target)||1)} ${ex.unit || 'Wdh'} · ${getDailyExerciseCount(ex.id)}/${Math.max(1, parseInt(ex.target)||1)}`,
          done: getDailyExerciseCount(ex.id) >= Math.max(1, parseInt(ex.target)||1),
          payload: ex
        });
      });
    (day.muscleGroups || []).filter(mg=>!mg.isArchived).forEach(mg=>{
      const mgTime = normalizeTimeOfDay(mg.timeOfDay || 'morning');
      const exs = (mg.exercises || []).filter(ex=>!ex.isArchived).map(ex=>normalizePlanExercise(ex, mg));
      buckets[mgTime].push({
        kind:'muscle',
        id: mg.id,
        icon: cleanUiIcon(mg.icon, '💪'),
        name: mg.name,
        sub: `${exs.length} Übung${exs.length === 1 ? '' : 'en'} · ${areAllExercisesDone(exs) ? 'erledigt' : 'offen'}`,
        done: areAllExercisesDone(exs),
        payload: exs
      });
      exs.forEach(ex=>{
        const exTime = normalizeTimeOfDay(ex.timeOfDay || mgTime, mgTime);
        if(exTime === mgTime) return;
        buckets[exTime].push({
          kind:'exercise',
          id: ex.id,
          icon: '•',
          name: ex.name,
          sub: `${mg.name} · ${ex.sets}×${ex.rMin}-${ex.rMax}`,
          done: isDone(ex.id),
          payload: ex
        });
      });
    });
  } else {
    getMusclesForType(plan.type).forEach(mg=>{
      const timeKey = normalizeTimeOfDay(mg.timeOfDay || 'morning');
      buckets[timeKey].push({
        kind:'muscle',
        id: mg.id || mg.name,
        icon: cleanUiIcon(mg.icon, '💪'),
        name: mg.name,
        sub: 'Muskelgruppe',
        done: false,
        payload: []
      });
    });
  }
  return buckets;
}

function flashScrollTarget(el){
  if(!el) return;
  el.scrollIntoView({behavior:'smooth', block:'center'});
  el.classList.remove('scroll-focus');
  void el.offsetWidth;
  el.classList.add('scroll-focus');
  setTimeout(()=>el.classList.remove('scroll-focus'), 1400);
}

function findRenderedByDataset(selector, key, value){
  return Array.from(document.querySelectorAll(selector))
    .find(el=>String(el.dataset[key] || '') === String(value || ''));
}

function getExercisesForTimeTaskMuscle(id, name, plan){
  const day = getSelectedTrainingPlanDay();
  if(day && !day.isRest){
    const mg = (day.muscleGroups || []).find(item=>
      String(item.id || '') === String(id || '') || String(item.name || '') === String(name || '')
    );
    if(mg) return (mg.exercises || []).filter(ex=>!ex.isArchived).map(ex=>normalizePlanExercise(ex, mg));
  }
  return getExercisesForType(plan.type).filter(ex=>String(ex.muscle) === String(name));
}

function scrollToTrainingTask(kind, id, name){
  let target = null;
  if(kind === 'daily') target = findRenderedByDataset('.daily-ex-card', 'dailyId', id);
  if(kind === 'muscle') target = findRenderedByDataset('.cat-card[data-muscle-id]', 'muscleId', id)
    || Array.from(document.querySelectorAll('#muscle-grid .cat-card')).find(el=>el.querySelector('.cat-name')?.textContent.trim() === name);
  if(kind === 'exercise') target = findRenderedByDataset('.ex-card[data-exercise-id]', 'exerciseId', id);
  flashScrollTarget(target || document.getElementById(kind === 'daily' ? 'daily-ex-section' : kind === 'muscle' ? 'muscle-grid' : 'exercise-list'));
}

function renderTimeTaskStructure(plan){
  const section = document.getElementById('time-task-section');
  const grid = document.getElementById('time-task-grid');
  if(!section || !grid) return;
  const buckets = getTimeTaskBucketsForSelectedDay(plan);
  const hasAny = TIME_OF_DAY_ORDER.some(key=>buckets[key]?.length);
  if(!hasAny){
    section.style.display = plan.type === 'rest' ? 'none' : 'block';
    grid.innerHTML = plan.type === 'rest'
      ? ''
      : '<div class="time-task-card"><div class="time-task-head"><div class="time-task-title"><span>＋</span><div>Noch keine Tagesstruktur</div></div></div><div class="time-task-meta">lege Muskelgruppen oder Tagesübungen mit Tageszeit an</div></div>';
  } else {
    section.style.display = 'block';
    grid.innerHTML = TIME_OF_DAY_ORDER
      .filter(key=>buckets[key]?.length)
      .map(key=>{
        const meta = timeOfDayMeta(key);
        const items = buckets[key];
        return `
          <div class="time-task-card" style="--time-color:${meta.color}">
            <div class="time-task-head">
              <div class="time-task-title"><span>${meta.icon}</span><div>${meta.headline}</div></div>
              <div class="time-task-meta">${items.length} Aufgabe${items.length === 1 ? '' : 'n'}</div>
            </div>
            <div class="time-task-items">
              ${items.map(item=>`
                <div class="time-task-item" data-time-kind="${item.kind}" data-time-id="${escapeHtml(item.id)}" data-time-name="${escapeHtml(item.name)}">
                  <div class="time-task-icon">${escapeHtml(item.icon)}</div>
                  <div>
                    <div class="time-task-name">${escapeHtml(item.name)}</div>
                    <div class="time-task-sub">${escapeHtml(item.sub)}</div>
                  </div>
                  <button class="time-task-check${item.done?' done':''}" type="button" data-time-check="${item.kind}" data-time-id="${escapeHtml(item.id)}">${item.done?'✓':''}</button>
                </div>`).join('')}
            </div>
          </div>`;
      }).join('');
  }
  grid.querySelectorAll('[data-time-check]').forEach(btn=>{
    btn.addEventListener('click',event=>{
      event.preventDefault();
      event.stopPropagation();
      const kind = btn.dataset.timeCheck;
      const id = btn.dataset.timeId;
      if(kind === 'daily'){
        const ex = findDailyExerciseForSelectedDay(id);
        if(ex){
          const target = Math.max(1, parseInt(ex.target)||1);
          const isComplete = getDailyExerciseCount(id) >= target;
          setDailyExerciseCount(id, isComplete ? 0 : target);
          saveState(S);
          renderTraining();
        }
      } else if(kind === 'exercise'){
        const ex = getExercisesForType(plan.type).find(item=>String(item.id) === String(id));
        if(ex) toggleExerciseDone(ex);
      } else if(kind === 'muscle'){
        const row = btn.closest('.time-task-item');
        const muscleName = row?.dataset.timeName || '';
        const exs = getExercisesForTimeTaskMuscle(id, muscleName, plan);
        toggleMuscleExercisesDone(exs);
      }
    });
  });
  grid.querySelectorAll('.time-task-item').forEach(row=>{
    row.addEventListener('click',event=>{
      if(event.target.closest('[data-time-check]')) return;
      const kind = row.dataset.timeKind;
      const id = row.dataset.timeId;
      const name = row.dataset.timeName || row.querySelector('.time-task-name')?.textContent.trim() || '';
      scrollToTrainingTask(kind, id, name);
    });
  });
  const editLink = document.getElementById('time-task-edit-link');
  if(editLink) editLink.onclick = openSelectedPlanDayEditor;
}

function renderMuscles(plan){
  const grid = document.getElementById('muscle-grid');
  grid.innerHTML = '';
  const muscles = getMusclesForType(plan.type);
  if(!muscles.length){
    grid.innerHTML = plan.type==='rest'
      ? '<div style="color:var(--text-muted);font-size:.82rem;padding:8px 2px;">Ruhetag - kein Training heute.</div>'
      : '<div class="cat-card cat-add" data-action="add-muscle"><div class="cat-icon-wrap" style="background:rgba(110,99,242,0.15)">＋</div><div class="cat-name" style="color:var(--purple-300)">Muskelgruppe hinzufügen</div><div class="cat-meta">TIPPEN ZUM ANLEGEN</div></div>';
    grid.querySelectorAll('[data-action="add-muscle"]').forEach(el=>el.addEventListener('click',()=>{
      if(getSelectedTrainingPlanDay()) openSelectedPlanDayEditor();
      else openMuscleEdit(null,plan.type);
    }));
    return;
  }
  const exs = getExercisesForType(plan.type);

  muscles.forEach((mObj,i)=>{
    const m = mObj.name;
    const icon = mObj.icon || MUSCLE_META[m]?.icon || '💪';
    const color = mObj.color || MUSCLE_META[m]?.color || 'var(--purple-500)';
    const mExs = exs.filter(e=>e.muscle===m);
    const mSets = mExs.reduce((a,e)=>a+e.sets,0);
    const doneSets = mExs.filter(e=>isDone(e.id)).reduce((a,e)=>a+e.sets,0);
    const pct = mSets ? Math.round(doneSets/mSets*100) : 0;
    const timeMeta = timeOfDayMeta(mObj.timeOfDay || 'morning');

    const isLastOdd = (i === muscles.length-1) && (muscles.length % 2 === 1) && muscles.length>1;
    const isSingle  = muscles.length === 1;
    const fullWidth = isLastOdd || isSingle;
    const suffix    = isLastOdd ? ' · ZUM SCHLUSS' : '';
    const exLabel   = mExs.length === 1 ? 'ÜBUNG' : 'ÜBUNGEN';

    const el = document.createElement('div');
    el.className = 'cat-card premium-muscle';
    el.dataset.muscleId = mObj.id || m;
    el.setAttribute('style', `${fullWidth ? 'grid-column:span 2;' : ''}--cat-color:${color};--cat-pct:${pct};`);
    el.innerHTML = `
      <div class="cat-top">
        <div class="cat-icon-wrap" style="background:${color}22">${icon}</div>
        <div class="cat-progress-ring" data-pct="${pct}%"></div>
      </div>
      <div class="cat-name">${m}</div>
      <div class="cat-meta"><span class="time-chip">${timeMeta.icon} ${timeMeta.short}</span></div>
      <div class="cat-meta">${mExs.length} ${exLabel} · ${mSets} SÄTZE${suffix}</div>
      <div class="cat-prog" style="width:${pct}%;background:${color}"></div>`;
    el.onclick = ()=>{ if(mExs.length) navigate('exercise', mExs[0]); };
    let pT;
    el.addEventListener('touchstart',()=>{ pT = setTimeout(()=>{
      if(getSelectedTrainingPlanDay()) openSelectedPlanDayEditor();
      else openMuscleEdit(mObj.id, plan.type);
    }, 550); }, {passive:true});
    el.addEventListener('touchend',()=>clearTimeout(pT));
    el.addEventListener('touchmove',()=>clearTimeout(pT));
    el.addEventListener('contextmenu',e=>{
      e.preventDefault();
      if(getSelectedTrainingPlanDay()) openSelectedPlanDayEditor();
      else openMuscleEdit(mObj.id, plan.type);
    });
    grid.appendChild(el);
  });

  // + Add-Card am Ende
  const addEl = document.createElement('div');
  addEl.className = 'cat-card cat-add';
  if(muscles.length % 2 === 0) addEl.setAttribute('style','grid-column:span 2');
  addEl.innerHTML = `
    <div class="cat-icon-wrap" style="background:rgba(110,99,242,0.15)">＋</div>
    <div class="cat-name" style="color:var(--purple-300)">Hinzufügen</div>
    <div class="cat-meta">NEUE MUSKELGRUPPE</div>`;
  addEl.addEventListener('click',()=>{
    if(getSelectedTrainingPlanDay()) openSelectedPlanDayEditor();
    else openMuscleEdit(null, plan.type);
  });
  grid.appendChild(addEl);
}

