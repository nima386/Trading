function enhancePremiumButton(btn, variant='login'){
  if(!btn || btn.dataset.premiumEnhanced === '1') return;
  btn.dataset.premiumEnhanced = '1';
  btn.classList.add('kasai-btn');
  btn.classList.toggle('kasai-btn-login', variant !== 'logout');
  btn.classList.toggle('kasai-btn-logout', variant === 'logout');
  const label = btn.innerHTML.trim();
  const isLogout = variant === 'logout';
  const effect = isLogout
    ? '<span class="kasai-btn-halo logout-halo"></span><span class="ring-logout r1"></span><span class="ring-logout r2"></span><span class="ring-logout r3"></span>'
    : '<span class="kasai-btn-halo login-halo"></span><span class="login-core"></span><span class="ring-login r1"></span><span class="ring-login r2"></span><span class="ring-login r3"></span>';
  const dots = isLogout
    ? '<div class="kasai-dot" style="background:rgba(255,85,119,.9)"></div><div class="kasai-dot" style="background:rgba(255,85,119,.9)"></div><div class="kasai-dot" style="background:rgba(255,85,119,.9)"></div>'
    : '<div class="kasai-dot"></div><div class="kasai-dot"></div><div class="kasai-dot"></div>';
  const text = isLogout && !label.includes('power-icon')
    ? `<span class="power-icon">⏻</span>${label.replace(/[⏻-]/g,'').trim()}`
    : label;
  btn.innerHTML = `
    ${effect}
    <span class="kasai-btn-text">${text}</span>
    <div class="kasai-btn-dots">${dots}</div>
    <div class="kasai-btn-check">
      <svg class="kasai-check-svg" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="4 12 9 17 20 7"></polyline>
      </svg>
    </div>
  `;
}

function setButtonLoading(btn, loading){
  if(!btn) return;
  btn.disabled = !!loading;
  btn.classList.toggle('loading', !!loading);
  if(loading) btn.classList.remove('success');
}

function setButtonSuccess(btn, duration=520){
  if(!btn) return Promise.resolve();
  btn.classList.remove('loading');
  btn.classList.add('success');
  return new Promise(resolve=>setTimeout(()=>{
    btn.classList.remove('success');
    btn.disabled = false;
    resolve();
  }, duration));
}

