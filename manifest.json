  else setSyncStatus('error','// sync später erneut');
}

async function refreshAuthSession(){
  if(_refreshAuthPromise) return _refreshAuthPromise;
  _refreshAuthPromise = (async()=>{
    try{
      const session = await ensureActiveSession('refresh');
      authSession = session || null;
      authLoading = false;
      updateAuthUI();
      if(authSession?.user) {
        await acquireExclusiveDevice(authSession);
        renderLocalUserState(authSession);
        try{
          await withTimeout(loadUserData(authSession.user.id, authSession), 6500, 'user data load');
          await withTimeout(flushPendingState(), 5500, 'pending save');
          subscribeToUserRealtime(authSession.user.id);
          scheduleNotifications();
        }catch(error){
          console.warn('Startup data sync failed, continuing with available local state.', error);
          const localBackup = loadLocalUserState(authSession);
          if(localBackup) {
            S = localBackup;
            normalizeState();
            renderAll();
          }
        }
      }
      return authSession;
    }catch(error){
      console.warn('Auth refresh failed', error);
      authSession = readPersistedSupabaseSession();
      if(authSession?.user) {
        authLoading = false;
        updateAuthUI();
        renderSyncDebug();
      }
      return authSession;
    }finally{
      authLoading = false;
      updateAuthUI();
      if(authSession?.user) renderAll();
    }
  })();
  try{
    return await _refreshAuthPromise;
  }finally{
    _refreshAuthPromise = null;
  }
}
window.refreshAuthSession = refreshAuthSession;

