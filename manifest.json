  S.muscles[type] = S.muscles[type].filter(x=>x.id!==_editingMuscleId);
  if(removed){
    S.archivedMuscleGroups[_editingMuscleId] = {...removed, archived:true, archivedAt:new Date().toISOString(), type};
  }
  if(affected.length){
    affected.forEach(ex=>{
      S.archivedExercises[ex.id] = {...ex, archived:true, archivedAt:new Date().toISOString(), archivedReason:'muscle_group_deleted'};
