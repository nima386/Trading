function kasaiNotificationPayload(title, body, tag){
  const type = kasaiNotificationType(tag, title);
  const current = S?.hydration?.[todayStr] || 0;
  const waterGoal = parseIntegerInput(S?.profile?.waterGoal) || 3000;
  const base = {
    title,
    body,
    tag,
    type,
    time: new Date().toLocaleTimeString('de-DE', {hour:'2-digit', minute:'2-digit'}),
    label: 'Training',
    headline: title.replace(/^KASAI\s*/i, '') || 'KASAI',
    description: body || '',
    actionLabel: 'Öffnen',
    ghostLabel: 'Später',
    progress: null
  };
  if(type === 'training') return Object.assign(base, {
    label: 'Training',
    headline: 'Training steht an',
    actionLabel: 'Training starten'
  });
  if(type === 'water') return Object.assign(base, {
    label: 'Wasser',
    headline: 'Zeit für ein Glas Wasser',
    description: body || `Du hast heute ${Math.round(current/100)/10}L / ${Math.round(waterGoal/100)/10}L getrunken.`,
    actionLabel: '+250ml',
    ghostLabel: 'Erledigt',
    progress: Math.min(100, Math.round((current / Math.max(1, waterGoal)) * 100))
  });
  if(type === 'habits') return Object.assign(base, {
    label: tag?.startsWith('kasai-habit-') ? 'Habit' : 'Habits',
    headline: tag?.startsWith('kasai-habit-') ? 'Habit offen' : 'Habits offen',
    actionLabel: 'Habits checken',
    ghostLabel: 'Ignorieren'
  });
  if(type === 'plan') return Object.assign(base, {
    label: 'Neuer Zyklus',
    headline: 'Trainingsplan Erinnerung',
    actionLabel: 'Plan öffnen'
  });
  return Object.assign(base, {
    label: 'Erfolg',
    headline: title.replace(/^KASAI\s*/i, '') || 'Stark gemacht',
    actionLabel: 'Stats'
  });
}

function closeKasaiToast(toast){
  if(!toast || toast.classList.contains('is-leaving')) return;
  toast.classList.add('is-leaving');
  setTimeout(()=>toast.remove(), 230);
}

function handleKasaiNotificationAction(payload){
  if(payload.type === 'water'){
    ensureDailyState(todayStr);
    S.hydration[todayStr] = (S.hydration[todayStr] || 0) + 250;
    saveState(S);
    if(currentScreen === 'nutrition') renderHydration();
    return;
  }
  if(payload.type === 'habits'){
    navigate('habits');
    return;
  }
  if(payload.type === 'plan'){
    if(typeof openTrainingPlanScreen === 'function') openTrainingPlanScreen();
    else navigate('profile');
    return;
  }
  navigate('training');
}

function showKasaiInAppNotification(payload){
  const layer = ensureKasaiNotificationLayer();
  const uid = `kasai-notif-${++kasaiNotificationSeq}`;
  const toast = document.createElement('div');
  toast.className = `kasai-toast kasai-toast--${payload.type}`;
  toast.dataset.tag = payload.tag || '';
  toast.innerHTML = `
    <div class="kasai-toast-glass">
      <button class="kasai-toast-dismiss" type="button" aria-label="Schließen">×</button>
      <div class="kasai-toast-accent"></div>
      <div class="kasai-toast-body">
        <div class="kasai-toast-icon">${kasaiNotificationIcon(payload.type, uid)}</div>
        <div class="kasai-toast-content">
          <div class="kasai-toast-header">
            <div class="kasai-toast-tag"><span class="kasai-toast-tag-dot"></span>${escapeHtml(payload.label)}</div>
            <div class="kasai-toast-time">${escapeHtml(payload.time)}</div>
          </div>
          <div class="kasai-toast-title">${escapeHtml(payload.headline)}</div>
          <div class="kasai-toast-desc">${escapeHtml(payload.description)}</div>
        </div>
      </div>
      ${payload.progress !== null ? `<div class="kasai-toast-progress-wrap"><div class="kasai-toast-progress"><div class="kasai-toast-progress-fill" style="width:${payload.progress}%"></div></div></div>` : ''}
      <div class="kasai-toast-actions">
        <button class="kasai-toast-btn kasai-toast-btn--primary" type="button" data-kasai-action="primary">${escapeHtml(payload.actionLabel)}</button>
        <button class="kasai-toast-btn kasai-toast-btn--ghost" type="button" data-kasai-action="dismiss">${escapeHtml(payload.ghostLabel)}</button>
      </div>
    </div>
  `;
  toast.querySelector('.kasai-toast-dismiss')?.addEventListener('click',()=>closeKasaiToast(toast));
  toast.querySelector('[data-kasai-action="dismiss"]')?.addEventListener('click',()=>closeKasaiToast(toast));
  toast.querySelector('[data-kasai-action="primary"]')?.addEventListener('click',()=>{
    handleKasaiNotificationAction(payload);
    closeKasaiToast(toast);
  });
  layer.prepend(toast);
  Array.from(layer.children).slice(3).forEach(closeKasaiToast);
  setTimeout(()=>closeKasaiToast(toast), payload.type === 'water' ? 9000 : 7200);
}

async function showKasaiNativeNotification(payload){
  if(notificationPermission() !== 'granted') return;
  const options = {
    body: payload.body,
    tag: payload.tag,
    badge: './icons/icon-192.png',
    icon: './icons/icon-192.png',
    data: {url: location.href, type: payload.type}
  };
  try{
    const reg = await navigator.serviceWorker?.ready;
    if(reg?.showNotification) return reg.showNotification(payload.title, options);
  }catch(_){}
  try{ new Notification(payload.title, options); }catch(_){}
}

async function showKasaiNotification(title, body, tag){
  const payload = kasaiNotificationPayload(title, body, tag);
  if(canShowKasaiInAppNotification()){
    showKasaiInAppNotification(payload);
    return;
  }
  return showKasaiNativeNotification(payload);
}

function minutesFromTime(time){
  const [h,m] = String(time || '08:00').split(':').map(Number);
  return (Number.isFinite(h) ? h : 8) * 60 + (Number.isFinite(m) ? m : 0);
}

function nextDateForTime(time){
  const [h,m] = String(time || '08:00').split(':').map(Number);
  const next = new Date();
  next.setHours(Number.isFinite(h) ? h : 8, Number.isFinite(m) ? m : 0, 0, 0);
  if(next <= new Date()) next.setDate(next.getDate() + 1);
  return next;
}

function scheduleAt(date, fn){
  const delay = Math.max(1000, date.getTime() - Date.now());
  const timer = setTimeout(()=>{ fn(); scheduleNotifications(); }, Math.min(delay, 2147483647));
  notificationTimers.push(timer);
}

function planReminderText(){
  const info = getPlanForDate(new Date());
  const plan = info.plan;
  const suffix = info.isRolling ? `Tag ${info.rollingIndex + 1}/${info.sequenceLength}` : `Woche ${info.week || 'A'}`;
  return `Heute ist ${plan?.label || 'Trainingstag'} · ${suffix}`;
}

function planReminderTextForTime(timeKey, items=[]){
  const meta = timeOfDayMeta(timeKey);
  const names = items.map(item=>item.name).filter(Boolean).slice(0, 3).join(', ');
  const more = items.length > 3 ? ` +${items.length - 3}` : '';
  return `${meta.label}: ${names || planReminderText()}${more}`;
}

function getTrainingNotificationBuckets(date=new Date()){
  const buckets = Object.fromEntries(TIME_OF_DAY_ORDER.map(key=>[key, []]));
  const day = getTrainingPlanDayForDate(date);
  if(!day || day.isRest) return buckets;
  ensureDailyExercisesForDay(day)
    .filter(ex=>!ex.isArchived)
    .forEach(ex=>{
      const timeKey = normalizeTimeOfDay(ex.timeOfDay || 'morning');
      buckets[timeKey].push({kind:'daily', name:ex.name});
    });
  (day.muscleGroups || []).filter(mg=>!mg.isArchived).forEach(mg=>{
    const mgTime = normalizeTimeOfDay(mg.timeOfDay || 'morning');
    const activeExercises = (mg.exercises || []).filter(ex=>!ex.isArchived);
    buckets[mgTime].push({kind:'muscle', name:mg.name});
    activeExercises.forEach(ex=>{
      const explicit = ex.timeOfDay && ex.timeOfDay !== 'inherit';
      const exTime = explicit ? normalizeTimeOfDay(ex.timeOfDay, mgTime) : mgTime;
      if(exTime !== mgTime) buckets[exTime].push({kind:'exercise', name:ex.name});
    });
  });
  return buckets;
}

function openHabitCount(){
  ensureDailyState(todayStr);
  return getActiveHabitsForDate(todayStr).filter(h=>!S.habits[todayStr]?.[h.id]).length;
}

function scheduleNotifications(){
  clearNotificationTimers();
  const n = normalizeNotificationSettings();
  if(!authSession?.user || !S.settings.notificationsEnabled) return;
  if(notificationPermission() !== 'granted' && !canShowKasaiInAppNotification()) return;
  if(n.training.enabled){
    const buckets = getTrainingNotificationBuckets(new Date());
    TIME_OF_DAY_ORDER.forEach(timeKey=>{
      const items = buckets[timeKey] || [];
      if(!items.length) return;
      scheduleAt(nextDateForTime(timeOfDayMeta(timeKey).notifyTime), ()=>{
        showKasaiNotification('KASAI Training', planReminderTextForTime(timeKey, items), `kasai-training-${timeKey}`);
      });
    });
  }
  if(n.planStart.enabled){
    scheduleAt(nextDateForTime('07:45'), ()=>{
      const start = S.trainingPlan?.startDate || S.planConfig?.startDate || todayStr;
      const prefix = start === todayStr ? 'Dein Plan startet heute.' : `Plan-Start: ${formatDateShort(parseDateKey(start))}`;
      showKasaiNotification('KASAI Plan', `${prefix} ${planReminderText()}`, 'kasai-plan');
    });
  }
  if(n.habits.enabled){
    scheduleAt(nextDateForTime(n.habits.time), ()=>{
      const count = openHabitCount();
      if(count > 0) showKasaiNotification('KASAI Habits', `${count} Habit${count===1?'':'s'} heute noch offen.`, 'kasai-habits');
    });
  }
  getActiveHabitsForDate(todayStr)
    .filter(h=>h.reminder?.enabled && h.reminder?.time)
    .forEach(h=>{
      scheduleAt(nextDateForTime(h.reminder.time), ()=>{
        if(!S.habits[todayStr]?.[h.id]){
          showKasaiNotification('KASAI Habit', `${cleanUiIcon(h.icon, '+')} ${h.name} ist noch offen.`, `kasai-habit-${h.id}`);
        }
      });
    });
  if(n.water.enabled){
    const nowMin = new Date().getHours() * 60 + new Date().getMinutes();
    const start = minutesFromTime(n.water.start);
    const end = minutesFromTime(n.water.end);
    const interval = Math.max(30, Number(n.water.intervalMinutes || 90));
    let nextMin = Math.max(start, nowMin + interval);
    if(nextMin > end) nextMin = start + 1440;
    const next = new Date();
    next.setHours(Math.floor((nextMin % 1440) / 60), nextMin % 60, 0, 0);
    if(nextMin >= 1440) next.setDate(next.getDate() + 1);
    scheduleAt(next, ()=>{
      showKasaiNotification('KASAI Wasser', 'Zeit für Wasser. Kleine Schlucke, großer Unterschied.', 'kasai-water');
    });
  }
}

function updateNotificationPermissionButton(){
  const btn = document.getElementById('notify-permission');
  if(!btn) return;
  const permission = notificationPermission();
  btn.textContent = permission === 'granted'
    ? 'Benachrichtigungen aktiv'
    : permission === 'denied'
      ? 'Benachrichtigungen im Browser erlauben'
      : 'Benachrichtigungen erlauben';
}

