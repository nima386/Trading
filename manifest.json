if('serviceWorker' in navigator){
  navigator.serviceWorker.register('sw.js').then(reg=>{
    reg.update?.().catch(()=>{});
    if(reg.waiting) reg.waiting.postMessage({type:'SKIP_WAITING'});
  }).catch(()=>{});
  let _swReloaded = false;
  navigator.serviceWorker.addEventListener('controllerchange',()=>{
    if(_swReloaded) return;
    _swReloaded = true;
    window.location.reload();
  });
}

// ---------------------------------------------------
// 🆕 PROTEIN TRACKER
// ---------------------------------------------------
function calcProteinTarget(weightKg, mn, mx){
  return { min: Math.round(weightKg*mn), max: Math.round(weightKg*mx) };
}
function evaluateProtein(g, t){
  if(g >= t.min && g <= t.max) return 'green';
  if(g > t.max) return 'teal';
  const ratio = g/t.min;
  if(ratio >= 0.8) return 'amber';
  if(ratio >= 0.6) return 'orange';
  return 'red';
}
const STATUS_LABELS = {
  red:'ZU WENIG', orange:'KNAPP DRUNTER', amber:'FAST GESCHAFFT',
  green:'IM ZIEL -', teal:'ÜBER ZIEL'
};
const STATUS_COLOR = {
  red:'var(--red, #f06060)', orange:'var(--orange)', amber:'var(--amber)',
  green:'var(--green)', teal:'var(--teal)'
};

function getProteinG(){
  // mock: aus DEFAULT_MEALS Protein-Anteil ableiten (ca 20% kcal)
  // bzw aus state, falls erweitert
  const meals = (S.meals && S.meals[selectedDateStr]) || [];
  const total = meals.reduce((a,m)=>a+(m.protein || Math.round(m.kcal*0.2/4)),0);
  return total;
}

function renderProtein(){
  const p = S.profile;
  const weightKg = parseNumberInput(p.weightKg);
  const proteinMin = parseNumberInput(p.proteinMin);
  const proteinMax = parseNumberInput(p.proteinMax);
  const g = getProteinG();
  const hasTarget = weightKg && proteinMin && proteinMax;
  const target = hasTarget ? calcProteinTarget(weightKg, proteinMin, proteinMax) : {min:0, max:0};
  const stat = evaluateProtein(g, target);

  document.getElementById('protein-val').innerHTML = `${g}<span class="g">g</span>`;
  if(!hasTarget){
    document.getElementById('protein-target').textContent = 'Bedarf: Profilwerte eintragen';
    const lbl = document.getElementById('protein-status');
    lbl.textContent = 'ZIEL OFFEN';
    lbl.className = 'protein-status p-amber';
    document.getElementById('protein-bar-fill').style.width = '0%';
    ['protein-bar-min','protein-bar-max','protein-bar-min-lbl','protein-bar-max-lbl'].forEach(id=>{
      const el = document.getElementById(id);
      if(el) el.style.left = '0%';
    });
    document.getElementById('protein-bar-min-lbl').textContent = '';
    document.getElementById('protein-bar-max-lbl').textContent = '';
    return;
  }
  document.getElementById('protein-target').textContent = `Bedarf: ${target.min}-${target.max}g (${p.weightKg} kg × ${p.proteinMin.toFixed(1)}-${p.proteinMax.toFixed(1)})`;

  const lbl = document.getElementById('protein-status');
  lbl.textContent = STATUS_LABELS[stat];
  lbl.className = 'protein-status p-' + stat;

  const fillEl = document.getElementById('protein-bar-fill');
  const visMax = Math.max(target.max * 1.2, g);
  const pct = Math.min((g / visMax) * 100, 100);
  fillEl.style.width = pct + '%';
  fillEl.style.background = STATUS_COLOR[stat];

  const minPct = (target.min/visMax)*100;
  const maxPct = (target.max/visMax)*100;
  document.getElementById('protein-bar-min').style.left = minPct+'%';
  document.getElementById('protein-bar-max').style.left = maxPct+'%';
  document.getElementById('protein-bar-min-lbl').style.left = minPct+'%';
  document.getElementById('protein-bar-min-lbl').textContent = target.min+'g';
  document.getElementById('protein-bar-max-lbl').style.left = maxPct+'%';
  document.getElementById('protein-bar-max-lbl').textContent = target.max+'g';
}

// ---------------------------------------------------
// 🆕 STEPS
// ---------------------------------------------------
function renderSteps(){
  const configuredGoal = parseIntegerInput(S.profile.stepGoal);
  const goal = configuredGoal || 10000;
  const cur = S.steps[selectedDateStr] || 0;
  const pct = Math.min(cur/goal, 1);

  document.getElementById('steps-val').textContent = cur.toLocaleString('de');
  document.getElementById('steps-goal').textContent = configuredGoal ? `/ ${goal.toLocaleString('de')}` : '/ Ziel offen';
  document.getElementById('steps-km').textContent = `ca. ${(cur*0.000762).toFixed(1).replace('.',',')} km`;

  const fill = document.getElementById('steps-fill');
  const arcLen = 302;
  fill.style.strokeDashoffset = arcLen - pct*arcLen;

  // farbverlauf nach prozent
  const ratio = cur/goal;
  let color = '#6e63f2';
  if(ratio >= 1) color = '#26d47c';
  else if(ratio < 0.25) color = '#f06060';
  else if(ratio < 0.5) color = '#ff8a3d';
  else if(ratio < 0.75) color = '#ffca28';
  fill.setAttribute('stroke', color);
}

KDOM.setClick('steps-add', ()=>{
  ensureDailyState(selectedDateStr);
  S.steps[selectedDateStr] = (S.steps[selectedDateStr] || 0) + 500;
  saveState(S);
  renderSteps();
});

