/* Sekundärer Action-Button (Sync-Now etc) */
.settings-action-btn{
  width:100%;background:rgba(110,99,242,0.10);
  border:1px solid rgba(110,99,242,0.25);color:var(--purple-300);
  padding:12px;border-radius:var(--r-full);
  font-family:'JetBrains Mono',monospace;font-size:.7rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;
  cursor:pointer;margin-top:12px;
  touch-action:manipulation;
}
.sync-now-btn{
  position:relative;overflow:hidden;
  min-height:48px;
  display:flex;align-items:center;justify-content:center;gap:10px;
  background:
    linear-gradient(135deg,rgba(38,212,124,.12),rgba(110,99,242,.16)),
    rgba(110,99,242,0.10);
  border-color:rgba(38,212,124,.28);
  color:#dfffee;
  box-shadow:0 10px 24px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.08);
  transition:transform .16s var(--ease),border-color .22s var(--ease),box-shadow .22s var(--ease),background .22s var(--ease),color .22s var(--ease);
}
.sync-now-btn::before{
  content:'';
  position:absolute;inset:-45% -30%;
  background:linear-gradient(110deg,transparent 35%,rgba(255,255,255,.22) 50%,transparent 65%);
  transform:translateX(-80%) rotate(8deg);
  transition:transform .62s cubic-bezier(.22,1,.36,1);
  pointer-events:none;
}
.sync-now-btn:active,.sync-now-btn.is-pressed{
  transform:scale(.975);
  box-shadow:0 6px 16px rgba(0,0,0,.28),0 0 22px rgba(38,212,124,.18);
}
.sync-now-btn.is-syncing::before,.sync-now-btn.is-success::before{
  transform:translateX(80%) rotate(8deg);
}
.sync-now-btn:disabled{cursor:wait;opacity:.95;}
.sync-now-btn.is-syncing{
  color:#fff4c8;
  border-color:rgba(255,202,40,.42);
  background:linear-gradient(135deg,rgba(255,202,40,.14),rgba(255,149,0,.10)),rgba(110,99,242,.12);
}
.sync-now-btn.is-success{
  color:#05150d;
  border-color:rgba(38,212,124,.58);
  background:linear-gradient(135deg,#26d47c,#85f0b3);
  box-shadow:0 10px 28px rgba(38,212,124,.22), inset 0 1px 0 rgba(255,255,255,.35);
}
.sync-now-btn.is-error{
  color:#ffd9e0;
  border-color:rgba(240,96,96,.48);
  background:linear-gradient(135deg,rgba(240,96,96,.18),rgba(255,45,85,.12));
}
.sync-now-icon{
  width:20px;height:20px;border-radius:50%;
  display:inline-flex;align-items:center;justify-content:center;
  border:1px solid currentColor;
  font-size:.82rem;line-height:1;
  flex-shrink:0;
}
.sync-now-btn.is-syncing .sync-now-icon{
  border-top-color:transparent;
  color:#ffca28;
  animation:syncSpin .8s linear infinite;
}
.sync-now-btn.is-success .sync-now-icon{
  color:#05150d;
  animation:syncPop .38s cubic-bezier(.22,1.4,.36,1);
}
.sync-now-label{position:relative;z-index:1;}
@keyframes syncSpin{to{transform:rotate(360deg);}}
@keyframes syncPop{
  0%{transform:scale(.55);}
  75%{transform:scale(1.18);}
  100%{transform:scale(1);}
}
.notification-settings{
  background:rgba(255,255,255,0.035);
  border:1px solid var(--border-default);
  border-radius:var(--r-md);
  padding:12px;
}
.notify-row{
  display:grid;
  grid-template-columns:auto 1fr minmax(86px,112px);
  align-items:center;
  gap:9px;
  padding:9px 8px;
  border-bottom:1px solid rgba(255,255,255,0.06);
  border-radius:12px;
  cursor:pointer;
  transition:background .18s var(--ease),border-color .18s var(--ease),box-shadow .18s var(--ease);
}
.notify-row:last-child{border-bottom:none;}
.notify-row.is-active{
  background:linear-gradient(135deg,rgba(110,99,242,.13),rgba(255,107,0,.05));
  box-shadow:inset 0 0 0 1px rgba(138,128,248,.22);
}
.notify-row input[type="checkbox"]{width:18px;height:18px;accent-color:#6e63f2;}
.notify-row input[type="time"],.notify-row select{
  width:100%;min-width:0;background:rgba(0,0,0,0.22);
  border:1px solid var(--border-default);border-radius:10px;
  color:var(--text-primary);padding:8px 7px;font-family:'JetBrains Mono',monospace;
  font-size:.68rem;outline:none;
}
.notify-main{min-width:0;}
.notify-title{font-size:.82rem;font-weight:800;color:var(--text-primary);line-height:1.15;}
.notify-sub{font-family:'JetBrains Mono',monospace;font-size:.5rem;color:var(--text-muted);letter-spacing:.08em;text-transform:uppercase;margin-top:2px;}
.notify-permission{
  margin-top:10px;width:100%;border:none;border-radius:999px;
  padding:10px 12px;background:linear-gradient(135deg,var(--purple-500),#8a52f0);
  color:#fff;font-weight:800;font-family:'Outfit',sans-serif;
}
.notify-test-btn{
  margin-top:8px;width:100%;border:1px solid rgba(255,149,0,.24);border-radius:999px;
  padding:10px 12px;background:rgba(255,107,0,.08);
  color:#ffca28;font-weight:800;font-family:'Outfit',sans-serif;
}
.version-mono{font-family:'JetBrains Mono',monospace;font-size:.55rem;letter-spacing:.2em;color:var(--text-muted);text-transform:uppercase;text-align:center;padding:1rem 0;}

/* KASAI Settings v2 */
#settings-overlay.settings-v2-overlay{
  align-items:stretch;justify-content:center;
  background:rgba(8,8,15,.72);
  overflow:hidden;
}
#settings-overlay .settings-v2-card{
  position:relative;width:min(100%,430px);height:100%;max-height:100%;
  padding:0;overflow-x:hidden;overflow-y:auto;
  background:var(--bg-surface);border:0;border-radius:0;
  transform:translateY(24px);
  transition:transform .45s cubic-bezier(.32,.72,0,1),border-radius .45s ease,filter .45s ease;
  transform-origin:center top;
  -webkit-overflow-scrolling:touch;
}
#settings-overlay.show .settings-v2-card{transform:translateY(0);}
#settings-overlay.show .settings-v2-card.settings-pushed{
  transform:scale(.92) translateY(14px);
  border-radius:20px;filter:brightness(.62);overflow:hidden;
}
.settings-v2-hero{
  position:relative;width:100%;height:260px;overflow:hidden;
  display:flex;flex-direction:column;align-items:center;justify-content:flex-end;
  padding-bottom:24px;
}
.settings-v2-hero-bg{
  position:absolute;inset:0;z-index:0;
  background:linear-gradient(180deg,#0a0308 0%,#120800 40%,var(--bg-surface) 100%);
}
.settings-v2-fire-scene{
  position:absolute;top:0;left:50%;transform:translateX(-50%);
  width:300px;height:200px;perspective:600px;z-index:1;pointer-events:none;
}
.settings-v2-fire-3d{
  position:absolute;top:20px;left:50%;width:100px;height:140px;
  transform:translateX(-50%);transform-style:preserve-3d;
  animation:settingsFireRotate 10s linear infinite;
}
@keyframes settingsFireRotate{
  from{transform:translateX(-50%) rotateY(0deg);}
  to{transform:translateX(-50%) rotateY(360deg);}
}
.settings-v2-fire-petal{
  position:absolute;top:50%;left:50%;border-radius:50% 50% 10% 10%;
  transform-style:preserve-3d;transform-origin:bottom center;
  opacity:0;animation:settingsPetalOpen 2s cubic-bezier(.16,1,.3,1) forwards;
}
.settings-v2-fp-o1{width:45px;height:68px;background:linear-gradient(180deg,rgba(255,45,85,.5),rgba(180,20,40,.7));transform:translate(-50%,-60%) rotateY(0deg) translateZ(26px) rotateX(-30deg);animation-delay:.5s;box-shadow:0 0 12px rgba(255,45,85,.2);}
.settings-v2-fp-o2{width:45px;height:68px;background:linear-gradient(180deg,rgba(255,60,40,.5),rgba(200,30,30,.7));transform:translate(-50%,-60%) rotateY(72deg) translateZ(26px) rotateX(-30deg);animation-delay:.7s;box-shadow:0 0 12px rgba(255,60,40,.2);}
.settings-v2-fp-o3{width:45px;height:68px;background:linear-gradient(180deg,rgba(255,45,85,.5),rgba(180,20,40,.7));transform:translate(-50%,-60%) rotateY(144deg) translateZ(26px) rotateX(-30deg);animation-delay:.9s;box-shadow:0 0 12px rgba(255,45,85,.2);}
.settings-v2-fp-o4{width:45px;height:68px;background:linear-gradient(180deg,rgba(255,80,30,.5),rgba(200,40,20,.7));transform:translate(-50%,-60%) rotateY(216deg) translateZ(26px) rotateX(-30deg);animation-delay:1.1s;box-shadow:0 0 12px rgba(255,80,30,.2);}
.settings-v2-fp-o5{width:45px;height:68px;background:linear-gradient(180deg,rgba(255,45,85,.5),rgba(180,20,40,.7));transform:translate(-50%,-60%) rotateY(288deg) translateZ(26px) rotateX(-30deg);animation-delay:1.3s;box-shadow:0 0 12px rgba(255,45,85,.2);}
.settings-v2-fp-m1{width:34px;height:50px;background:linear-gradient(180deg,rgba(255,107,0,.6),rgba(255,60,30,.8));transform:translate(-50%,-55%) rotateY(36deg) translateZ(16px) rotateX(-20deg);animation-delay:1s;box-shadow:0 0 15px rgba(255,107,0,.25);}
.settings-v2-fp-m2{width:34px;height:50px;background:linear-gradient(180deg,rgba(255,130,0,.6),rgba(255,80,20,.8));transform:translate(-50%,-55%) rotateY(108deg) translateZ(16px) rotateX(-20deg);animation-delay:1.2s;box-shadow:0 0 15px rgba(255,130,0,.25);}
.settings-v2-fp-m3{width:34px;height:50px;background:linear-gradient(180deg,rgba(255,107,0,.6),rgba(255,60,30,.8));transform:translate(-50%,-55%) rotateY(180deg) translateZ(16px) rotateX(-20deg);animation-delay:1.4s;box-shadow:0 0 15px rgba(255,107,0,.25);}
.settings-v2-fp-m4{width:34px;height:50px;background:linear-gradient(180deg,rgba(255,130,0,.6),rgba(255,80,20,.8));transform:translate(-50%,-55%) rotateY(252deg) translateZ(16px) rotateX(-20deg);animation-delay:1.6s;box-shadow:0 0 15px rgba(255,130,0,.25);}
.settings-v2-fp-m5{width:34px;height:50px;background:linear-gradient(180deg,rgba(255,107,0,.6),rgba(255,60,30,.8));transform:translate(-50%,-55%) rotateY(324deg) translateZ(16px) rotateX(-20deg);animation-delay:1.8s;box-shadow:0 0 15px rgba(255,107,0,.25);}
.settings-v2-fp-i1{width:22px;height:34px;background:linear-gradient(180deg,rgba(255,202,40,.7),rgba(255,140,0,.9));transform:translate(-50%,-50%) rotateY(0deg) translateZ(7px) rotateX(-10deg);animation-delay:1.5s;box-shadow:0 0 18px rgba(255,202,40,.3);}
.settings-v2-fp-i2{width:22px;height:34px;background:linear-gradient(180deg,rgba(255,220,60,.7),rgba(255,160,10,.9));transform:translate(-50%,-50%) rotateY(120deg) translateZ(7px) rotateX(-10deg);animation-delay:1.7s;box-shadow:0 0 18px rgba(255,220,60,.3);}
.settings-v2-fp-i3{width:22px;height:34px;background:linear-gradient(180deg,rgba(255,202,40,.7),rgba(255,140,0,.9));transform:translate(-50%,-50%) rotateY(240deg) translateZ(7px) rotateX(-10deg);animation-delay:1.9s;box-shadow:0 0 18px rgba(255,202,40,.3);}
.settings-v2-fire-core{
  position:absolute;top:50%;left:50%;width:20px;height:20px;margin:-10px 0 0 -10px;
  border-radius:50%;background:radial-gradient(circle,rgba(255,230,150,1),rgba(255,180,50,.7),transparent);
  box-shadow:0 0 25px rgba(255,180,50,.5),0 0 50px rgba(255,100,0,.3);
  animation:settingsCoreGlow 2s ease-in-out infinite;
}
@keyframes settingsCoreGlow{
  0%,100%{box-shadow:0 0 25px rgba(255,180,50,.5),0 0 50px rgba(255,100,0,.3);transform:scale(1);}
  50%{box-shadow:0 0 40px rgba(255,180,50,.7),0 0 80px rgba(255,100,0,.4);transform:scale(1.15);}
}
@keyframes settingsPetalOpen{
  from{opacity:0;transform:translate(-50%,-50%) scale(.2);filter:blur(6px) brightness(2);}
  to{opacity:1;filter:blur(0) brightness(1);}
}
.settings-v2-ember{
  position:absolute;border-radius:50%;z-index:2;pointer-events:none;
  animation:settingsEmberRise linear infinite;
}
@keyframes settingsEmberRise{
  0%{opacity:0;transform:translateY(0) scale(1);}
  10%{opacity:.8;}
  100%{opacity:0;transform:translateY(-160px) scale(.2);}
}
.settings-v2-se1{width:2px;height:2px;left:22%;bottom:30%;background:#ff6b00;animation-duration:3s;box-shadow:0 0 4px #ff6b00;}
.settings-v2-se2{width:3px;height:3px;left:48%;bottom:25%;background:#ffca28;animation-duration:3.5s;animation-delay:.5s;box-shadow:0 0 5px #ffca28;}
.settings-v2-se3{width:2px;height:2px;left:72%;bottom:32%;background:#ff2d55;animation-duration:2.8s;animation-delay:1s;box-shadow:0 0 4px #ff2d55;}
.settings-v2-se4{width:2px;height:2px;left:36%;bottom:22%;background:#ff9500;animation-duration:4s;animation-delay:1.5s;box-shadow:0 0 4px #ff9500;}
.settings-v2-se5{width:3px;height:3px;left:62%;bottom:28%;background:#ff6b00;animation-duration:3.2s;animation-delay:2s;box-shadow:0 0 5px #ff6b00;}
.settings-v2-hero-vignette{
  position:absolute;inset:0;z-index:3;
  background:radial-gradient(ellipse 70% 60% at 50% 30%,transparent 20%,rgba(10,10,20,.9) 100%);
  pointer-events:none;
}
.settings-v2-hero-close{
  position:absolute;top:max(16px,calc(env(safe-area-inset-top,0px) + 10px));right:16px;z-index:10;
  width:36px;height:36px;border-radius:50%;
  background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.08);
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
  color:var(--text-secondary);font-size:1rem;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
}
.settings-v2-hero-text{position:relative;z-index:5;text-align:center;}
.settings-v2-hero-kicker{
  font-family:'JetBrains Mono',monospace;font-size:.5rem;letter-spacing:.2em;
  text-transform:uppercase;color:rgba(255,149,0,.4);margin-bottom:4px;
}
.settings-v2-hero-title{font-size:1.5rem;font-weight:900;letter-spacing:0;}
.settings-v2-hero-title span{
  background:linear-gradient(135deg,#ffca28,#ff6b00,#ff2d55);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.settings-v2-content{padding:0 20px calc(40px + env(safe-area-inset-bottom,0px));position:relative;z-index:5;}
#settings-overlay .settings-v2-profile-card{
  display:flex;align-items:center;gap:14px;
  background:linear-gradient(135deg,rgba(255,107,0,.08),rgba(255,45,85,.05));
  border:1px solid rgba(255,107,0,.15);border-radius:var(--r-lg);
  padding:16px;margin:-18px 0 12px;position:relative;z-index:6;
  backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
  cursor:pointer;transition:transform .25s ease;
}
#settings-overlay .settings-v2-profile-card:active{transform:scale(.97);}
#settings-overlay .settings-v2-profile-card .settings-profile-avatar{
  width:50px;height:50px;border-radius:50%;flex-shrink:0;
  background:linear-gradient(135deg,#ff6b00,#ff2d55);
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:1.05rem;color:#fff;
  box-shadow:0 0 18px rgba(255,107,0,.3);position:relative;
}
#settings-overlay .settings-v2-profile-card .settings-profile-avatar::after{
  content:'';position:absolute;inset:-3px;border-radius:50%;
  border:1.5px solid rgba(255,107,0,.25);
  animation:settingsAvatarRing 3s ease-in-out infinite;
}
@keyframes settingsAvatarRing{0%,100%{transform:scale(1);opacity:.4;}50%{transform:scale(1.06);opacity:.8;}}
#settings-overlay .settings-v2-profile-card .settings-profile-name{font-weight:800;font-size:1rem;letter-spacing:0;}
#settings-overlay .settings-v2-profile-card .settings-profile-email{
  font-family:'JetBrains Mono',monospace;font-size:.58rem;color:var(--text-muted);
  letter-spacing:.04em;margin-top:2px;word-break:break-word;
}
.settings-v2-profile-arrow{color:rgba(255,107,0,.4);font-size:1.2rem;flex-shrink:0;}
#settings-overlay .settings-v2-sync{
  display:inline-flex;align-items:center;gap:8px;
  font-family:'JetBrains Mono',monospace;font-size:.52rem;color:var(--green);
  letter-spacing:.1em;text-transform:uppercase;
  background:rgba(38,212,124,.06);border:1px solid rgba(38,212,124,.15);
  border-radius:var(--r-full);padding:6px 12px;margin:0 0 14px;
}
.settings-v2-section-label{
  font-family:'JetBrains Mono',monospace;font-size:.5rem;font-weight:700;
  letter-spacing:.18em;text-transform:uppercase;color:var(--text-muted);
  margin:22px 0 10px 2px;display:flex;align-items:center;gap:8px;
}
.settings-v2-section-label::after{
  content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--border-default),transparent);
}
.settings-v2-menu-rows{display:flex;flex-direction:column;gap:6px;margin-top:8px;}
.settings-v2-menu-row{
  width:100%;display:flex;align-items:center;gap:12px;text-align:left;
  padding:13px 14px;background:var(--bg-card);border:1px solid var(--border-default);
  border-radius:var(--r-md);cursor:pointer;color:var(--text-primary);font:inherit;
  transition:transform .2s var(--ease),background .2s var(--ease),border-color .2s var(--ease);
}
.settings-v2-menu-row:active{transform:scale(.97);}
.settings-v2-row-icon{
  width:36px;height:36px;border-radius:var(--r-sm);
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;flex-shrink:0;
}
.settings-v2-row-text{flex:1;min-width:0;}
.settings-v2-row-name{font-size:.84rem;font-weight:700;}
.settings-v2-row-sub{
  font-family:'JetBrains Mono',monospace;font-size:.46rem;color:var(--text-muted);
  letter-spacing:.06em;text-transform:uppercase;margin-top:1px;
}
.settings-v2-row-chevron{color:var(--text-muted);font-size:.8rem;opacity:.5;}
.settings-v2-menu-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.settings-v2-menu-tile{
  background:var(--bg-card);border:1px solid var(--border-default);
  border-radius:var(--r-lg);padding:18px 14px;cursor:pointer;
  display:flex;flex-direction:column;gap:10px;position:relative;overflow:hidden;
  color:var(--text-primary);font:inherit;text-align:left;
  transition:transform .2s var(--ease),border-color .2s var(--ease),box-shadow .2s var(--ease);
}
.settings-v2-menu-tile:active{transform:scale(.96);}
.settings-v2-menu-tile::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;border-radius:20px 20px 0 0;opacity:1;
}
.settings-v2-tile-fire::before{background:linear-gradient(90deg,#ff6b00,#ff2d55);}
.settings-v2-tile-green::before{background:linear-gradient(90deg,#26d47c,#26c6da);}
.settings-v2-tile-amber::before{background:linear-gradient(90deg,#ffca28,#ff9500);}
.settings-v2-tile-purple::before{background:linear-gradient(90deg,#6e63f2,#a29bfe);}
.settings-v2-tile-icon{
  width:42px;height:42px;border-radius:var(--r-sm);
  display:flex;align-items:center;justify-content:center;font-size:1.2rem;
}
.settings-v2-tile-fire .settings-v2-tile-icon{background:rgba(255,107,0,.12);}
.settings-v2-tile-green .settings-v2-tile-icon{background:rgba(38,212,124,.12);}
.settings-v2-tile-amber .settings-v2-tile-icon{background:rgba(255,202,40,.12);}
.settings-v2-tile-purple .settings-v2-tile-icon{background:rgba(110,99,242,.12);}
.settings-v2-tile-name{font-size:.82rem;font-weight:700;line-height:1.2;}
.settings-v2-tile-sub{
  font-family:'JetBrains Mono',monospace;font-size:.46rem;color:var(--text-muted);
  letter-spacing:.06em;text-transform:uppercase;
}
.settings-v2-account-section{margin-top:24px;}
.settings-v2-account-section #settings-account-actions,.settings-v2-account-section #settings-account-login{margin:0;}
.settings-v2-version{
  font-family:'JetBrains Mono',monospace;font-size:.48rem;letter-spacing:.2em;
  color:var(--text-muted);text-transform:uppercase;text-align:center;
  padding:20px 0 12px;opacity:.5;
}
.settings-v2-sheet-backdrop{
  position:absolute;inset:0;z-index:90;background:rgba(0,0,0,.5);
  opacity:0;pointer-events:none;transition:opacity .4s ease;
}
.settings-v2-sheet-backdrop.show{opacity:1;pointer-events:auto;}
.settings-v2-sheet{
  position:absolute;bottom:0;left:50%;
  transform:translateX(-50%) translateY(100%);
  width:min(100%,430px);max-height:88vh;
  background:var(--bg-surface);
  border-radius:var(--r-xl) var(--r-xl) 0 0;
  border-top:1px solid rgba(255,255,255,.08);
  z-index:100;overflow:hidden;display:flex;flex-direction:column;
  transition:transform .5s cubic-bezier(.32,.72,0,1);
  box-shadow:0 -10px 60px rgba(0,0,0,.5);
}
.settings-v2-sheet.show{transform:translateX(-50%) translateY(0);}
.settings-v2-sheet-grab{
  width:36px;height:4px;background:rgba(255,255,255,.12);
  border-radius:2px;margin:10px auto 0;flex-shrink:0;
}
.settings-v2-sheet-head{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 20px 10px;flex-shrink:0;
}
.settings-v2-sheet-title{font-size:1.1rem;font-weight:800;letter-spacing:0;}
.settings-v2-sheet-title-icon{margin-right:8px;}
.settings-v2-sheet-close{
  width:32px;height:32px;border-radius:50%;
  background:var(--bg-card);border:1px solid var(--border-default);
  color:var(--text-secondary);font-size:.85rem;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
}
.settings-v2-sheet-body{
  flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;
  padding:4px 20px calc(32px + env(safe-area-inset-bottom,0px));
}
.settings-v2-input-card{
  background:var(--bg-card);border:1px solid var(--border-default);
  border-radius:var(--r-md);padding:14px;margin-bottom:10px;
  transition:border-color .2s ease,box-shadow .2s ease;
}
.settings-v2-input-card:focus-within{
  border-color:rgba(255,107,0,.25);box-shadow:0 0 16px rgba(255,107,0,.05);
}
.settings-v2-label{
  font-family:'JetBrains Mono',monospace;font-size:.5rem;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;color:var(--text-muted);
  margin-bottom:8px;display:flex;align-items:center;gap:6px;
}
.settings-v2-label-icon{font-size:.7rem;}
.settings-v2-field,#settings-overlay .settings-v2-sheet select{
  width:100%;background:rgba(0,0,0,.25);
  border:1px solid rgba(255,255,255,.06);border-radius:var(--r-sm);
  padding:11px 13px;font-family:'JetBrains Mono',monospace;
  font-size:16px;font-weight:600;color:var(--text-primary);outline:none;
  -webkit-appearance:none;appearance:none;transition:border-color .2s ease,box-shadow .2s ease;
}
.settings-v2-field:focus,#settings-overlay .settings-v2-sheet select:focus{
  border-color:rgba(255,107,0,.3);box-shadow:0 0 10px rgba(255,107,0,.06);
}
.settings-v2-field::placeholder{color:var(--text-muted);}
.settings-v2-helper{
  font-family:'JetBrains Mono',monospace;font-size:.44rem;letter-spacing:.08em;
  color:rgba(255,149,0,.3);margin-top:6px;text-transform:uppercase;
}
.language-premium{
  display:flex;flex-direction:column;gap:12px;margin-top:2px;
}
.language-premium-card{
  width:100%;position:relative;overflow:hidden;border-radius:20px;
  display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:13px;
  padding:15px;border:1px solid rgba(255,255,255,.075);
  background:
    linear-gradient(145deg,rgba(255,255,255,.07),rgba(255,255,255,.025)),
    rgba(12,10,22,.84);
  color:var(--text-primary);text-align:left;cursor:pointer;touch-action:manipulation;
  transition:transform .2s var(--ease),border-color .2s ease,box-shadow .2s ease,background .2s ease;
}
.language-premium-card::before{
  content:'';position:absolute;inset:0;opacity:0;pointer-events:none;
  background:radial-gradient(circle at 18% 0%,rgba(255,149,0,.22),transparent 36%),
             linear-gradient(135deg,rgba(255,202,40,.09),rgba(255,45,85,.05));
  transition:opacity .2s ease;
}
.language-premium-card:active{transform:scale(.985);}
.language-premium-card.active{
  border-color:rgba(255,149,0,.42);
  box-shadow:0 16px 38px rgba(255,80,0,.12), inset 0 0 0 1px rgba(255,255,255,.035);
}
.language-premium-card.active::before{opacity:1;}
.language-flag{
  position:relative;width:42px;height:42px;border-radius:15px;
  display:flex;align-items:center;justify-content:center;font-size:1.35rem;
  background:rgba(255,255,255,.055);border:1px solid rgba(255,255,255,.07);
}
.language-copy{position:relative;min-width:0;display:flex;flex-direction:column;gap:3px;}
.language-copy strong{font-size:.95rem;font-weight:900;letter-spacing:0;}
.language-copy span{
  font-family:'JetBrains Mono',monospace;font-size:.5rem;letter-spacing:.09em;
  text-transform:uppercase;color:rgba(255,255,255,.36);line-height:1.35;
}
.language-check{
  position:relative;width:30px;height:30px;border-radius:999px;
  display:flex;align-items:center;justify-content:center;
  border:1px solid rgba(255,255,255,.09);color:transparent;
  background:rgba(255,255,255,.045);font-weight:900;
}
.language-premium-card.active .language-check{
  color:#06170d;background:#26d47c;border-color:#26d47c;
  box-shadow:0 0 18px rgba(38,212,124,.22);
}
.language-live-preview{
  margin-top:14px;padding:12px 14px;border-radius:18px;
  background:rgba(255,149,0,.075);border:1px dashed rgba(255,149,0,.22);
  font-family:'JetBrains Mono',monospace;font-size:.5rem;letter-spacing:.08em;
  text-transform:uppercase;color:rgba(255,202,40,.72);line-height:1.45;
}
.settings-v2-row-2{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
#settings-overlay .settings-v2-notification-settings{
  background:transparent;border:0;border-radius:0;padding:0;
}
#settings-overlay .settings-v2-notify-row{
  display:grid;grid-template-columns:auto 1fr minmax(86px,112px);
  align-items:center;gap:10px;padding:12px 0;
  border-bottom:1px solid rgba(255,255,255,.04);border-radius:0;
  cursor:pointer;
}
#settings-overlay .settings-v2-notify-row:last-of-type{border-bottom:none;}
#settings-overlay .settings-v2-notify-row.is-active .notify-title{color:var(--text-primary);}
#settings-overlay .settings-v2-notify-row input[type="checkbox"]{
  position:relative;width:42px;height:24px;border-radius:12px;
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);
  appearance:none;-webkit-appearance:none;cursor:pointer;flex-shrink:0;
  transition:background .3s ease,border-color .3s ease,box-shadow .3s ease;
}
#settings-overlay .settings-v2-notify-row input[type="checkbox"]::after{
  content:'';position:absolute;top:2px;left:2px;width:18px;height:18px;
  border-radius:50%;background:var(--text-muted);
  transition:left .3s cubic-bezier(.34,1.56,.64,1),background .3s ease,box-shadow .3s ease;
}
#settings-overlay .settings-v2-notify-row input[type="checkbox"]:checked{
  background:linear-gradient(135deg,rgba(255,107,0,.4),rgba(255,45,85,.3));
  border-color:rgba(255,107,0,.3);box-shadow:0 0 12px rgba(255,107,0,.15);
}
#settings-overlay .settings-v2-notify-row input[type="checkbox"]:checked::after{
  left:20px;background:#fff;box-shadow:0 0 8px rgba(255,107,0,.4);
}
#settings-overlay .settings-v2-notify-row input[type="time"],
#settings-overlay .settings-v2-notify-row select{
  background:rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.06);
  border-radius:var(--r-sm);color:var(--text-primary);
  padding:7px 8px;font-family:'JetBrains Mono',monospace;font-size:.62rem;
  outline:none;width:100%;min-width:0;-webkit-appearance:none;appearance:none;
}
.settings-v2-system-row{
  display:flex;align-items:center;justify-content:space-between;margin-top:16px;
}
.settings-v2-version-pill{
  font-family:'JetBrains Mono',monospace;font-size:.55rem;color:var(--purple-300);
  padding:3px 10px;border-radius:999px;background:rgba(110,99,242,.1);
  border:1px solid rgba(110,99,242,.2);white-space:nowrap;
}
#settings-overlay .settings-v2-sheet .sync-debug-card{
  display:block;margin:0;padding:0;background:transparent;border:0;border-radius:0;
}
#settings-overlay .settings-v2-sheet .sync-debug-head{display:none;}
#settings-overlay .settings-v2-sheet .sync-debug-grid{gap:6px;margin-top:10px;}
#settings-overlay .settings-v2-sheet .sync-debug-item{
  padding:9px;border-radius:var(--r-sm);
  background:rgba(10,10,20,.4);border:1px solid rgba(255,255,255,.04);
}
.settings-v2-sheet.show .si-1{opacity:0;animation:fade-up .4s ease .1s forwards;}
.settings-v2-sheet.show .si-2{opacity:0;animation:fade-up .4s ease .15s forwards;}
.settings-v2-sheet.show .si-3{opacity:0;animation:fade-up .4s ease .2s forwards;}
.settings-v2-sheet.show .si-4{opacity:0;animation:fade-up .4s ease .25s forwards;}
.settings-v2-sheet.show .si-5{opacity:0;animation:fade-up .4s ease .3s forwards;}
.settings-v2-sheet.show .si-6{opacity:0;animation:fade-up .4s ease .35s forwards;}
.settings-v2-sheet.show .si-7{opacity:0;animation:fade-up .4s ease .4s forwards;}
.settings-v2-sheet.show .si-8{opacity:0;animation:fade-up .4s ease .45s forwards;}
@keyframes fade-up{
  from{opacity:0;transform:translateY(12px);}
  to{opacity:1;transform:translateY(0);}
}
@media(max-width:360px){
  .settings-v2-row-2{grid-template-columns:1fr;}
  .settings-v2-menu-grid{gap:6px;}
  .settings-v2-content{padding-inline:16px;}
}

/* -- FORGE FULL CONCEPT POLISH -- */
:root{
  --bg-base:#0a0a14;
  --bg-surface:#0f0f1a;
  --bg-card:#161626;
  --bg-card-hover:#1c1c32;
  --bg-elevated:#222238;
  --border-default:rgba(255,255,255,.06);
  --border-subtle:rgba(255,255,255,.04);
  --border-glow:rgba(110,99,242,.22);
  --shadow-glow:0 0 24px rgba(110,99,242,.35);
  --r-lg:20px;
  --r-xl:28px;
}
#app::before{
  background:
    radial-gradient(700px 500px at 5% -5%,rgba(110,99,242,.15),transparent 60%),
    radial-gradient(600px 400px at 100% 5%,rgba(240,98,146,.08),transparent 60%);
}
.app-header{
  padding:calc(var(--safe-top) + 14px) 16px 12px;
  background:transparent;
}
.header-kicker{
  font-size:.54rem;
  letter-spacing:.24em;
  color:var(--purple-500);
}
.header-title{
  font-size:1.28rem;
  font-weight:900;
}
.avatar{
  width:36px;height:36px;
  font-size:.72rem;
}
.screen-body{
  padding-inline:14px;
}
.calendar-meta{
  display:flex;justify-content:space-between;align-items:center;
  min-height:34px;
  padding:3px 0 1px;
  margin-top:0;
  margin-bottom:-2px;
  overflow:visible;
}
.calendar-swipe{
  font-family:'JetBrains Mono',monospace;
  font-size:.48rem;letter-spacing:.16em;
  color:var(--text-muted);text-transform:uppercase;
}
.concept-pill{
  display:inline-flex;align-items:center;gap:5px;
  background:rgba(110,99,242,.12);
  border:1px solid rgba(110,99,242,.22);
  border-radius:var(--r-full);
  min-height:28px;
  padding:6px 11px;
  font-family:'JetBrains Mono',monospace;
  font-size:.48rem;font-weight:700;line-height:1;
  color:var(--purple-300);
  text-transform:uppercase;letter-spacing:.08em;
}
.calendar-strip{
  gap:5px;
  padding:20px 0 24px;
  margin-top:-6px;
}
.cal-day{
  width:42px;height:62px;
  border-radius:12px;
  background:var(--bg-card);
  border-color:rgba(255,255,255,.06);
  gap:3px;
}
.cal-day.active{
  background:var(--purple-500);
  box-shadow:0 0 0 1px rgba(255,255,255,.12),0 0 18px rgba(110,99,242,.42);
  transform:none;
}
.cal-day.active.today{
  box-shadow:
    0 0 0 1px rgba(255,255,255,.22),
    0 0 18px rgba(255,149,0,.55),
    0 0 34px rgba(255,45,85,.22);
}
.cal-day-name{font-size:.42rem;letter-spacing:.1em;}
.cal-day-num{font-size:.9rem;}
.cal-dot{width:3px;height:3px;}
.concept-quote-card{
  margin:0 0 12px;
  background:transparent;
  border:0;
  border-radius:14px;
  padding:10px 8px 14px;
  position:relative;overflow:hidden;
  text-align:center;
}
.concept-quote-card::before{
  content:none;
}
.concept-quote-k{
  font-family:'JetBrains Mono',monospace;
  font-size:.48rem;letter-spacing:.22em;
  color:var(--purple-500);text-transform:uppercase;
  font-weight:700;margin-bottom:7px;
  display:flex;justify-content:center;gap:12px;
}
.concept-quote-live{
  display:inline-flex;
  align-items:center;
  gap:6px;
  color:rgba(240,238,255,.58);
}
.quote-live-dot{
  width:4px;
  height:4px;
  border-radius:50%;
  background:var(--green);
  box-shadow:0 0 6px var(--green);
  animation:pulse 2s ease-in-out infinite;
}
.concept-quote-t{
  font-size:.82rem;font-weight:600;
  color:rgba(240,238,255,.85);
  line-height:1.4;
  text-align:center;
}
.concept-quote-t strong{color:var(--text-primary);font-weight:800;}
.concept-quote-t em{
  font-style:normal;
  background:linear-gradient(90deg,var(--purple-300),var(--pink));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}
.concept-profile-card{
  margin:0 0 12px;
  background:linear-gradient(135deg,rgba(110,99,242,.18),rgba(240,98,146,.10)),var(--bg-card);
  border:1px solid rgba(110,99,242,.22);
  border-radius:14px;
  padding:16px 14px;
  text-align:center;
  position:relative;overflow:hidden;
}
.concept-profile-avatar{
  width:56px;height:56px;border-radius:50%;
  background:linear-gradient(135deg,var(--purple-500),var(--pink));
  margin:0 auto 9px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;font-weight:800;color:#fff;
  box-shadow:0 0 18px rgba(110,99,242,.4);
}
.concept-profile-name{font-size:1rem;font-weight:800;letter-spacing:-.02em;}
.concept-profile-email{
  font-family:'JetBrains Mono',monospace;
  font-size:.5rem;color:var(--text-muted);
  letter-spacing:.08em;margin-top:2px;word-break:break-word;
}
.concept-profile-stats{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:5px;margin-top:12px;
}
.concept-profile-stat{
  background:rgba(15,15,26,.5);
  border:1px solid rgba(255,255,255,.05);
  border-radius:8px;padding:8px 4px;
}
.concept-profile-stat strong{
  display:block;font-family:'JetBrains Mono',monospace;
  font-size:.8rem;
}
.concept-profile-stat span{
  display:block;font-family:'JetBrains Mono',monospace;
  font-size:.38rem;color:var(--text-muted);
  letter-spacing:.1em;text-transform:uppercase;margin-top:2px;
}
.week-tabs{
  display:flex;gap:5px;
  padding:0 0 10px;
  overflow-x:auto;scrollbar-width:none;
}
.week-tabs::-webkit-scrollbar{display:none;}
.wtab{
  flex-shrink:0;background:var(--bg-card);
  border:1px solid rgba(255,255,255,.07);
  border-radius:var(--r-full);
  padding:6px 13px;
  font-family:'JetBrains Mono',monospace;
  font-size:.48rem;letter-spacing:.12em;
  color:var(--text-secondary);text-transform:uppercase;font-weight:700;
}
.wtab.active{background:var(--purple-500);border-color:transparent;color:#fff;box-shadow:0 0 10px rgba(110,99,242,.3);}
.wtab.add{border-style:dashed;color:var(--text-muted);}
.profile-plan-settings{
  display:grid;grid-template-columns:1fr 1fr;gap:8px;
  margin:0 0 12px;
}
.profile-plan-settings .plan-setting-card{
  background:var(--bg-card);
  border:1px solid rgba(255,255,255,.07);
  border-radius:12px;
  padding:10px;
}
.profile-plan-settings .plan-setting-card.full{grid-column:1/-1;}
.plan-setting-label{
  font-family:'JetBrains Mono',monospace;font-size:.44rem;letter-spacing:.14em;
  color:var(--text-muted);text-transform:uppercase;margin-bottom:6px;
}
.plan-setting-card input{
  width:100%;background:rgba(15,15,26,.7);border:1px solid rgba(255,255,255,.08);
  color:var(--text-primary);border-radius:9px;padding:8px 9px;font:inherit;font-size:.78rem;
  text-align:center;line-height:1.15;min-width:0;height:42px;
  appearance:none;-webkit-appearance:none;
}
.plan-setting-card input::-webkit-date-and-time-value{
  text-align:center;
}
.plan-setting-card input::-webkit-calendar-picker-indicator{
  opacity:.55;
}
.plan-status-toggle{display:flex;gap:6px;}
.plan-status-pill{
  flex:1;text-align:center;border:1px solid rgba(255,255,255,.08);border-radius:999px;
  padding:7px 8px;font-family:'JetBrains Mono',monospace;font-size:.46rem;
  color:var(--text-muted);text-transform:uppercase;font-weight:800;letter-spacing:.08em;
}
.plan-status-pill.active{background:var(--purple-500);border-color:transparent;color:#fff;}
.day-rows{display:flex;flex-direction:column;gap:6px;margin-bottom:12px;}
.day-row{
  background:var(--bg-card);
  border:1px solid rgba(255,255,255,.06);
  border-radius:10px;
  padding:10px 11px;
  display:flex;align-items:center;gap:10px;
}
.day-name{
  font-family:'JetBrains Mono',monospace;
  font-size:.5rem;letter-spacing:.12em;
  color:var(--text-muted);text-transform:uppercase;font-weight:700;
  width:32px;flex-shrink:0;
}
.day-type{font-size:.82rem;font-weight:700;flex:1;}
.day-edit{font-size:1rem;color:var(--text-muted);}
.duration-card{
  background:var(--bg-card);
  border:1px solid rgba(255,255,255,.06);
  border-radius:14px;
  padding:13px;margin-bottom:12px;
}
.dur-presets{display:flex;gap:6px;flex-wrap:wrap;margin-top:9px;}
.dur-chip{
  background:rgba(110,99,242,.10);
  border:1px solid rgba(110,99,242,.18);
  border-radius:var(--r-full);
  padding:5px 10px;
  font-family:'JetBrains Mono',monospace;
  font-size:.45rem;color:var(--purple-300);
  text-transform:uppercase;letter-spacing:.1em;font-weight:700;
}
.dur-chip.active{background:var(--purple-500);border-color:transparent;color:#fff;}

/* --------------------------------------
   TRAINING PLAN SCREEN - KASAI
-------------------------------------- */
.tp-back-btn{
  background:none;border:none;cursor:pointer;
  font-family:'Outfit',sans-serif;font-size:.82rem;font-weight:600;
  color:var(--text-secondary);padding:0;display:flex;align-items:center;gap:5px;
  -webkit-tap-highlight-color:transparent;
}
.tp-body{
  flex:1;overflow-y:auto;
  padding:12px 16px;
  padding-bottom:calc(var(--safe-bottom) + 32px);
  scrollbar-width:none;
}
.tp-body::-webkit-scrollbar{display:none;}
.tp-section{
  background:#141020;
  border:1px solid rgba(255,255,255,0.07);
  border-radius:14px;padding:14px 16px;margin-bottom:12px;
}
.tp-kicker{
  font-family:'JetBrains Mono',monospace;
  font-size:.42rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;
  color:var(--fire1);margin-bottom:7px;
}
.tp-input{
  background:#0e0c1a;
  border:1px solid rgba(255,255,255,0.07);border-radius:12px;
  padding:13px 15px;
  font-family:'Outfit',sans-serif;font-size:.86rem;font-weight:600;
  color:#fff8f0;width:100%;outline:none;
  -webkit-user-select:text;user-select:text;
  transition:border-color .18s;
}
.tp-input:focus{border-color:rgba(255,107,0,.45);}
.tp-input::placeholder{color:var(--text-muted);}

/* Week-mode pills */
.wm-pills{
  display:flex;gap:6px;overflow-x:auto;scrollbar-width:none;padding-bottom:2px;
}
.wm-pills::-webkit-scrollbar{display:none;}
.wm-pill{
  flex-shrink:0;background:#141020;
  border:1px solid rgba(255,255,255,.07);border-radius:9999px;
  padding:7px 14px;
  font-family:'JetBrains Mono',monospace;font-size:.42rem;letter-spacing:.14em;
  color:var(--text-muted);text-transform:uppercase;font-weight:700;
  cursor:pointer;white-space:nowrap;transition:all .18s;
  -webkit-tap-highlight-color:transparent;
}
.wm-pill.active{
  background:linear-gradient(135deg,#ff6b00,#ff3d00);
  border-color:transparent;color:#fff;box-shadow:0 0 12px rgba(255,107,0,.4);
}

/* Week tabs (training plan) */
.tp-week-tabs{
  display:flex;gap:6px;overflow-x:auto;scrollbar-width:none;margin-bottom:12px;
}
.tp-week-tabs::-webkit-scrollbar{display:none;}
.tp-wtab{
  flex-shrink:0;background:#141020;
  border:1px solid rgba(255,255,255,.07);border-radius:9999px;
  padding:6px 16px;
  font-family:'JetBrains Mono',monospace;font-size:.45rem;letter-spacing:.14em;
  color:var(--text-muted);text-transform:uppercase;font-weight:700;
  cursor:pointer;display:flex;align-items:center;gap:6px;
  transition:all .18s;-webkit-tap-highlight-color:transparent;
}
.tp-wtab.active{background:var(--fire1);border-color:transparent;color:#fff;box-shadow:0 0 10px rgba(255,107,0,.35);}
.tp-wtab.add-tab{border-style:dashed;border-color:rgba(255,255,255,.10);color:#3e3848;}
.tp-wtab .wtab-del{font-size:.7rem;color:rgba(255,45,85,.6);line-height:1;padding:0 0 0 2px;}

/* Day rows */
.tp-day-rows{display:flex;flex-direction:column;gap:6px;}
.tp-day-row{
  background:#141020;border:1px solid rgba(255,255,255,.05);border-radius:12px;
  padding:12px 14px;display:flex;align-items:center;gap:10px;
  cursor:pointer;transition:background .15s;-webkit-tap-highlight-color:transparent;
}
.tp-day-row:active{background:#1a1330;}
.tp-day-row.is-rest{opacity:.5;}
.tp-day-row.rolling-add{
  border-style:dashed;justify-content:center;color:#ff9500;
  background:rgba(255,107,0,.04);
}
.tp-day-abbr{
  font-family:'JetBrains Mono',monospace;font-size:.45rem;letter-spacing:.12em;
  color:var(--text-muted);text-transform:uppercase;font-weight:700;width:28px;flex-shrink:0;
}
.tp-day-info{flex:1;min-width:0;}
.tp-day-label-text{font-size:.82rem;font-weight:700;color:#fff8f0;line-height:1.2;}
.tp-day-label-text.rest-lbl{color:var(--text-muted);}
.tp-day-muscles{
  font-family:'JetBrains Mono',monospace;font-size:.4rem;letter-spacing:.08em;
  color:var(--text-muted);text-transform:uppercase;margin-top:2px;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:180px;
}
.tp-chevron{font-size:.9rem;color:var(--text-muted);}
.tp-rolling-meta{
  display:grid;grid-template-columns:minmax(0,1fr);gap:8px;margin-bottom:12px;
  min-width:0;overflow:hidden;
}
.tp-rolling-date{
  display:flex;flex-direction:column;gap:5px;min-width:0;
}
.tp-rolling-date span{
  font-family:'JetBrains Mono',monospace;font-size:.42rem;letter-spacing:.14em;
  color:var(--text-muted);text-transform:uppercase;font-weight:700;
}
.tp-rolling-date .tp-input{
  width:100%;max-width:100%;min-width:0;
  padding:12px 10px;text-align:center;
  font-size:clamp(.78rem,4.2vw,.86rem);line-height:1.2;
  box-sizing:border-box;
}
.tp-rolling-date input[type="date"]{
  -webkit-appearance:none;appearance:none;
  min-height:52px;overflow:hidden;
}
.tp-rolling-date input[type="date"]::-webkit-date-and-time-value{
  text-align:center;min-width:0;max-width:100%;
}
.tp-day-del{
  width:28px;height:28px;border-radius:50%;border:none;
  display:flex;align-items:center;justify-content:center;
  background:rgba(255,45,85,.08);color:rgba(255,85,119,.8);
  cursor:pointer;touch-action:manipulation;-webkit-tap-highlight-color:transparent;
  flex-shrink:0;
}

/* Day Detail: chips */
.dd-chips{display:flex;gap:6px;flex-wrap:wrap;margin-top:9px;}
.dd-chip{
  background:rgba(255,107,0,.08);border:1px solid rgba(255,107,0,.15);
  border-radius:9999px;padding:4px 10px;
  font-family:'JetBrains Mono',monospace;font-size:.4rem;color:#ff9500;
  cursor:pointer;letter-spacing:.08em;text-transform:uppercase;transition:all .15s;
  -webkit-tap-highlight-color:transparent;
}
.dd-chip:active{background:rgba(255,107,0,.2);}

/* Rest toggle */
.rest-toggle-wrap{display:flex;align-items:center;gap:8px;}
.rest-toggle-lbl{
  font-family:'JetBrains Mono',monospace;font-size:.42rem;letter-spacing:.12em;
  color:var(--text-muted);text-transform:uppercase;
}
.toggle-sw{position:relative;width:38px;height:22px;flex-shrink:0;}
.toggle-sw input{opacity:0;width:0;height:0;position:absolute;}
.toggle-sl{
  position:absolute;inset:0;border-radius:11px;background:rgba(255,255,255,.12);
  transition:background .2s;cursor:pointer;
}
.toggle-sl::after{
  content:'';position:absolute;width:18px;height:18px;left:2px;top:2px;
  border-radius:50%;background:#fff;transition:transform .2s;
}
.toggle-sw input:checked + .toggle-sl{background:var(--fire1);}
.toggle-sw input:checked + .toggle-sl::after{transform:translateX(16px);}

/* Muscle group blocks */
.mg-blocks{display:flex;flex-direction:column;gap:8px;margin-bottom:8px;}
.mg-block{
  background:#141020;border:1px solid rgba(255,255,255,.07);border-radius:14px;overflow:hidden;
}
.mg-header-row{
  display:flex;align-items:center;gap:10px;padding:12px 14px;cursor:default;
}
.mg-drag-h{font-size:.9rem;color:rgba(255,255,255,.18);flex-shrink:0;}
.mg-icon-h{font-size:1.2rem;flex-shrink:0;}
.mg-name-h{font-size:.82rem;font-weight:700;color:#fff8f0;flex:1;}
.mg-count-h{
  font-family:'JetBrains Mono',monospace;font-size:.4rem;color:var(--text-muted);letter-spacing:.08em;
}
.mg-del-h{font-size:.75rem;color:rgba(255,45,85,.6);padding:6px;cursor:pointer;flex-shrink:0;-webkit-tap-highlight-color:transparent;}

/* Exercise rows inside muscle group */
.mg-exercises{border-top:1px solid rgba(255,255,255,.06);padding:6px 0;}
.ex-row-tp{
  display:flex;align-items:center;gap:8px;padding:9px 14px 9px 28px;
  transition:background .12s;cursor:pointer;-webkit-tap-highlight-color:transparent;
}
.ex-row-tp:active{background:rgba(255,255,255,.03);}
.ex-drag-h{font-size:.8rem;color:rgba(255,255,255,.15);flex-shrink:0;}
.ex-name-h{font-size:.78rem;font-weight:700;color:#fff8f0;flex:1;}
.ex-sets-h{
  font-family:'JetBrains Mono',monospace;font-size:.4rem;color:#ff9500;letter-spacing:.05em;white-space:nowrap;
}
.ex-rest-h{
  font-family:'JetBrains Mono',monospace;font-size:.4rem;color:var(--text-muted);letter-spacing:.05em;margin-left:5px;
}
.ex-del-h{font-size:.72rem;color:rgba(255,45,85,.6);padding:6px;cursor:pointer;flex-shrink:0;-webkit-tap-highlight-color:transparent;}
.add-ex-row-tp{
  display:flex;align-items:center;gap:8px;padding:10px 14px 10px 28px;
  border-top:1px dashed rgba(255,255,255,.07);cursor:pointer;
  color:var(--text-muted);font-size:.75rem;transition:background .12s;
  -webkit-tap-highlight-color:transparent;
}
.add-ex-row-tp:active{background:rgba(255,255,255,.03);}

.daily-plan-block{
  background:#141020;border:1px solid rgba(255,107,0,.12);border-radius:14px;
  overflow:hidden;margin:10px 0 12px;
}
.daily-plan-row{
  display:flex;align-items:center;gap:10px;padding:11px 14px;
  border-bottom:1px solid rgba(255,255,255,.05);cursor:pointer;
  -webkit-tap-highlight-color:transparent;
}
.daily-plan-row:active{background:rgba(255,107,0,.06);}
.daily-plan-icon{font-size:1.05rem;flex-shrink:0;}
.daily-plan-name{font-size:.8rem;font-weight:800;color:#fff8f0;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.daily-plan-meta{font-family:'JetBrains Mono',monospace;font-size:.42rem;color:#ff9500;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap;}
.daily-plan-del{font-size:.75rem;color:rgba(255,45,85,.66);padding:6px;cursor:pointer;flex-shrink:0;}
.add-daily-row{
  display:flex;align-items:center;justify-content:center;gap:8px;
  padding:12px 14px;color:#ff9500;font-size:.76rem;cursor:pointer;
  background:rgba(255,107,0,.04);-webkit-tap-highlight-color:transparent;
}

/* Add muscle group */
.add-mg-block{
  display:flex;align-items:center;justify-content:center;gap:8px;
  background:#141020;border:1px dashed rgba(255,255,255,.10);border-radius:14px;
  padding:16px;cursor:pointer;color:var(--text-muted);font-size:.8rem;
  margin-bottom:8px;transition:border-color .15s;-webkit-tap-highlight-color:transparent;
}
.add-mg-block:active{border-color:rgba(255,107,0,.3);}

/* Plan duration */
.tp-dur-chips{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;}
.tp-dur-chip{
  background:#141020;border:1px solid rgba(255,255,255,.07);border-radius:9999px;
  padding:7px 13px;
  font-family:'JetBrains Mono',monospace;font-size:.42rem;letter-spacing:.12em;
  color:var(--text-muted);text-transform:uppercase;font-weight:700;
  cursor:pointer;transition:all .15s;-webkit-tap-highlight-color:transparent;
}
.tp-dur-chip.active{
  background:linear-gradient(135deg,#ff6b00,#ff3d00);border-color:transparent;color:#fff;
  box-shadow:0 0 10px rgba(255,107,0,.35);
}
.tp-cal-btn{
  display:flex;align-items:center;gap:10px;background:#141020;
  border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:12px 14px;
  cursor:pointer;transition:border-color .15s;margin-bottom:12px;
  -webkit-tap-highlight-color:transparent;
}
.tp-cal-btn:active{border-color:rgba(255,107,0,.35);}
.tp-cal-icon{font-size:1rem;}
.tp-cal-txt{font-size:.8rem;font-weight:600;color:var(--text-secondary);flex:1;}
.tp-cal-date{font-family:'JetBrains Mono',monospace;font-size:.45rem;color:#ff9500;letter-spacing:.05em;}
.tp-prog-bar{height:4px;border-radius:2px;background:rgba(255,255,255,.08);overflow:hidden;margin:8px 0 4px;}
.tp-prog-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--fire1),var(--fire2));transition:width .5s;}
.tp-prog-labels{display:flex;justify-content:space-between;font-family:'JetBrains Mono',monospace;font-size:.38rem;color:var(--text-muted);}
.tp-prog-info{text-align:center;font-family:'JetBrains Mono',monospace;font-size:.42rem;color:#ff9500;margin-top:4px;}
.plan-cal-card{
  background:#141020;border:1px solid rgba(255,255,255,.10);
  border-radius:18px;padding:16px;width:min(360px, calc(100vw - 34px));
  box-shadow:0 24px 80px rgba(0,0,0,.62),0 0 36px rgba(255,107,0,.08);
}
.plan-cal-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;}
.plan-cal-title{font-size:1rem;font-weight:900;color:#fff8f0;}
.plan-cal-sub{
  font-family:'JetBrains Mono',monospace;font-size:.42rem;letter-spacing:.16em;
  color:#ff9500;text-transform:uppercase;margin-top:2px;
}
.plan-cal-nav{display:flex;gap:6px;}
.plan-cal-nav button,.plan-cal-close{
  width:34px;height:34px;border-radius:12px;border:1px solid rgba(255,255,255,.08);
  background:#0e0c1a;color:var(--text-secondary);font-weight:900;cursor:pointer;
}
.plan-cal-weekdays,.plan-cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:6px;}
.plan-cal-weekdays{margin-bottom:7px;}
.plan-cal-weekdays span{
  text-align:center;font-family:'JetBrains Mono',monospace;font-size:.38rem;
  color:var(--text-muted);letter-spacing:.1em;text-transform:uppercase;
}
.plan-cal-day{
  aspect-ratio:1;border-radius:12px;border:1px solid rgba(255,255,255,.06);
  background:#0e0c1a;color:var(--text-secondary);font-family:'JetBrains Mono',monospace;
  font-size:.62rem;font-weight:800;display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all .16s var(--ease);
}
.plan-cal-day.empty{opacity:0;pointer-events:none;}
.plan-cal-day.disabled{opacity:.25;pointer-events:none;}
.plan-cal-day.today{border-color:rgba(255,202,40,.48);color:#ffca28;}
.plan-cal-day.selected{
  background:linear-gradient(135deg,#ff9500,#ff3d00);
  color:#fff;border-color:transparent;box-shadow:0 0 18px rgba(255,107,0,.42);
}
.plan-cal-foot{
  display:flex;justify-content:space-between;align-items:center;gap:10px;
  margin-top:14px;
}
.plan-cal-hint{
  font-family:'JetBrains Mono',monospace;font-size:.45rem;color:var(--text-muted);
  letter-spacing:.08em;text-transform:uppercase;line-height:1.4;
}
.plan-cal-clear{
  border:1px solid rgba(255,255,255,.08);background:#0e0c1a;color:var(--text-secondary);
  border-radius:999px;padding:8px 12px;font-family:'JetBrains Mono',monospace;
  font-size:.42rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;
}

/* -- TRAINING PLAN MODALS (bottom sheets) -- */
.tp-overlay{
  position:fixed;inset:0;z-index:290;background:rgba(0,0,0,0);
  pointer-events:none;transition:background .25s;
}
.tp-overlay.open{background:rgba(0,0,0,.68);pointer-events:all;}
.tp-sheet{
  position:fixed;bottom:0;left:0;right:0;z-index:300;
  background:#141020;border-radius:22px 22px 0 0;
  padding:0 16px calc(var(--safe-bottom) + 24px);
  max-height:92vh;overflow-y:auto;
  transform:translateY(110%);transition:transform .32s cubic-bezier(.16,1,.3,1);
  scrollbar-width:none;
}
.tp-sheet::-webkit-scrollbar{display:none;}
.tp-sheet.open{transform:translateY(0);}
.tp-sheet-grab{width:36px;height:4px;border-radius:2px;background:rgba(255,255,255,.15);margin:12px auto 16px;}
.tp-sheet-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px;}
.tp-sheet-title{font-size:1.1rem;font-weight:800;color:#fff8f0;}
.tp-sheet-close{background:none;border:none;font-size:1.1rem;color:var(--text-muted);cursor:pointer;padding:4px;-webkit-tap-highlight-color:transparent;}
.tp-field{margin-bottom:16px;position:relative;}
.tp-field-lbl{
  font-family:'JetBrains Mono',monospace;font-size:.42rem;font-weight:700;
  letter-spacing:.18em;text-transform:uppercase;color:var(--fire1);margin-bottom:6px;
}
.tp-notes{
  background:#0e0c1a;border:1px solid rgba(255,255,255,.07);border-radius:10px;
  padding:12px 14px;font-family:'Outfit',sans-serif;font-size:.8rem;color:#fff8f0;
  width:100%;resize:none;height:76px;outline:none;
  -webkit-user-select:text;user-select:text;transition:border-color .18s;
}
.tp-notes:focus{border-color:rgba(255,107,0,.45);}
.tp-notes::placeholder{color:var(--text-muted);}
.tp-notes-ctr{text-align:right;font-family:'JetBrains Mono',monospace;font-size:.38rem;color:var(--text-muted);margin-top:3px;}
.tp-cta{
  width:100%;padding:14px;border-radius:12px;border:none;cursor:pointer;
  background:linear-gradient(135deg,#ff6b00,#ff3d00);color:#fff;
  font-family:'Outfit',sans-serif;font-size:.9rem;font-weight:800;
  box-shadow:0 4px 16px rgba(255,107,0,.35);margin-top:8px;transition:opacity .15s;
  -webkit-tap-highlight-color:transparent;
}
.tp-cta:active{opacity:.85;}

/* Stepper */
.tp-stepper{
  display:flex;align-items:center;background:#0e0c1a;
  border:1px solid rgba(255,255,255,.07);border-radius:10px;overflow:hidden;
}
.tp-step-btn{
  width:42px;height:42px;display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;font-weight:700;color:var(--text-secondary);
  cursor:pointer;flex-shrink:0;border:none;background:none;
  transition:background .12s,color .12s;-webkit-tap-highlight-color:transparent;
}
.tp-step-btn:active{background:rgba(255,107,0,.15);color:var(--fire1);}
.tp-step-val{flex:1;text-align:center;font-family:'JetBrains Mono',monospace;font-size:.88rem;font-weight:700;color:#fff8f0;}
.tp-reps-row{display:flex;gap:10px;}
.tp-reps-row > div{flex:1;}
.tp-reps-lbl{font-family:'JetBrains Mono',monospace;font-size:.38rem;color:var(--text-muted);letter-spacing:.1em;text-transform:uppercase;margin-bottom:4px;}
.tp-rest-hint{font-family:'JetBrains Mono',monospace;font-size:.38rem;color:#ff9500;letter-spacing:.06em;margin-top:5px;}

/* Equipment & Type pills */
.tp-eq-pills{display:flex;gap:5px;flex-wrap:wrap;}
.tp-eq-pill{
  background:#0e0c1a;border:1px solid rgba(255,255,255,.07);border-radius:9999px;
  padding:6px 11px;font-family:'JetBrains Mono',monospace;font-size:.38rem;
  color:var(--text-muted);text-transform:uppercase;letter-spacing:.1em;
  cursor:pointer;transition:all .15s;-webkit-tap-highlight-color:transparent;
}
.tp-eq-pill.active{background:linear-gradient(135deg,#ff6b00,#ff3d00);border-color:transparent;color:#fff;}
.tp-type-pills{display:flex;gap:6px;}
.tp-type-pill{
  flex:1;text-align:center;background:#0e0c1a;border:1px solid rgba(255,255,255,.07);
  border-radius:9999px;padding:7px 10px;
  font-family:'JetBrains Mono',monospace;font-size:.4rem;
  color:var(--text-muted);text-transform:uppercase;letter-spacing:.12em;
  cursor:pointer;transition:all .15s;-webkit-tap-highlight-color:transparent;
}
.tp-type-pill.active{background:linear-gradient(135deg,#ff6b00,#ff3d00);border-color:transparent;color:#fff;}

/* Autocomplete */
.tp-autocomplete{
  position:absolute;top:100%;left:0;right:0;z-index:400;
  background:#1a1530;border:1px solid rgba(255,255,255,.1);border-radius:10px;margin-top:3px;
  max-height:150px;overflow-y:auto;box-shadow:0 8px 24px rgba(0,0,0,.5);
}
.tp-ac-item{
  padding:10px 14px;font-size:.78rem;font-weight:600;color:#fff8f0;cursor:pointer;
  border-bottom:1px solid rgba(255,255,255,.04);transition:background .12s;
  -webkit-tap-highlight-color:transparent;
}
.tp-ac-item:last-child{border-bottom:none;}
.tp-ac-item:active{background:rgba(255,107,0,.12);}

/* Emoji & color pickers */
.tp-emoji-grid{display:grid;grid-template-columns:repeat(8,1fr);gap:8px;margin-bottom:4px;}
.tp-emoji-pick{
  font-size:1.35rem;text-align:center;padding:5px;border-radius:10px;
  cursor:pointer;transition:background .12s;border:2px solid transparent;
}
.tp-emoji-pick.active{border-color:var(--fire1);background:rgba(255,107,0,.1);}
.tp-color-row{display:flex;gap:8px;flex-wrap:wrap;}
.tp-color-dot{
  width:28px;height:28px;border-radius:50%;cursor:pointer;
  border:2px solid transparent;transition:transform .15s,border-color .15s;
  -webkit-tap-highlight-color:transparent;
}
.tp-color-dot.active{border-color:#fff;transform:scale(1.18);}
.mg-name-chips{display:flex;gap:5px;flex-wrap:wrap;margin-top:8px;}
.mg-name-chip{
  background:rgba(255,107,0,.08);border:1px solid rgba(255,107,0,.15);border-radius:9999px;
  padding:4px 10px;font-family:'JetBrains Mono',monospace;font-size:.4rem;color:#ff9500;
  cursor:pointer;letter-spacing:.08em;text-transform:uppercase;-webkit-tap-highlight-color:transparent;
}

/* Confirm dialog */
.tp-confirm{
  position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.72);
  display:flex;align-items:center;justify-content:center;padding:24px;
  opacity:0;pointer-events:none;transition:opacity .2s;
}
.tp-confirm.open{opacity:1;pointer-events:all;}
.tp-confirm-card{
  background:#1a1530;border:1px solid rgba(255,255,255,.1);border-radius:18px;
  padding:22px;width:100%;max-width:320px;
}
.tp-confirm-title{font-size:1rem;font-weight:800;color:#fff8f0;margin-bottom:8px;}
.tp-confirm-text{font-size:.78rem;color:var(--text-secondary);line-height:1.5;margin-bottom:18px;}
.tp-confirm-btns{display:flex;flex-direction:column;gap:8px;}
.tp-cbtn{
  padding:12px;border-radius:10px;border:none;cursor:pointer;
  font-family:'Outfit',sans-serif;font-size:.82rem;font-weight:700;transition:opacity .15s;
  -webkit-tap-highlight-color:transparent;
}
.tp-cbtn:active{opacity:.8;}
.tp-cbtn.fire{background:linear-gradient(135deg,#ff6b00,#ff3d00);color:#fff;}
.tp-cbtn.danger{background:#ff2d55;color:#fff;}
.tp-cbtn.ghost{background:rgba(255,255,255,.07);color:var(--text-secondary);}

.today-card{
  margin:0 0 12px;
  border-radius:14px;
  padding:14px;
  background:linear-gradient(135deg,rgba(110,99,242,.18),rgba(240,98,146,.10)),var(--bg-card);
  border-color:rgba(110,99,242,.22);
}
.today-card::before{display:none;}
.today-kicker{
  font-size:.48rem;
  letter-spacing:.22em;
  color:var(--purple-300);
}
.today-day{
  font-size:1.35rem;
  font-weight:900;
}
.today-badge{
  background:rgba(110,99,242,.12);
  border-color:rgba(110,99,242,.22);
  color:var(--purple-300);
  font-family:'JetBrains Mono',monospace;
  font-size:.5rem;
  letter-spacing:.08em;
  text-transform:uppercase;
}
.today-stats{gap:5px;margin-bottom:11px;}
.stat-block{
  border-radius:8px;
  padding:8px 5px;
  background:rgba(15,15,26,.5);
}
.stat-val{font-size:.88rem;}
.stat-lbl{font-size:.43rem;letter-spacing:.1em;}
.cta-btn{
  padding:11px;
  font-size:.82rem;
}
.section-row{margin:14px 0 8px;}
.section-row-title{font-size:.86rem;}
.section-row-link{font-size:.48rem;letter-spacing:.16em;}
.cat-grid{
  gap:6px;
  margin-bottom:12px;
}
.cat-card{
  border-radius:12px;
  padding:11px;
  background:var(--bg-card);
  border-color:rgba(255,255,255,.06);
}
.cat-icon-wrap{
  width:28px;height:28px;
  border-radius:7px;
  font-size:.9rem;
}
.cat-name{font-size:.82rem;}
.cat-meta{font-size:.43rem;letter-spacing:.1em;text-transform:uppercase;}
.ex-list{gap:5px;}
.ex-card{
  border-radius:10px;
  padding:10px 11px;
  background:var(--bg-card);
  border-color:rgba(255,255,255,.06);
}
.ex-num{
  width:20px;height:20px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  background:rgba(110,99,242,.12);
  color:var(--purple-300);
  font-size:.52rem;font-weight:700;
}
.ex-name{font-size:.78rem;font-weight:700;}
.ex-sub{font-size:.44rem;letter-spacing:.08em;text-transform:uppercase;}
.protein-tracker,.steps-card,.progress-card,.macro-ring-card,.hydration-card,.streak-banner,.history-card,.set-tracker,.pr-card,.ex-hero{
  border-radius:14px;
  background-color:var(--bg-card);
}
.bottom-nav{
  width:min(368px, calc(100vw - 28px));
  height:64px;
  min-height:64px;
  max-height:64px;
  border-radius:30px;
  padding:7px;
  background:
    linear-gradient(180deg,rgba(255,255,255,.12),rgba(255,255,255,.035)),
    rgba(17,17,31,.68);
  border-color:rgba(255,255,255,.12);
}
.nav-item{
  height:50px;
  min-height:50px;
  border-radius:22px;
  gap:3px;
  padding:5px 4px;
}
.nav-item.active{
  background:linear-gradient(135deg,rgba(110,99,242,.34),rgba(110,99,242,.16));
}
.nav-icon{font-size:1rem;}
.nav-label{font-size:.42rem;letter-spacing:.16em;}
@keyframes screenSoftIn{
  0%{opacity:0;transform:scale(.975);filter:blur(7px);}
  100%{opacity:1;transform:scale(1);filter:blur(0);}
}
.screen.screen-entering{
  animation:screenSoftIn .32s cubic-bezier(.22,1,.36,1);
}

/* KASAI NAV VARIANT D - NEON SLASH UNDERLINE */
.bottom-nav{
  background:linear-gradient(155deg,#0d0b1e,#070510);
  border:1px solid rgba(255,70,0,0.1);
  border-radius:24px;
  padding:6px 8px 0;
  overflow:hidden;
  box-shadow:0 18px 42px rgba(0,0,0,.46),0 0 34px rgba(255,70,0,.05);
}
.bottom-nav::after{
  content:'';
  position:absolute;bottom:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent 5%,rgba(255,80,0,0.12) 30%,rgba(255,45,85,0.18) 50%,rgba(255,80,0,0.12) 70%,transparent 95%);
  pointer-events:none;
}
.kasai-nav-slider{
  position:absolute;bottom:0;height:2px;left:0;width:0;
  background:linear-gradient(90deg,transparent,#ff9500,#ff2d55,#ff9500,transparent);
  box-shadow:0 0 10px rgba(255,100,0,0.8),0 0 20px rgba(255,45,85,0.4);
  transition:left .42s cubic-bezier(.34,1.3,.64,1),width .42s cubic-bezier(.34,1.3,.64,1);
  border-radius:1px;
  z-index:1;
  pointer-events:none;
}
.kasai-nav-slider::after{
  content:'';
  position:absolute;right:-2px;top:-3px;
  width:8px;height:8px;border-radius:50%;
  background:radial-gradient(circle,#fff8c0,rgba(255,200,60,0.4) 60%,transparent 100%);
  box-shadow:0 0 6px #ffca28;
  animation:spark-pulse .8s ease-in-out infinite;
}
@keyframes spark-pulse{
  0%,100%{transform:scale(1);opacity:1;}
  50%{transform:scale(1.4);opacity:.6;}
}
.kasai-nav-particles{
  position:absolute;inset:0;pointer-events:none;overflow:hidden;border-radius:inherit;
}
.kasai-nav-particle{
  position:absolute;border-radius:50%;pointer-events:none;
  animation:p-burst var(--pd,.48s) ease-out forwards;
}
@keyframes p-burst{
  0%{transform:translate(0,0) scale(1);opacity:.9;}
  100%{transform:translate(var(--px),var(--py)) scale(.05);opacity:0;}
}
.bottom-nav .nav-item{
  flex:1;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;
  height:58px;min-height:58px;
  padding:12px 4px 14px;
  border-radius:0;
  background:transparent!important;
  box-shadow:none!important;
  cursor:pointer;position:relative;z-index:2;
  transition:transform .2s cubic-bezier(.34,1.56,.64,1);
}
.bottom-nav .nav-item:active{transform:scale(.88);}
.bottom-nav .nav-icon{
  width:26px;height:26px;
  display:flex;align-items:center;justify-content:center;
  font-size:0;line-height:1;opacity:.22;
  filter:grayscale(.8);
  transition:opacity .3s,filter .3s,transform .3s;
}
.bottom-nav .nav-icon:not([data-variant-d="1"]){
  opacity:0;color:transparent;
}
.bottom-nav .nav-icon svg{width:26px;height:26px;display:block;}
.bottom-nav .nav-item.active .nav-icon{
  opacity:1;transform:scale(1.1);
  filter:drop-shadow(0 0 8px rgba(255,120,0,.85));
}
.bottom-nav .nav-label{
  font-size:7px;letter-spacing:1.8px;text-transform:uppercase;
  color:rgba(255,255,255,.18);
  transition:color .3s;
}
.bottom-nav .nav-item.active .nav-label{color:rgba(255,190,70,.9);}
.bottom-nav .nav-item.morphing .nav-icon{animation:none;}
@media(max-width:480px){
  :root{--nav-h:64px;--scroll-bottom:88px;}
  .bottom-nav{
    width:min(344px, calc(100vw - 28px));
    height:64px;min-height:64px;max-height:64px;
    border-radius:24px;
  }
  .bottom-nav .nav-item{height:58px;min-height:58px;padding:12px 4px 14px;}
  .bottom-nav .nav-label{font-size:7px;}
}

/* KASAI SPLASH SCREEN V2 */


#splash {
  position: fixed; inset: 0;
  background: #04020a;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  z-index: 200000; overflow: hidden;
}
#splash::before{
  content:'KASAI';
  position:absolute;left:50%;top:50%;z-index:4;
  transform:translate(-50%,-50%);
  font-family:'Outfit',system-ui,-apple-system,BlinkMacSystemFont,sans-serif;
  font-size:clamp(42px,13vw,76px);font-weight:900;letter-spacing:.08em;
  background:linear-gradient(135deg,#ffca28,#ff6b00,#ff2d55);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  text-shadow:0 0 24px rgba(255,107,0,.18);
  opacity:1;transition:opacity .22s ease;
}
#splash::after{
  content:'// TRAIN LIKE FIRE';
  position:absolute;left:50%;top:calc(50% + 54px);z-index:4;
  transform:translateX(-50%);
  font-family:'JetBrains Mono',ui-monospace,monospace;
  font-size:8px;letter-spacing:3px;color:rgba(255,149,0,.42);
  white-space:nowrap;opacity:1;transition:opacity .22s ease;
}
#splash.splash-playing::before,
#splash.splash-playing::after,
#splash.external-splash-active::before,
#splash.external-splash-active::after{opacity:0;}
#splash.splash-booting > :not(.version-tag):not(.exit-overlay){
  opacity:0!important;visibility:hidden!important;pointer-events:none!important;
}
#splash.splash-booting .external-splash-frame{
  display:none!important;
}
.external-splash-frame{
  position:absolute;inset:0;width:100%;height:100%;
  border:0;background:#04020a;display:none;z-index:30;
  opacity:0;visibility:hidden;
  transition:opacity .16s ease;
}
#splash.external-splash-active > :not(.external-splash-frame):not(.version-tag):not(.exit-overlay){
  opacity:0!important;pointer-events:none!important;
}
#splash.external-splash-active .external-splash-frame{display:block;}
#splash.external-splash-ready .external-splash-frame{
  opacity:1;visibility:visible;
}
#splash.external-splash-active .version-tag{
  z-index:60;opacity:1!important;
  bottom:max(18px, env(safe-area-inset-bottom, 18px));
  color:rgba(255,202,40,.82);
}
#splash.external-splash-active .exit-overlay{z-index:80;}

/* -- SHARED -- */
.bg-burst { position: absolute; inset: 0; pointer-events: none; opacity: 0; }
.grid-overlay {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(255,100,0,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,100,0,0.03) 1px, transparent 1px);
  background-size: 44px 44px; opacity: 0;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 75%);
  -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 75%);
  pointer-events: none;
}
.particle-field { position: absolute; inset: 0; pointer-events: none; }
.ember { position: absolute; border-radius: 50%; opacity: 0; pointer-events: none; }

@keyframes ember-float {
  0%   { opacity: 0; transform: translateY(0) scale(1); }
  15%  { opacity: 0.9; }
  85%  { opacity: 0.4; }
  100% { opacity: 0; transform: translateY(-320px) scale(0.15); }
}

.center-stage {
  position: relative; z-index: 10;
  display: flex; flex-direction: column; align-items: center;
}

.icon-wrap {
  position: relative; display: flex;
  align-items: center; justify-content: center;
  opacity: 0; margin-bottom: 16px;
}
.icon-glow {
  position: absolute; inset: -50px; border-radius: 50%;
  background: radial-gradient(circle, rgba(255,120,0,0.5) 0%, transparent 65%);
  filter: blur(22px); opacity: 0;
}

.kasai-letter {
  display: inline-block; opacity: 0;
  transform: translateY(38px) scale(0.78);
  font-weight: 900; letter-spacing: 0.1em;
  background: linear-gradient(160deg,#ffe8b0 0%,#ffca28 15%,#ff9500 38%,#ff6b00 58%,#ff3d00 78%,#ff2d55 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.kanji-sub {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; letter-spacing: 4px;
  color: rgba(255,149,0,0.5); text-transform: uppercase;
  opacity: 0; transform: translateY(10px);
}
.tagline-sub {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px; letter-spacing: 3px;
  color: rgba(255,107,0,0.35); text-transform: uppercase;
  opacity: 0; transform: translateY(8px);
}

.loader-wrap {
  position: absolute; bottom: max(60px, env(safe-area-inset-bottom, 60px));
  left: 50%; transform: translateX(-50%);
  width: 150px; display: flex; flex-direction: column;
  align-items: center; gap: 10px; opacity: 0;
}
.loader-track {
  width: 150px; height: 2px;
  background: rgba(255,107,0,0.1); border-radius: 1px; overflow: hidden;
}
.loader-fill {
  height: 100%; width: 0%;
  background: linear-gradient(90deg,#ff9500,#ff6b00,#ff2d55);
  border-radius: 1px; box-shadow: 0 0 8px rgba(255,107,0,0.8);
}
.loader-fill::after {
  content: ''; position: absolute;
  right: 0; top: -3px; width: 4px; height: 8px;
  background: #fffaf0; border-radius: 2px;
  box-shadow: 0 0 10px rgba(255,200,100,1);
}
.loader-lbl {
  font-family: 'JetBrains Mono', monospace;
  font-size: 8.5px; letter-spacing: 2.5px;
  color: rgba(255,107,0,0.3); text-transform: uppercase;
}
.version-tag {
  position: absolute; bottom: max(24px, env(safe-area-inset-bottom, 24px));
  left: 50%; transform: translateX(-50%);
  font-family: 'JetBrains Mono', monospace;
  font-size: 8.5px; letter-spacing: 2px; font-weight: 700;
  color: rgba(255,202,40,0.72); white-space: nowrap; opacity: 0;
  text-transform: uppercase;
  text-shadow: 0 0 12px rgba(255,107,0,0.28);
}
.exit-overlay {
  position: absolute; inset: 0;
  background: #04020a; opacity: 0;
  pointer-events: none; z-index: 999;
}
.variant-badge {
  position: absolute; top: max(52px, env(safe-area-inset-top, 52px)); right: 20px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 7px; letter-spacing: 1.5px;
  color: rgba(255,107,0,0.2); text-transform: uppercase;
  opacity: 0; z-index: 20;
}

/* -- RUNNER ANIMATION (V1) -- */
@keyframes run-cycle {
  0%   { transform: translateX(0) scaleX(1); }
  100% { transform: translateX(0) scaleX(1); }
}
@keyframes runner-bounce {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-6px); }
}
@keyframes speed-lines {
  0%   { opacity: 0; transform: translateX(30px); }
  30%  { opacity: 0.6; }
  100% { opacity: 0; transform: translateX(-80px); }
}
.speed-line {
  position: absolute; height: 1px; pointer-events: none; opacity: 0;
  background: linear-gradient(90deg, transparent, rgba(255,149,0,0.5), transparent);
}

/* -- LIGHTNING (V2) -- */
@keyframes bolt-flash {
  0%,100% { opacity: 0; }
  5%  { opacity: 1; }
  10% { opacity: 0.3; }
  15% { opacity: 0.9; }
  20% { opacity: 0; }
}
.lightning-bolt { position: absolute; pointer-events: none; opacity: 0; }

/* -- HEARTBEAT (V3) -- */
@keyframes pulse-ring {
  0%   { transform: scale(0.8); opacity: 0.9; }
  100% { transform: scale(2.2); opacity: 0; }
}
.pulse-ring {
  position: absolute; border-radius: 50%;
  border: 1.5px solid rgba(255,107,0,0.5);
  pointer-events: none; opacity: 0;
}
@keyframes ecg-draw {
  0%   { stroke-dashoffset: 600; opacity: 1; }
  60%  { stroke-dashoffset: 0; opacity: 1; }
  100% { stroke-dashoffset: 0; opacity: 0.3; }
}

/* -- MOUNTAIN / SUMMIT (V4) -- */
@keyframes peak-rise {
  0%   { transform: translateY(80px); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}
@keyframes star-twinkle {
  0%,100% { opacity: 0.15; transform: scale(1); }
  50%      { opacity: 0.8; transform: scale(1.4); }
}

/* -- WEIGHT / DUMBBELL (V5) -- */
@keyframes lift-up {
  0%   { transform: translateY(20px) scale(0.9); opacity: 0; }
  60%  { transform: translateY(-8px) scale(1.02); opacity: 1; }
  80%  { transform: translateY(0) scale(1); opacity: 1; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}
@keyframes impact-ring {
  0%   { transform: scale(0.5); opacity: 1; border-color: rgba(255,107,0,0.9); }
  100% { transform: scale(3); opacity: 0; border-color: rgba(255,45,85,0); }
}


#splash{transition:opacity .35s ease;}
body.splash-done #splash{display:none;}

.flame-svg{width:118px;height:170px}.loader-wrap{bottom:calc(env(safe-area-inset-bottom,0px) + 48px)}.version{bottom:calc(env(safe-area-inset-bottom,0px) + 22px)}}

/* KASAI Run Tracker */
.run-section{margin:24px 0 8px;padding:18px 0 4px;border-top:1px solid rgba(255,107,0,.12);}
.run-sec-header,.run-card-head,.run-list-head{display:flex;align-items:center;justify-content:space-between;gap:12px;}
.run-sec-header{margin-bottom:14px;}
.run-sec-label{font-family:'JetBrains Mono',monospace;font-size:.52rem;letter-spacing:.24em;color:rgba(255,107,0,.48);text-transform:uppercase;}
.run-sec-title{margin-top:2px;font-size:1.05rem;font-weight:900;color:rgba(255,255,255,.9);}
.run-sec-badge,.run-all-btn{font-family:'JetBrains Mono',monospace;font-size:.48rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,149,0,.76);background:rgba(255,107,0,.1);border:1px solid rgba(255,107,0,.22);border-radius:999px;padding:5px 10px;}
.run-stat-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;}
.run-stat-card,.run-chart-card,.run-calendar-card{background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.06);border-radius:16px;position:relative;overflow:hidden;}
.run-stat-card{padding:12px 13px;}
.run-stat-card.primary{background:linear-gradient(135deg,rgba(255,100,0,.14),rgba(255,45,85,.08));border-color:rgba(255,107,0,.24);}
.run-stat-lbl{font-family:'JetBrains Mono',monospace;font-size:.48rem;letter-spacing:.18em;color:rgba(255,255,255,.28);text-transform:uppercase;margin-bottom:5px;}
.run-stat-val{font-size:1.52rem;font-weight:900;line-height:1;color:rgba(255,255,255,.78);}
.run-stat-val.fire{background:linear-gradient(135deg,#ffca28,#ff6b00,#ff2d55);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.run-stat-val span{font-size:.72rem;font-weight:500;margin-left:2px;color:rgba(255,255,255,.34);-webkit-text-fill-color:rgba(255,255,255,.34);}
.run-stat-sub,.run-stat-trend{font-family:'JetBrains Mono',monospace;font-size:.55rem;color:rgba(255,255,255,.28);margin-top:4px;}
.run-stat-trend.up{color:rgba(100,220,130,.76);}
.run-stat-trend.down{color:rgba(255,120,120,.78);}
.run-chart-card,.run-calendar-card{padding:14px;margin-bottom:12px;}
.run-card-title{font-size:.72rem;font-weight:800;color:rgba(255,255,255,.55);letter-spacing:.04em;}
.run-toggle{display:flex;gap:3px;}
.run-mode-btn,.run-cal-btn{border:1px solid transparent;border-radius:7px;background:transparent;color:rgba(255,255,255,.22);font-family:'JetBrains Mono',monospace;font-size:.46rem;letter-spacing:.12em;font-weight:800;}
.run-mode-btn{padding:4px 9px;}
.run-mode-btn.active{background:rgba(255,107,0,.16);border-color:rgba(255,107,0,.25);color:rgba(255,169,70,.88);}
.run-bars{height:98px;display:grid;grid-template-columns:repeat(7,1fr);gap:6px;align-items:end;margin-top:13px;}
.run-bar-col{height:100%;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;gap:5px;min-width:0;}
.run-bar-track{height:72px;width:100%;background:rgba(255,255,255,.05);border-radius:6px 6px 4px 4px;position:relative;overflow:visible;}
.run-bar-track.today{outline:1px solid rgba(255,149,0,.36);outline-offset:1px;}
.run-bar-fill{position:absolute;left:0;right:0;bottom:0;height:0;border-radius:5px 5px 3px 3px;background:rgba(255,255,255,.08);transition:height .6s cubic-bezier(.34,1.3,.64,1);}
.run-bar-fill.has-run{background:linear-gradient(180deg,#ff9500,#ff2d55);}
.run-bar-fill.today{background:linear-gradient(180deg,#ffca28,#ff6b00);}
.run-pause-stack{
  position:absolute;right:3px;bottom:4px;width:5px;
  display:flex;flex-direction:column-reverse;gap:2px;align-items:center;
  pointer-events:none;z-index:3;opacity:.9;
}
.run-pause-stack i{
  width:5px;height:2px;border-radius:999px;
  background:rgba(230,232,244,.72);
  box-shadow:0 0 6px rgba(230,232,244,.2);
  animation:runPauseBlink .9s cubic-bezier(.22,1,.36,1) both;
}
.run-pause-more{
  font-family:'JetBrains Mono',monospace;font-size:.42rem;line-height:1;
  color:rgba(235,235,245,.72);margin-bottom:1px;
}
@keyframes runPauseBlink{
  from{opacity:0;transform:translateY(4px) scaleX(.4);}
  to{opacity:1;transform:translateY(0) scaleX(1);}
}
.run-bar-val{position:absolute;top:-15px;left:50%;transform:translateX(-50%);white-space:nowrap;font-family:'JetBrains Mono',monospace;font-size:.44rem;color:rgba(255,149,0,.62);}
.run-bar-day{font-family:'JetBrains Mono',monospace;font-size:.46rem;color:rgba(255,255,255,.24);text-transform:uppercase;}
.run-bar-day.today{color:rgba(255,149,0,.72);}
.run-cal-nav{display:flex;gap:6px;}
.run-cal-btn{width:24px;height:24px;border-color:rgba(255,255,255,.08);font-size:1rem;line-height:1;color:rgba(255,255,255,.34);}
.run-weekdays,.run-cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;}
.run-weekdays{margin:12px 0 5px;}
.run-weekdays span{font-family:'JetBrains Mono',monospace;font-size:.44rem;letter-spacing:.05em;text-align:center;color:rgba(255,255,255,.18);text-transform:uppercase;}
.run-cal-cell{aspect-ratio:1;border-radius:6px;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:.52rem;position:relative;color:rgba(255,255,255,.24);}
.run-cal-cell.empty{background:transparent;}
.run-cal-cell.rest{background:rgba(255,255,255,.045);}
.run-cal-cell.light{background:rgba(255,107,0,.15);color:rgba(255,180,60,.72);}
.run-cal-cell.medium{background:rgba(255,107,0,.28);color:rgba(255,190,80,.86);}
.run-cal-cell.heavy{background:linear-gradient(135deg,rgba(255,149,0,.42),rgba(255,45,85,.32));color:#ffca28;font-weight:900;}
.run-cal-cell.future{background:transparent;color:rgba(255,255,255,.08);}
.run-cal-cell.today{outline:1.5px solid rgba(255,107,0,.55);outline-offset:1px;}
.run-cal-dot{position:absolute;bottom:3px;left:50%;transform:translateX(-50%);width:3px;height:3px;border-radius:50%;background:#ff6b00;}
.run-legend{display:flex;align-items:center;justify-content:flex-end;gap:6px;margin-top:9px;}
.run-legend span{font-family:'JetBrains Mono',monospace;font-size:.44rem;color:rgba(255,255,255,.2);letter-spacing:.12em;text-transform:uppercase;}
.run-legend i{width:8px;height:8px;border-radius:2px;background:rgba(255,255,255,.06);}
.run-legend i:nth-of-type(2){background:rgba(255,107,0,.15);}
.run-legend i:nth-of-type(3){background:rgba(255,107,0,.28);}
.run-legend i:nth-of-type(4){background:rgba(255,100,0,.42);}
.run-list-head{margin:2px 0 8px;}
.run-all-btn{background:transparent;cursor:pointer;}
.run-item{display:flex;align-items:center;gap:10px;padding:10px 11px;border-radius:13px;margin-bottom:6px;border:1px solid transparent;background:rgba(255,255,255,.018);position:relative;overflow:hidden;cursor:pointer;transition:transform .18s var(--ease),border-color .18s var(--ease),background .18s var(--ease);}
.run-item:active{transform:scale(.985);background:rgba(255,255,255,.035);border-color:rgba(255,107,0,.12);}
.run-item::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:rgba(255,255,255,.12);}
.run-item.pr::before{background:linear-gradient(180deg,#ffca28,#ff6b00);}
.run-item.good::before{background:linear-gradient(180deg,#ff9500,#ff3d00);}
.run-icon{width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(255,107,0,.1);border:1px solid rgba(255,107,0,.16);color:#ff9500;font-weight:900;}
.run-info{flex:1;min-width:0;}
.run-name{font-size:.78rem;font-weight:800;color:rgba(255,255,255,.78);}
.run-meta{font-family:'JetBrains Mono',monospace;font-size:.55rem;color:rgba(255,255,255,.26);}
.run-proof-dot{display:inline-flex;align-items:center;gap:3px;margin-left:6px;color:rgba(255,202,40,.66);}
.run-right{text-align:right;flex-shrink:0;}
.run-km{font-size:.95rem;font-weight:900;background:linear-gradient(135deg,#ffca28,#ff6b00);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.run-pace{font-family:'JetBrains Mono',monospace;font-size:.5rem;color:rgba(255,255,255,.24);}
.run-pr-badge{font-family:'JetBrains Mono',monospace;font-size:.42rem;letter-spacing:.12em;color:#ffca28;background:rgba(255,180,0,.1);border:1px solid rgba(255,180,0,.24);border-radius:5px;padding:1px 5px;margin-left:5px;vertical-align:middle;}
.run-empty{padding:14px;border:1px dashed rgba(255,107,0,.16);border-radius:14px;color:rgba(255,255,255,.35);font-size:.8rem;text-align:center;}
.run-log-btn{width:100%;margin-top:6px;padding:13px;border:none;border-radius:14px;background:linear-gradient(135deg,#ff9500,#ff6b00 50%,#ff2d55);color:#fff;font-weight:800;font-size:.84rem;letter-spacing:.04em;display:flex;align-items:center;justify-content:center;gap:8px;}
.run-plus{font-family:'JetBrains Mono',monospace;font-size:1rem;}
.run-form{margin-top:12px;padding:16px;background:linear-gradient(160deg,rgba(35,24,49,.985),rgba(10,8,22,.99));border:1px solid rgba(255,107,0,.24);border-radius:20px;display:none;opacity:0;transform:translateY(12px) scale(.98);transition:opacity .35s cubic-bezier(.34,1.3,.64,1),transform .35s cubic-bezier(.34,1.3,.64,1),border-color .2s var(--ease),box-shadow .2s var(--ease);box-shadow:0 20px 45px rgba(0,0,0,.28),inset 0 1px 0 rgba(255,255,255,.05);position:relative;overflow:hidden;}
.run-form::before{content:'';position:absolute;inset:0 0 auto;height:2px;background:linear-gradient(90deg,transparent,#ff9500,#ff2d55,transparent);opacity:.85;}
.run-form.open{display:block;opacity:1;transform:translateY(0) scale(1);}
.run-form:focus-within{border-color:rgba(255,149,0,.38);box-shadow:0 22px 50px rgba(0,0,0,.34),0 0 0 1px rgba(255,149,0,.08),inset 0 1px 0 rgba(255,255,255,.06);}
.run-form-title{font-size:.95rem;font-weight:900;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;gap:8px;}
.run-form-title::after{content:'// optional proof';font-family:'JetBrains Mono',monospace;font-size:.42rem;letter-spacing:.14em;color:rgba(255,149,0,.32);text-transform:uppercase;font-weight:700;}
.run-form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px 9px;}
.run-form label{min-width:0;}
.run-form label span,.run-pr-toggle span{display:block;font-family:'JetBrains Mono',monospace;font-size:.46rem;letter-spacing:.16em;color:rgba(255,255,255,.28);text-transform:uppercase;margin-bottom:5px;}
.run-form input,.run-form select{width:100%;min-width:0;max-width:100%;background:linear-gradient(180deg,rgba(255,255,255,.075),rgba(255,255,255,.04));border:1px solid rgba(255,255,255,.12);border-radius:14px;padding:12px 11px;color:rgba(255,255,255,.86);font-family:'JetBrains Mono',monospace;font-size:16px;outline:none;box-shadow:inset 0 1px 0 rgba(255,255,255,.06),0 10px 24px rgba(0,0,0,.13);transition:border-color .18s var(--ease),box-shadow .18s var(--ease),background .18s var(--ease),transform .18s var(--ease);}
.run-form input:focus,.run-form select:focus{background:rgba(255,255,255,.075);border-color:rgba(255,149,0,.38);box-shadow:0 0 0 2px rgba(255,149,0,.08);}
.run-form input.invalid{border-color:rgba(255,95,110,.72);box-shadow:0 0 0 1px rgba(255,95,110,.18);}
.run-form select{appearance:none;-webkit-appearance:none;padding-right:28px;background-image:linear-gradient(45deg,transparent 50%,rgba(255,202,40,.72) 50%),linear-gradient(135deg,rgba(255,202,40,.72) 50%,transparent 50%),linear-gradient(180deg,rgba(255,255,255,.075),rgba(255,255,255,.04));background-position:calc(100% - 17px) 50%,calc(100% - 12px) 50%,0 0;background-size:5px 5px,5px 5px,100% 100%;background-repeat:no-repeat;}
.run-field-date input,.run-field-type select{height:46px;text-align:center;font-size:14px;font-weight:800;letter-spacing:0;border-radius:13px;padding-top:8px;padding-bottom:8px;}
.run-field-type select{text-align-last:center;}
.run-field-date,.run-field-type{position:relative;overflow:hidden;}
.run-field-date input{appearance:none;-webkit-appearance:none;padding-left:9px;padding-right:9px;}
.run-field-date input::-webkit-date-and-time-value{text-align:center;}
.run-field-date input::-webkit-calendar-picker-indicator{width:14px;height:14px;margin-left:-4px;opacity:.55;filter:invert(1) sepia(1) saturate(3) hue-rotate(350deg);}
.run-field-type select{padding-left:8px;padding-right:24px;background-position:calc(100% - 14px) 50%,calc(100% - 9px) 50%,0 0;}
.run-pr-toggle{display:flex!important;align-items:center;gap:8px;margin-top:10px;}
.run-pr-toggle input{width:auto;}
.run-pr-toggle span{margin:0;}
.run-proof-field{grid-column:1/-1;}
.run-proof-field input[type="file"]{padding:8px;font-size:.72rem;}
.run-proof-field input[type="file"]::file-selector-button{
  border:0;border-radius:9px;padding:8px 10px;margin-right:8px;
  background:rgba(255,149,0,.14);color:#ffca28;font-family:'JetBrains Mono',monospace;
  font-size:.58rem;font-weight:900;letter-spacing:.08em;text-transform:uppercase;
}
.run-proof-preview{min-height:38px;margin-top:7px;border:1px dashed rgba(255,149,0,.18);border-radius:12px;padding:7px;display:flex;align-items:center;gap:7px;overflow-x:auto;scrollbar-width:none;background:rgba(255,149,0,.035);}
.run-proof-preview::-webkit-scrollbar{display:none;}
.run-proof-empty{font-family:'JetBrains Mono',monospace;font-size:.5rem;letter-spacing:.1em;color:rgba(255,255,255,.24);text-transform:uppercase;}
.run-proof-thumb{width:46px;height:46px;border-radius:11px;object-fit:contain;background:rgba(5,4,12,.62);flex-shrink:0;border:1px solid rgba(255,255,255,.1);box-shadow:0 8px 18px rgba(0,0,0,.24);animation:runProofPop .26s cubic-bezier(.34,1.56,.64,1) both;}
@keyframes runProofPop{from{opacity:0;transform:scale(.82) translateY(6px);}to{opacity:1;transform:scale(1) translateY(0);}}
.run-form-error{min-height:16px;margin-top:8px;color:#ff8fa0;font-size:.72rem;}
.run-form-actions{display:flex;gap:8px;margin-top:8px;}
.run-form-btn{flex:1;border:none;border-radius:11px;padding:11px;font-family:'JetBrains Mono',monospace;font-size:.52rem;letter-spacing:.14em;text-transform:uppercase;font-weight:900;}
.run-form-btn.ghost{background:rgba(255,255,255,.06);color:rgba(255,255,255,.42);border:1px solid rgba(255,255,255,.08);}
.run-form-btn.save{background:linear-gradient(135deg,#ff9500,#ff2d55);color:#fff;}
.run-form-overlay{z-index:60000;}
.run-form-sheet{
  max-height:min(88vh,760px);
  padding:12px 20px calc(24px + env(safe-area-inset-bottom,0px));
  background:linear-gradient(165deg,rgba(23,15,35,.98),rgba(8,7,17,.995));
  border:1px solid rgba(255,149,0,.18);
  border-bottom:0;
  box-shadow:0 -22px 60px rgba(0,0,0,.42),inset 0 1px 0 rgba(255,255,255,.06);
}
.run-form.in-sheet{
  display:block;
  margin:0;
  padding:0;
  background:transparent;
  border:0;
  border-radius:0;
  box-shadow:none;
  opacity:1;
  transform:none;
  overflow:visible;
}
.run-form.in-sheet::before{display:none;}
.run-form.in-sheet .run-form-title{font-size:1.08rem;margin:2px 0 14px;}
.run-form.in-sheet .run-form-actions{position:sticky;bottom:0;padding-top:10px;background:linear-gradient(180deg,transparent,rgba(8,7,17,.96) 35%);}
.run-detail-overlay{z-index:60000;}
.run-detail-card{max-height:min(82vh,720px);overflow-y:auto;}
.run-detail-hero{position:relative;margin:-2px -2px 14px;border-radius:18px;overflow:hidden;background:linear-gradient(135deg,rgba(255,149,0,.18),rgba(255,45,85,.08));border:1px solid rgba(255,149,0,.18);padding:16px;}
.run-detail-hero::before{content:'';position:absolute;right:-40px;top:-60px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(255,149,0,.2),transparent 70%);filter:blur(8px);}
.run-detail-km{font-size:2.1rem;font-weight:900;line-height:1;background:linear-gradient(135deg,#ffca28,#ff6b00,#ff2d55);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.run-detail-meta{font-family:'JetBrains Mono',monospace;font-size:.56rem;letter-spacing:.08em;color:rgba(255,255,255,.38);text-transform:uppercase;margin-top:5px;}
.run-detail-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px;}
.run-detail-stat{background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:10px;text-align:center;}
.run-detail-stat strong{display:block;font-size:1rem;color:rgba(255,255,255,.86);}
.run-detail-stat span{font-family:'JetBrains Mono',monospace;font-size:.44rem;color:rgba(255,255,255,.28);letter-spacing:.12em;text-transform:uppercase;}
.run-proof-gallery{display:grid;grid-template-columns:1fr;gap:10px;margin-top:10px;}
.run-proof-gallery img{width:100%;max-height:min(68vh,620px);aspect-ratio:9/16;object-fit:contain;background:linear-gradient(160deg,rgba(255,149,0,.08),rgba(5,4,12,.82));border-radius:16px;border:1px solid rgba(255,255,255,.1);box-shadow:0 14px 28px rgba(0,0,0,.25);animation:runProofPop .28s cubic-bezier(.34,1.56,.64,1) both;}
.run-proof-none{padding:12px;border:1px dashed rgba(255,149,0,.18);border-radius:14px;color:rgba(255,255,255,.32);font-size:.78rem;text-align:center;}
.run-detail-proof-uploader{margin-top:12px;border:1px solid rgba(255,149,0,.16);border-radius:16px;padding:11px;background:linear-gradient(135deg,rgba(255,149,0,.07),rgba(255,45,85,.035));}
.run-detail-proof-uploader label{display:flex;align-items:center;justify-content:space-between;gap:10px;cursor:pointer;}
.run-detail-proof-uploader input{position:absolute;width:1px;height:1px;opacity:0;pointer-events:none;}
.run-detail-proof-copy{min-width:0;}
.run-detail-proof-copy strong{display:block;font-size:.76rem;color:rgba(255,255,255,.8);}
.run-detail-proof-copy span{display:block;margin-top:2px;font-family:'JetBrains Mono',monospace;font-size:.46rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.3);}
.run-detail-proof-action{flex-shrink:0;border-radius:999px;padding:8px 10px;background:rgba(255,149,0,.14);border:1px solid rgba(255,149,0,.24);color:#ffca28;font-family:'JetBrains Mono',monospace;font-size:.48rem;letter-spacing:.12em;text-transform:uppercase;font-weight:900;}
.run-detail-proof-status{min-height:15px;margin-top:7px;font-size:.68rem;color:rgba(255,255,255,.36);}
@media(max-width:520px){
  .run-field-date,.run-field-type{grid-column:1/-1;}
  .run-field-date input,.run-field-type select{height:44px;font-size:13.5px;padding-top:7px;padding-bottom:7px;}
}
@media(max-width:360px){.run-form-grid,.run-stat-row{grid-template-columns:1fr;}}

/* -- Time-of-day planning / premium daily structure -- */
.language-switch{
  display:inline-flex;align-items:center;gap:4px;
  padding:4px;border:1px solid rgba(255,255,255,.1);
  border-radius:999px;background:rgba(255,255,255,.055);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.04);
}
.auth-language-switch{position:absolute;top:18px;right:18px;z-index:7;}
.language-switch button{
  border:0;border-radius:999px;background:transparent;color:rgba(255,255,255,.48);
  min-width:38px;height:30px;padding:0 8px;font-family:'JetBrains Mono',monospace;
  font-size:.58rem;font-weight:900;letter-spacing:.08em;cursor:pointer;
  transition:all .18s var(--ease);touch-action:manipulation;
}
.language-switch button.active{
  color:#fff;background:linear-gradient(135deg,rgba(255,149,0,.95),rgba(255,45,85,.88));
  box-shadow:0 8px 18px rgba(255,80,0,.18);
}
.tp-time-picker{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;}
.tp-time-pill{
  position:relative;border:1px solid rgba(255,255,255,.08);border-radius:14px;
  padding:10px 5px;background:rgba(255,255,255,.04);text-align:center;
  cursor:pointer;transition:all .18s var(--ease);overflow:hidden;
  -webkit-tap-highlight-color:transparent;
}
.tp-time-pill::before{
  content:'';position:absolute;inset:0;opacity:0;transition:opacity .18s var(--ease);
  background:linear-gradient(135deg,rgba(255,202,40,.16),rgba(255,45,85,.08));
}
.tp-time-pill.active{border-color:rgba(255,149,0,.48);box-shadow:0 12px 24px rgba(255,80,0,.12);}
.tp-time-pill.active::before{opacity:1;}
.tp-time-ico,.tp-time-name{position:relative;display:block;}
.tp-time-ico{font-size:1rem;margin-bottom:3px;}
.tp-time-name{
  font-family:'JetBrains Mono',monospace;font-size:.44rem;letter-spacing:.12em;
  text-transform:uppercase;color:rgba(255,255,255,.56);font-weight:900;
}
.tp-time-pill.active .tp-time-name{color:#ffca28;}
.time-task-section{margin:2px 0 18px;}
.time-task-grid{display:flex;flex-direction:column;gap:9px;}
.time-task-card{
  position:relative;overflow:hidden;border-radius:18px;padding:12px;
  background:linear-gradient(145deg,rgba(255,255,255,.055),rgba(255,255,255,.022));
  border:1px solid rgba(255,255,255,.075);
  box-shadow:0 14px 34px rgba(0,0,0,.20);
}
.time-task-card::before{
  content:'';position:absolute;inset:0 0 auto 0;height:2px;
  background:linear-gradient(90deg,var(--time-color,#ff9500),transparent);
  opacity:.85;
}
.time-task-head{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:10px;}
.time-task-title{display:flex;align-items:center;gap:9px;font-weight:900;font-size:.88rem;}
.time-task-title span:first-child{
  width:30px;height:30px;border-radius:11px;display:flex;align-items:center;justify-content:center;
  background:color-mix(in srgb,var(--time-color,#ff9500) 16%,transparent);
  border:1px solid color-mix(in srgb,var(--time-color,#ff9500) 24%,transparent);
}
.time-task-meta{
  font-family:'JetBrains Mono',monospace;font-size:.46rem;letter-spacing:.14em;
  color:rgba(255,255,255,.34);text-transform:uppercase;
}
.time-task-items{display:flex;flex-direction:column;gap:7px;}
.time-task-item{
  display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:9px;
  border-radius:13px;padding:9px;background:rgba(5,4,12,.32);
  border:1px solid rgba(255,255,255,.055);
  cursor:pointer;touch-action:manipulation;
  transition:transform .18s var(--ease),border-color .18s var(--ease),background .18s var(--ease);
}
.time-task-item:active{transform:scale(.985);background:rgba(255,255,255,.055);}
.time-task-icon{
  width:28px;height:28px;border-radius:10px;display:flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,.055);font-size:.9rem;
}
.time-task-name{font-weight:800;font-size:.78rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.time-task-sub{
  margin-top:1px;font-family:'JetBrains Mono',monospace;font-size:.43rem;letter-spacing:.11em;
  color:rgba(255,255,255,.3);text-transform:uppercase;
}
.time-task-check{
  width:30px;height:30px;border-radius:999px;border:1px solid rgba(255,255,255,.09);
  background:rgba(255,255,255,.055);color:rgba(255,255,255,.42);
  display:flex;align-items:center;justify-content:center;font-weight:900;
}
.time-task-check.done{
  color:#06170d;background:#26d47c;border-color:#26d47c;
  box-shadow:0 0 18px rgba(38,212,124,.22);
}
.scroll-focus{
  animation:kasai-scroll-focus 1.25s ease both;
}
@keyframes kasai-scroll-focus{
  0%{box-shadow:0 0 0 rgba(38,212,124,0);border-color:rgba(38,212,124,.12);}
  28%{box-shadow:0 0 0 1px rgba(38,212,124,.62),0 0 28px rgba(38,212,124,.22);border-color:rgba(38,212,124,.65);}
  100%{box-shadow:0 0 0 rgba(38,212,124,0);border-color:var(--border-default);}
}
.time-chip{
  display:inline-flex;align-items:center;gap:4px;padding:3px 7px;border-radius:999px;
  background:rgba(255,149,0,.10);border:1px solid rgba(255,149,0,.18);
  color:#ffca28;font-family:'JetBrains Mono',monospace;font-size:.42rem;
  letter-spacing:.1em;text-transform:uppercase;font-weight:900;
}
.cat-card.premium-muscle{
  min-height:116px;padding:12px;background:
    linear-gradient(150deg,rgba(255,255,255,.055),rgba(255,255,255,.02)),
    var(--bg-card);
}
.cat-card.premium-muscle::before{
  content:'';position:absolute;right:-28px;top:-32px;width:92px;height:92px;border-radius:50%;
  background:radial-gradient(circle,color-mix(in srgb,var(--cat-color,#ff9500) 28%,transparent),transparent 70%);
  filter:blur(3px);opacity:.6;pointer-events:none;
}
.cat-card.premium-muscle .cat-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;position:relative;}
.cat-card.premium-muscle .cat-icon-wrap{margin-bottom:0;}
.cat-card.premium-muscle .cat-name{margin-top:10px;position:relative;}
.cat-card.premium-muscle .cat-meta{position:relative;margin-top:4px;}
.cat-progress-ring{
  width:34px;height:34px;border-radius:50%;
  background:conic-gradient(var(--cat-color,#ff9500) calc(var(--cat-pct,0)*1%),rgba(255,255,255,.08) 0);
  display:grid;place-items:center;box-shadow:inset 0 0 0 1px rgba(255,255,255,.05);
}
.cat-progress-ring::after{
  content:attr(data-pct);width:26px;height:26px;border-radius:50%;display:grid;place-items:center;
  background:#0f0d1a;color:rgba(255,255,255,.66);font-family:'JetBrains Mono',monospace;
  font-size:.42rem;font-weight:900;
}
.notify-auto-time{
  justify-self:end;max-width:118px;text-align:right;
  font-family:'JetBrains Mono',monospace;font-size:.46rem;line-height:1.35;
  letter-spacing:.08em;text-transform:uppercase;color:#ffca28;
}
.native-push-note{
  border:1px solid rgba(255,149,0,.14);border-radius:16px;padding:11px;
  background:linear-gradient(135deg,rgba(255,149,0,.07),rgba(110,99,242,.045));
  font-size:.72rem;line-height:1.45;color:rgba(255,255,255,.5);
}
.native-push-note strong{display:block;color:rgba(255,255,255,.82);margin-bottom:3px;}

</style>
