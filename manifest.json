    <g id="runnerGroup" style="animation: runner-bounce 0.55s ease-in-out infinite;" filter="url(#run-glow)">
      <!-- head -->
      <circle cx="105" cy="42" r="16" fill="url(#run-g)"/>
      <!-- torso -->
      <path d="M105,58 C100,68 92,80 88,95 L98,95 C100,84 107,74 112,66 Z" fill="url(#run-g)"/>
      <!-- fwd arm -->
      <path d="M105,65 C112,60 122,58 130,62" stroke="url(#run-g)" stroke-width="6" fill="none" stroke-linecap="round"/>
      <!-- back arm -->
      <path d="M100,68 C92,74 82,76 76,80" stroke="url(#run-g)" stroke-width="6" fill="none" stroke-linecap="round"/>
      <!-- fwd leg -->
      <path d="M95,95 C90,108 85,120 78,132 C84,135 90,135 94,130 C98,120 103,108 105,97 Z" fill="url(#run-g)"/>
      <!-- back leg -->
      <path d="M98,95 C104,110 108,124 112,138 C118,136 122,132 120,126 C116,115 110,102 106,95 Z" fill="url(#run-g)"/>
      <!-- fwd foot -->
      <path d="M78,132 C72,136 65,138 60,136 C62,142 70,145 80,142 C86,139 90,135 94,130 Z" fill="url(#run-g)"/>
      <!-- back foot -->
      <path d="M112,138 C116,142 120,145 126,143 C128,137 124,134 120,126 Z" fill="url(#run-g)"/>
    </g>
    <!-- speed lines -->
    <line id="sl1" class="speed-line" x1="0" y1="90" x2="55" y2="90" style="stroke:rgba(255,149,0,0.4);stroke-width:1.5;"/>
    <line id="sl2" class="speed-line" x1="0" y1="100" x2="42" y2="100" style="stroke:rgba(255,107,0,0.3);stroke-width:1;"/>
    <line id="sl3" class="speed-line" x1="0" y1="110" x2="60" y2="110" style="stroke:rgba(255,80,0,0.25);stroke-width:1.5;"/>
    <!-- motion trail dots -->
    <circle cx="75" cy="58" r="2.5" fill="rgba(255,149,0,0.25)"/>
    <circle cx="60" cy="55" r="1.8" fill="rgba(255,149,0,0.15)"/>
    <circle cx="47" cy="53" r="1.2" fill="rgba(255,149,0,0.08)"/>
  </svg>`,

  // V2: Lightning bolt
  `<svg width="160" height="180" viewBox="0 0 160 180" xmlns="http://www.w3.org/2000/svg" id="iconSvg">
    <defs>
      <linearGradient id="bolt-g" x1="0.3" y1="0" x2="0.7" y2="1">
        <stop offset="0%" stop-color="#fff8c0"/>
