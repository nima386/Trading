<script>
window.kasaiSetAuthMode = function(mode){
  ['welcome','login','signup','pending','profile','new-password','reset'].forEach(function(name){
    var panel = document.getElementById('auth-' + name + '-panel');
    if(panel) panel.classList.toggle('active', name === mode);
  });
};
window.kasaiAuthStatus = function(message, type){
  var gate = document.getElementById('gate-auth-status');
  if(!gate) return;
  gate.textContent = message || '';
  gate.className = 'auth-status auth-gate-status' + (type ? ' ' + type : '');
};
window.kasaiEarlySupabaseClient = async function(){
  var started = Date.now();
  while(!(window.supabase && window.supabase.createClient) && Date.now() - started < 6000){
    await new Promise(function(resolve){ setTimeout(resolve, 100); });
  }
  if(!(window.supabase && window.supabase.createClient)) return null;
  if(window.__kasaiEarlySupabase) return window.__kasaiEarlySupabase;
  window.__kasaiEarlySupabase = window.supabase.createClient(
    'https://llpiuyksrpdogirblifr.supabase.co',
    'sb_publishable_rLqfnxo6j7_bm4-wrCSevA_IqfEEUOc',
    {
      auth: {
        persistSession: true,
        autoRefreshToken: true,
        detectSessionInUrl: true,
        storage: window.localStorage,
        storageKey: 'forge.supabase.auth'
      }
    }
  );
  return window.__kasaiEarlySupabase;
};
window.kasaiSetButtonBusy = function(btn, busy){
  if(!btn) return;
  btn.disabled = !!busy;
  btn.classList.toggle('loading', !!busy);
};
window.kasaiContinueAfterAuth = function(session, message){
  if(!session || !session.user) return;
  try{ authSession = session; }catch(_){}
  try{ if(typeof rememberSupabaseSession === 'function') rememberSupabaseSession(session); }catch(_){}
  try{ authLoading = false; }catch(_){}
  document.body.classList.remove('auth-locked','auth-checking');
  window.kasaiAuthStatus(message || '');
  try{
    if(typeof bootstrapAuthenticatedSession === 'function') {
      bootstrapAuthenticatedSession(session);
      return;
    }
  }catch(error){
    console.warn('Auth bootstrap failed, continuing with unlocked app.', error);
  }
  try{ if(typeof updateAuthUI === 'function') updateAuthUI(); }catch(_){}
  try{ if(typeof renderAll === 'function') renderAll(); }catch(_){}
  try{ if(typeof refreshAuthSession === 'function') refreshAuthSession(); }catch(_){}
};
window.addEventListener('error', function(event){
  if(window.__kasaiAuthMainReady) return;
  var message = event && event.message ? event.message : 'Unbekannter JavaScript-Fehler';
  console.warn('KASAI startup error before auth ready', message);
  window.kasaiAuthStatus('App-Startfehler: ' + message, 'error');
});
window.kasaiAuthTimeout = function(promise, label){
  return Promise.race([
    promise,
    new Promise(function(_, reject){
      setTimeout(function(){ reject(new Error((label || 'Supabase Auth') + ' timeout')); }, 12000);
    })
  ]);
};
window.kasaiEarlyEnhanceButton = function(btn){
  if(!btn || btn.dataset.premiumEnhanced === '1') return;
  btn.dataset.premiumEnhanced = '1';
  btn.classList.add('kasai-btn','kasai-btn-login');
  var label = btn.innerHTML.trim();
  btn.innerHTML =
    '<span class="kasai-btn-halo login-halo"></span>' +
    '<span class="login-core"></span>' +
    '<span class="ring-login r1"></span>' +
    '<span class="ring-login r2"></span>' +
    '<span class="ring-login r3"></span>' +
    '<span class="kasai-btn-text">' + label + '</span>' +
    '<div class="kasai-btn-dots"><div class="kasai-dot"></div><div class="kasai-dot"></div><div class="kasai-dot"></div></div>' +
    '<div class="kasai-btn-check"><svg class="kasai-check-svg" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 12 9 17 20 7"></polyline></svg></div>';
};
document.querySelectorAll('#gate-login-btn,#gate-signup-btn,#gate-confirmed-email-btn,#gate-open-app-btn,#auth-gate .btn-primary').forEach(window.kasaiEarlyEnhanceButton);
document.addEventListener('click', function(e){
  var btn = e.target.closest && e.target.closest('#auth-gate [data-auth-mode]');
  if(!btn) return;
  e.preventDefault();
  window.kasaiSetAuthMode(btn.getAttribute('data-auth-mode'));
}, true);
window.__kasaiAuthMainReady = false;
document.addEventListener('click', async function(e){
  var btn = e.target.closest && e.target.closest('#gate-login-btn');
  if(!btn || window.__kasaiAuthMainReady) return;
  e.preventDefault();
  var emailEl = document.getElementById('gate-login-email');
  var passwordEl = document.getElementById('gate-login-password');
  var email = (emailEl && emailEl.value || '').trim();
  var password = passwordEl && passwordEl.value || '';
  if(!email || !password) return window.kasaiAuthStatus('Bitte E-Mail und Passwort eingeben.', 'error');
  window.kasaiAuthStatus('Login läuft...');
  window.kasaiSetButtonBusy(btn, true);
  try{
    var client = await window.kasaiEarlySupabaseClient();
    if(!client) throw new Error('Supabase ist nicht geladen. Bitte App neu öffnen.');
    var result = await window.kasaiAuthTimeout(
      client.auth.signInWithPassword({email:email, password:password}),
      'Supabase Login'
    );
    if(result.error) throw result.error;
    if(!result.data || !result.data.session) throw new Error('Login erfolgreich, aber keine Session erhalten.');
    window.kasaiAuthStatus('Login erfolgreich.', 'success');
    window.kasaiContinueAfterAuth(result.data.session, '');
    window.kasaiSetButtonBusy(btn, false);
  }catch(error){
    window.kasaiSetButtonBusy(btn, false);
    window.kasaiAuthStatus(error.message || 'Login fehlgeschlagen.', 'error');
  }
}, true);
document.addEventListener('click', async function(e){
  var btn = e.target.closest && e.target.closest('#gate-signup-btn');
  if(!btn || window.__kasaiAuthMainReady) return;
  e.preventDefault();
  var nameEl = document.getElementById('gate-signup-name');
  var emailEl = document.getElementById('gate-signup-email');
  var passwordEl = document.getElementById('gate-signup-password');
  var name = (nameEl && nameEl.value || '').trim();
  var email = (emailEl && emailEl.value || '').trim();
  var password = passwordEl && passwordEl.value || '';
  if(!email || password.length < 8) return window.kasaiAuthStatus('Bitte E-Mail und Passwort mit mindestens 8 Zeichen eingeben.', 'error');
  window.kasaiAuthStatus('Account wird erstellt...');
  window.kasaiSetButtonBusy(btn, true);
  try{
    var client = await window.kasaiEarlySupabaseClient();
    if(!client) throw new Error('Supabase ist nicht geladen. Bitte App neu öffnen.');
    var result = await window.kasaiAuthTimeout(
      client.auth.signUp({
        email:email,
        password:password,
        options:{
          emailRedirectTo: window.location.origin + window.location.pathname,
          data:{display_name:name || 'Champion'}
        }
      }),
      'Supabase Registrierung'
    );
    if(result.error) throw result.error;
    if(result.data && result.data.session){
      window.kasaiAuthStatus('Account erstellt.', 'success');
      window.kasaiContinueAfterAuth(result.data.session, '');
      window.kasaiSetButtonBusy(btn, false);
      return;
    }
    window.kasaiSetButtonBusy(btn, false);
    var chip = document.getElementById('pending-email-chip');
    if(chip) chip.textContent = email;
    window.kasaiAuthStatus('Account erstellt. Bitte bestätige deine E-Mail.', 'success');
    window.kasaiSetAuthMode('pending');
  }catch(error){
    window.kasaiSetButtonBusy(btn, false);
    window.kasaiAuthStatus(error.message || 'Registrierung fehlgeschlagen.', 'error');
  }
}, true);
</script>
