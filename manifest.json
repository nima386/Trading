function hydrateNotificationSettingsUI(){
  const n = normalizeNotificationSettings();
  const setChecked = (id, value)=>{ const el = document.getElementById(id); if(el) el.checked = !!value; };
  const setValue = (id, value)=>{ const el = document.getElementById(id); if(el) el.value = value; };
  setChecked('notify-training-enabled', n.training.enabled);
  setValue('notify-training-time', n.training.time);
  setChecked('notify-water-enabled', n.water.enabled);
  setValue('notify-water-interval', String(n.water.intervalMinutes));
  setChecked('notify-habit-enabled', n.habits.enabled);
  setValue('notify-habit-time', n.habits.time);
  setChecked('notify-plan-enabled', n.planStart.enabled);
