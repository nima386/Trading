let _i18nApplying = false;
let _i18nTimer = null;

function currentLanguage(){
  return S?.settings?.language === 'en' ? 'en' : 'de';
}

function translatePhrase(text, lang=currentLanguage()){
  if(!text) return text;
  const trimmed = text.trim();
  const lead = text.slice(0, text.indexOf(trimmed));
  const trail = text.slice(text.indexOf(trimmed) + trimmed.length);
  const dict = lang === 'en' ? KASAI_I18N : KASAI_I18N_REVERSE;
  let out = dict[trimmed] || trimmed;
  (KASAI_TERM_TRANSLATIONS[lang] || []).forEach(([from,to])=>{
    out = out.split(from).join(to);
  });
  return lead + out + trail;
}

function localizeStaticControls(lang=currentLanguage()){
  const navLabels = {
    training: lang === 'en' ? 'Training' : 'Training',
    run: lang === 'en' ? 'Run' : 'Laufen',
    nutrition: lang === 'en' ? 'Nutrition' : 'Ernährung',
    habits: lang === 'en' ? 'Habits' : 'Gewohnheiten',
    profile: lang === 'en' ? 'Profile' : 'Profil'
  };
  document.querySelectorAll('.nav-item').forEach(item=>{
    const label = item.querySelector('.nav-label');
    const key = item.dataset.screen || 'training';
    if(label && navLabels[key]) label.textContent = navLabels[key];
  });
  const runTypeLabels = {
    'Easy Run': {de:'Locker Lauf', en:'Easy Run'},
    'Tempo': {de:'Tempo', en:'Tempo'},
    'Long Run': {de:'Langer Lauf', en:'Long Run'},
    'Intervall': {de:'Intervall', en:'Interval'}
  };
  document.querySelectorAll('#run-input-type option').forEach(option=>{
    if(!option.value) option.value = option.textContent.trim();
    const label = runTypeLabels[option.value] || runTypeLabels[option.textContent.trim()];
    if(label) option.textContent = label[lang] || option.value;
  });
}

function applyI18n(root=document.body){
  if(_i18nApplying || !root) return;
  _i18nApplying = true;
  const lang = currentLanguage();
  document.documentElement.lang = lang;
  document.querySelectorAll('[data-lang-choice]').forEach(btn=>{
    btn.classList.toggle('active', btn.dataset.langChoice === lang);
  });
  const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
    acceptNode(node){
      const parent = node.parentElement;
      if(!parent || !node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
      if(parent.closest('script,style,textarea,select,svg,[data-no-i18n]')) return NodeFilter.FILTER_REJECT;
      if(parent.closest('input')) return NodeFilter.FILTER_REJECT;
      return NodeFilter.FILTER_ACCEPT;
    }
  });
  const nodes = [];
  while(walker.nextNode()) nodes.push(walker.currentNode);
  nodes.forEach(node=>{
    const next = translatePhrase(node.nodeValue, lang);
    if(next !== node.nodeValue) node.nodeValue = next;
  });
  document.querySelectorAll('[placeholder],[aria-label],title').forEach(el=>{
    ['placeholder','aria-label','title'].forEach(attr=>{
      const value = el.getAttribute(attr);
      if(value) el.setAttribute(attr, translatePhrase(value, lang));
    });
  });
  localizeStaticControls(lang);
  _i18nApplying = false;
}

function scheduleI18n(){
  if(_i18nTimer) cancelAnimationFrame(_i18nTimer);
  _i18nTimer = requestAnimationFrame(()=>applyI18n());
}

function setLanguage(lang, persist=true){
  const safe = lang === 'en' ? 'en' : 'de';
  if(!S.settings) S.settings = {};
  S.settings.language = safe;
  try{ localStorage.setItem('kasai.language', safe); }catch(_){}
  if(persist) saveState(S, 'settings');
  renderAll();
  scheduleI18n();
}

function dateKey(date){
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2,'0');
  const d = String(date.getDate()).padStart(2,'0');
  return `${y}-${m}-${d}`;
}

function parseDateKey(key){
  const d = new Date(key + 'T00:00:00');
  return Number.isNaN(d.getTime()) ? new Date(today.toDateString()) : d;
}

function startOfIsoWeek(value){
  const d = value instanceof Date ? new Date(value.toDateString()) : parseDateKey(value);
  const isoDow = d.getDay() || 7;
  d.setDate(d.getDate() - isoDow + 1);
  return d;
}

function inclusiveDaysUntil(dateStr, fromDate=today){
  if(!dateStr) return null;
  const end = parseDateKey(dateStr);
  const from = new Date(fromDate.toDateString());
  return Math.max(0, Math.ceil((end - from) / 86400000) + 1);
}

function formatShortDate(dateStr){
  if(!dateStr) return '';
  return parseDateKey(dateStr).toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric'});
}

function escapeHtml(value=''){
  return String(value).replace(/[&<>"']/g, ch => ({
    '&':'&amp;',
    '<':'&lt;',
    '>':'&gt;',
    '"':'&quot;',
    "'":'&#39;'
  })[ch]);
}

function cleanUiIcon(icon, fallback=''){
  const value = String(icon || '').trim();
  if(!value || value === '-' || value.charCodeAt(0) === 0x00ef || /[\uFFFD]/.test(value)) return fallback;
  return value;
}

function repairMojibakeText(value){
  const text = String(value ?? '');
  if(!/[ÃÂâðç]/.test(text)) return text;
  const cp1252 = {
    0x20AC:0x80,0x201A:0x82,0x0192:0x83,0x201E:0x84,0x2026:0x85,0x2020:0x86,0x2021:0x87,
    0x02C6:0x88,0x2030:0x89,0x0160:0x8A,0x2039:0x8B,0x0152:0x8C,0x017D:0x8E,
    0x2018:0x91,0x2019:0x92,0x201C:0x93,0x201D:0x94,0x2022:0x95,0x2013:0x96,0x2014:0x97,
    0x02DC:0x98,0x2122:0x99,0x0161:0x9A,0x203A:0x9B,0x0153:0x9C,0x017E:0x9E,0x0178:0x9F
  };
  const toBytes = input=>{
    const bytes = [];
    for(const ch of input){
      const code = ch.codePointAt(0);
      if(code < 0x80) bytes.push(code);
      else if(cp1252[code]) bytes.push(cp1252[code]);
      else if(code <= 0xFF) bytes.push(code);
      else bytes.push(...new TextEncoder().encode(ch));
    }
    return bytes;
  };
  try{
    let repaired = new TextDecoder('utf-8').decode(new Uint8Array(toBytes(text)));
    if(/[ÃÂâðç]/.test(repaired)){
      repaired = new TextDecoder('utf-8').decode(new Uint8Array(toBytes(repaired)));
    }
    return repaired;
  }catch(_){
    return text;
  }
}

let _encodingRepairing = false;
function repairVisibleEncoding(root=document.body){
  if(_encodingRepairing || !root) return;
  _encodingRepairing = true;
  try{
    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
    const nodes = [];
    while(walker.nextNode()) nodes.push(walker.currentNode);
    nodes.forEach(node=>{
      const fixed = repairMojibakeText(node.nodeValue);
      if(fixed !== node.nodeValue) node.nodeValue = fixed;
    });
    root.querySelectorAll?.('*').forEach(el=>{
      ['placeholder','aria-label','title','data-icon','data-val'].forEach(attr=>{
        if(!el.hasAttribute(attr)) return;
        const current = el.getAttribute(attr);
        const fixed = repairMojibakeText(current);
        if(fixed !== current) el.setAttribute(attr, fixed);
      });
      if(el.childElementCount === 0 && el.textContent) {
        const fixed = repairMojibakeText(el.textContent);
        if(fixed !== el.textContent) el.textContent = fixed;
      }
    });
  }finally{
    _encodingRepairing = false;
  }
}

function scheduleEncodingRepair(){
  requestAnimationFrame(()=>repairVisibleEncoding(document.body));
}

function getDayOfYear(date=today){
  const start = new Date(date.getFullYear(), 0, 0);
  return Math.floor((date - start) / 86400000);
}

function renderDailyQuote(date=today){
  const quotes = (window.FORGE_QUOTES_365 || []).slice(0, 365);
  const textEl = document.getElementById('daily-quote-text');
  const dayEl = document.getElementById('daily-quote-day');
  if(!quotes.length || !textEl || !dayEl) return;

  const index = (getDayOfYear(date) - 1 + quotes.length) % quotes.length;
  const quote = quotes[index];
  textEl.innerHTML = `<strong>${escapeHtml(quote.main)}</strong><br><em>${escapeHtml(quote.accent)}</em>`;
  dayEl.textContent = `tag ${index + 1} von ${quotes.length}`;
}

function getPlanWeekIds(){
  const editorWeeks = tpWeekList?.() || [];
  if(editorWeeks.length) return editorWeeks;
  const configured = S.planConfig?.weekIds?.filter(Boolean);
  return configured?.length ? configured : ['A'];
}

function getPlanTemplateForWeek(weekId){
  return PLAN['week' + weekId] || PLAN.weekA;
}

function inferPlanType(label='', fallback='custom'){
  const l = String(label).toLowerCase();
  if(l.includes('ruhe') || l.includes('pause')) return 'rest';
  if(l.includes('push')) return 'push';
  if(l.includes('pull')) return 'pull';
  if(l.includes('bein') || l.includes('leg') || l.includes('lower')) return 'legs';
  if(l.includes('ober') || l.includes('upper')) return 'upper';
  if(l.includes('cardio')) return 'cardio';
  return fallback;
}

function planFromTrainingPlanDay(day, jsDow){
  if(!day) return null;
  const activeMgs = (day.muscleGroups || []).filter(m=>!m.isArchived);
  const exerciseCount = activeMgs.reduce((sum, mg)=>sum + (mg.exercises || []).filter(ex=>!ex.isArchived).length, 0);
  const duration = day.isRest ? 0 : Math.max(40, Math.min(90, 35 + exerciseCount * 6 + activeMgs.length * 5));
  return {
    type: day.isRest ? 'rest' : inferPlanType(day.label, `custom-${jsDow}`),
    label: day.label || (day.isRest ? 'Ruhetag' : 'Trainingstag'),
    duration,
    muscles: activeMgs.map(m=>m.name)
  };
}

function getWeekForDate(date=today){
  const weekIds = getPlanWeekIds();
  const start = startOfIsoWeek(S.trainingPlan?.startDate || S.planConfig?.startDate || todayStr);
  const current = startOfIsoWeek(date);
  const diffWeeks = Math.max(0, Math.floor((current - start) / 604800000));
  return weekIds[diffWeeks % weekIds.length] || 'A';
}

function rollingInfoForDate(date=today){
  const tp = S.trainingPlan;
  if(tp?.weekMode !== 'rolling') return null;
  const rolling = ensureRollingPlan(true);
  const days = rolling?.days || [];
  if(!days.length) return null;
  const startKey = rolling.startDate || tp.startDate || S.planConfig?.startDate || todayStr;
  const endKey = rolling.endDate || tp.endDate || null;
  const start = parseDateKey(startKey);
  const current = new Date(date.toDateString());
  const diffDays = Math.floor((current - start) / 86400000);
  if(diffDays < 0) return null;
  if(endKey && current > parseDateKey(endKey)) return null;
  const index = diffDays % days.length;
  return {
    day: days[index],
    index,
    dayNumber: diffDays + 1,
    sequenceLength: days.length,
    startDate: startKey,
    endDate: endKey
  };
}

function getPlanForDate(date=today){
  const dow = date.getDay();
  const rolling = rollingInfoForDate(date);
  if(rolling){
    const editorPlan = planFromTrainingPlanDay(rolling.day, dow);
    if(editorPlan) return {
      plan: editorPlan,
      week: `Tag ${rolling.index + 1}`,
      dow,
      date,
      dateStr: dateKey(date),
      isRolling: true,
      rollingIndex: rolling.index,
      rollingDayNumber: rolling.dayNumber,
      sequenceLength: rolling.sequenceLength
    };
  }
  const week = getWeekForDate(date);
  const tpIndex = dow === 0 ? 6 : dow - 1;
  const editorPlan = planFromTrainingPlanDay(tpDay(week, tpIndex), dow);
  if(editorPlan) return {plan: editorPlan, week, dow, date, dateStr: dateKey(date)};
  const template = getPlanTemplateForWeek(week);
  return {plan: template[dow] || PLAN.weekA[dow], week, dow, date, dateStr: dateKey(date)};
}

function getTodayPlan(){
  return getPlanForDate(selectedDate);
}

function deletePlanWeek(weekId){
  const weekIds = getPlanWeekIds().filter(id=>id !== weekId);
  S.planConfig.weekIds = weekIds.length ? weekIds : ['A'];
  S.planConfig.singleWeekMode = S.planConfig.weekIds.length === 1;
  saveState(S);
}

function addPlanWeek(){
  const existing = getPlanWeekIds();
  const nextId = String.fromCharCode(65 + existing.length);
  S.planConfig.weekIds = [...existing, nextId];
  PLAN['week' + nextId] = JSON.parse(JSON.stringify(PLAN.weekA));
  S.planConfig.singleWeekMode = false;
  saveState(S);
  return nextId;
}

function getSelectedTrainingPlanDay(){
  const rolling = rollingInfoForDate(selectedDate);
  if(rolling) return rolling.day;
  const {week, dow} = getPlanForDate(selectedDate);
  const tpIndex = dow === 0 ? 6 : dow - 1;
  return tpDay(week, tpIndex);
}

function getTrainingPlanDayForDate(date=today){
  const rolling = rollingInfoForDate(date);
  if(rolling) return rolling.day;
  const {week, dow} = getPlanForDate(date);
  const tpIndex = dow === 0 ? 6 : dow - 1;
  return tpDay(week, tpIndex);
}

function getDailyExercisesForSelectedDay(){
  const day = getSelectedTrainingPlanDay();
  if(!day || day.isRest) return [];
  return ensureDailyExercisesForDay(day)
    .filter(ex=>!ex.isArchived)
    .sort((a,b)=>(a.sortOrder ?? 0) - (b.sortOrder ?? 0));
}

function findDailyExerciseForSelectedDay(exId){
  return getDailyExercisesForSelectedDay().find(ex=>ex.id === exId) || null;
}

function getDailyExerciseCount(exId, dayKey=selectedDateStr){
  ensureDailyState(dayKey);
  return Math.max(0, parseInt(S.dailyExerciseLogs?.[dayKey]?.[exId]) || 0);
}

function setDailyExerciseCount(exId, count, dayKey=selectedDateStr){
  ensureDailyState(dayKey);
  S.dailyExerciseLogs[dayKey][exId] = Math.max(0, parseInt(count) || 0);
}

function getTrainingPlanMusclesForSelectedDay(){
  const day = getSelectedTrainingPlanDay();
  if(!day || day.isRest) return [];
  return (day.muscleGroups || [])
    .filter(mg=>!mg.isArchived)
    .map((mg, index)=>({
      id: mg.id,
      name: mg.name,
      icon: mg.icon,
      color: mg.color,
      timeOfDay: normalizeTimeOfDay(mg.timeOfDay || 'morning', 'morning'),
      sortOrder: mg.sortOrder ?? index
    }));
}

function normalizePlanExercise(ex, mg){
  return {
    id: ex.id,
    name: ex.name || 'Übung',
    muscle: mg.name,
    eq: ex.equipment || ex.eq || 'Equipment',
    type: ex.type || 'Compound',
    sets: ex.targetSets || ex.sets || 3,
    rMin: ex.repsMin || ex.rMin || 8,
    rMax: ex.repsMax || ex.rMax || 12,
    rest: ex.restSeconds || ex.rest || 90,
    timeOfDay: ex.timeOfDay === 'inherit' ? normalizeTimeOfDay(mg.timeOfDay || 'morning') : normalizeTimeOfDay(ex.timeOfDay || mg.timeOfDay || 'morning'),
    notes: ex.notes || '',
    history: ex.history || [],
    pr: ex.pr || null,
    archived: !!ex.isArchived
  };
}

function getTrainingPlanExercisesForSelectedDay(){
  const day = getSelectedTrainingPlanDay();
  if(!day || day.isRest) return [];
  return (day.muscleGroups || [])
    .filter(mg=>!mg.isArchived)
    .flatMap(mg=>(mg.exercises || [])
      .filter(ex=>!ex.isArchived)
      .map(ex=>normalizePlanExercise(ex, mg)));
}

function getExercisesForType(type){
  const planExercises = getTrainingPlanExercisesForSelectedDay();
  if(planExercises.length || getSelectedTrainingPlanDay()) return planExercises;
  return ((S.exercises && S.exercises[type]) || []).filter(ex=>!ex.archived);
}
function getMusclesForType(type){
  const planMuscles = getTrainingPlanMusclesForSelectedDay();
  if(planMuscles.length || getSelectedTrainingPlanDay()) return planMuscles;
  return ((S.muscles && S.muscles[type]) || []).filter(m=>!m.archived);
}

function isDone(exerciseId){
  const sess = S.sessions[selectedDateStr]?.[exerciseId];
  if(!sess) return false;
  return Array.isArray(sess.sets) && sess.sets.length > 0 && sess.sets.every(set => set.done);
}

function ensureExerciseSession(ex, dateStr=selectedDateStr){
  ensureDailyState(dateStr);
  const setCount = Math.max(1, parseInt(ex?.sets) || 1);
  if(!S.sessions[dateStr][ex.id]){
    S.sessions[dateStr][ex.id] = {
      startedAt: new Date().toISOString(),
      incompleteFrom: null,
      exerciseSnapshot: {id:ex.id,name:ex.name,muscle:ex.muscle,type:ex.type,eq:ex.eq},
      sets: Array.from({length:setCount},()=>({
        weight: null,
        reps: null,
        done: false
      }))
    };
  }
  const sess = S.sessions[dateStr][ex.id];
  if(!Array.isArray(sess.sets)) sess.sets = [];
  while(sess.sets.length < setCount){
    sess.sets.push({weight:null,reps:null,done:false});
  }
  ensureSessionSnapshot(ex, dateStr);
  return sess;
}

function setExerciseDone(ex, done, dateStr=selectedDateStr){
  if(!ex?.id) return;
  const sess = ensureExerciseSession(ex, dateStr);
  const setCount = Math.max(1, parseInt(ex.sets) || sess.sets.length || 1);
  while(sess.sets.length < setCount){
    sess.sets.push({weight:null,reps:null,done:false});
  }
  sess.sets.forEach(set=>{ set.done = !!done; });
}

function toggleExerciseDone(ex){
  const done = isDone(ex.id);
  setExerciseDone(ex, !done);
  saveState(S);
  if(currentScreen === 'training') renderTraining();
}

function areAllExercisesDone(exs){
  const active = (exs || []).filter(ex=>!ex.archived);
  return active.length > 0 && active.every(ex=>isDone(ex.id));
}

function toggleMuscleExercisesDone(exs){
  const active = (exs || []).filter(ex=>!ex.archived);
  if(!active.length) return;
  const markDone = !areAllExercisesDone(active);
  active.forEach(ex=>setExerciseDone(ex, markDone));
  saveState(S);
  if(currentScreen === 'training') renderTraining();
}

function findExerciseById(exerciseId){
  for(const list of Object.values(S.exercises || {})){
    const found = list.find(ex=>ex.id === exerciseId);
    if(found) return found;
  }
  return S.archivedExercises?.[exerciseId] || null;
}

