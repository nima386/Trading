async function oauthLogin(provider){
  const client = await ensureForgeSupabaseClient();
  if(!client) return setAuthStatus('Supabase ist nicht geladen. Bitte Verbindung prüfen und App neu öffnen.', 'error');
  setAuthStatus(`Weiterleitung zu ${provider}...`);
  const {error} = await client.auth.signInWithOAuth({
    provider,
    options:{ redirectTo: window.location.origin + window.location.pathname }
  });
  if(error) setAuthStatus(`${provider} Login fehlgeschlagen: ${error.message}. Provider muss in Supabase aktiviert sein.`, 'error');
}
