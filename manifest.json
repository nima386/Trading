const SETTINGS_AUTOSAVE_FIELDS = [
  'set-name','set-weight','set-stepgoal','set-kcal','set-water','set-pmin','set-pmax',
  'notify-training-enabled','notify-training-time','notify-water-enabled','notify-water-interval',
  'notify-habit-enabled','notify-habit-time','notify-plan-enabled','notify-plan-time'
];
let _settingsAutosaveTimer = null;
function scheduleSettingsAutosave(delay=450){
  collectSettingsFormIntoState();
  updateAuthUI();
  setSyncStatus('waiting','// speichert...');
  if(_settingsAutosaveTimer) clearTimeout(_settingsAutosaveTimer);
  _settingsAutosaveTimer = setTimeout(async()=>{
    _settingsAutosaveTimer = null;
    if(!authSession?.user) await resumeSession('settings-autosave');
    saveState(S, 'settings');
    scheduleNotifications();
    renderAll();
  }, delay);
}

function flushSettingsAutosave(){
  if(!_settingsAutosaveTimer) return;
  clearTimeout(_settingsAutosaveTimer);
  _settingsAutosaveTimer = null;
  collectSettingsFormIntoState();
  saveState(S, 'settings');
  scheduleNotifications();
  renderAll();
}

SETTINGS_AUTOSAVE_FIELDS.forEach(id=>{
  const el = document.getElementById(id);
  if(!el) return;
  el.addEventListener('input',()=>scheduleSettingsAutosave(450));
  el.addEventListener('change',()=>{
    scheduleSettingsAutosave(150);
    updateNotificationRowsUI();
    if(el.type === 'checkbox') previewNotificationToggle(id);
  });
  el.addEventListener('blur',()=>scheduleSettingsAutosave(0));
});

