function defaultNotificationSettings(){
  return {
    permissionAsked: false,
    training: {enabled:true, mode:'auto'},
    water: {enabled:true, intervalMinutes:90, start:'09:00', end:'21:00'},
    habits: {enabled:true, time:'20:30'},
    planStart: {enabled:true, time:'07:45', mode:'auto'}
  };
}

function normalizeNotificationSettings(){
  if(!S.settings) S.settings = {};
  const defaults = defaultNotificationSettings();
  const current = S.settings.notifications || {};
  S.settings.notifications = {
    permissionAsked: !!current.permissionAsked,
    training: Object.assign({}, defaults.training, current.training || {}),
    water: Object.assign({}, defaults.water, current.water || {}),
    habits: Object.assign({}, defaults.habits, current.habits || {}),
    planStart: Object.assign({}, defaults.planStart, current.planStart || {})
  };
  return S.settings.notifications;
}

function applyNutritionRecords(rows=[]){
  rows.forEach(row=>{
    if(!row?.date) return;
    if(row.meals && Array.isArray(row.meals)) S.meals[row.date] = row.meals;
  });
}

function applyHabitRecords(rows=[]){
  if(!rows.length) return;
  S.userHabits = rows.map(row=>({
    id: row.client_id || row.id,
    name: row.name,
    icon: cleanUiIcon(row.icon, '+'),
    scope: row.scope || 'daily',
    activeDates: Array.isArray(row.active_dates) ? row.active_dates : [],
    streak: Number(row.streak || 0),
    reminder: {
      enabled: !!row.reminder_enabled,
      time: row.reminder_time || '20:30'
    }
  }));
  rows.forEach(row=>{
    const completions = Array.isArray(row.completions) ? row.completions : [];
    completions.forEach(date=>{
      if(!S.habits[date]) S.habits[date] = {};
      S.habits[date][row.client_id || row.id] = true;
    });
  });
}

function applyTrainingSessionRecords(rows=[]){
  rows.forEach(row=>{
    if(!row?.date) return;
    const exercises = row.exercises && typeof row.exercises === 'object' ? row.exercises : {};
    if(exercises.sessions && typeof exercises.sessions === 'object') S.sessions[row.date] = exercises.sessions;
    else S.sessions[row.date] = exercises;
    if(exercises.readiness != null) S.readiness[row.date] = exercises.readiness;
  });
}

function applyRunRecords(rows=[]){
  if(!Array.isArray(rows) || !rows.length) return;
  const localById = new Map((S.runs || []).map(run=>[String(run.id), run]));
  rows.forEach(row=>{
    if(!row?.id || !row?.date) return;
    localById.set(String(row.id), {
      id: String(row.id),
      date: row.date,
      km: Number(row.distance_km || 0),
      min: Number(row.duration_min || 0),
      type: row.run_type || 'Easy Run',
      pr: !!row.is_pr,
      pauses: Number(localById.get(String(row.id))?.pauses || 0) || 0,
      proofImages: normalizeRunProofImages(localById.get(String(row.id))?.proofImages || []),
      notes: row.notes || '',
      createdAt: row.created_at || new Date().toISOString()
    });
  });
  S.runs = Array.from(localById.values()).sort((a,b)=>String(b.date).localeCompare(String(a.date)) || String(b.createdAt||'').localeCompare(String(a.createdAt||'')));
}

function buildHabitRows(state, userId){
  const completionsByHabit = {};
  Object.entries(state.habits || {}).forEach(([date, habitsForDate])=>{
    Object.entries(habitsForDate || {}).forEach(([habitId, done])=>{
      if(!done) return;
      if(!completionsByHabit[habitId]) completionsByHabit[habitId] = [];
      completionsByHabit[habitId].push(date);
    });
  });
  return (state.userHabits || []).map(h=>({
    user_id: userId,
    client_id: String(h.id || `h-${Date.now()}`),
    name: h.name || 'Habit',
    icon: cleanUiIcon(h.icon, '+'),
    scope: h.scope || 'daily',
    active_dates: Array.isArray(h.activeDates) ? h.activeDates : [],
    streak: Number(h.streak || 0),
    reminder_enabled: !!h.reminder?.enabled,
    reminder_time: h.reminder?.time || null,
    completions: completionsByHabit[h.id] || [],
    updated_at: new Date().toISOString()
  }));
}

function buildNutritionRows(state, userId){
  return Object.entries(state.meals || {}).map(([date, meals])=>({
    user_id: userId,
    date,
    meals: Array.isArray(meals) ? meals : [],
    calories: Array.isArray(meals) ? meals.reduce((sum, meal)=>sum + (Number(meal.kcal || meal.calories || 0) || 0), 0) : 0,
    updated_at: new Date().toISOString()
  }));
}

function buildTrainingSessionRows(state, userId){
  return Object.entries(state.sessions || {}).map(([date, sessions])=>{
    const exerciseCount = Object.values(sessions || {}).reduce((count, sess)=>count + (sess?.sets?.length ? 1 : 0), 0);
    return {
      user_id: userId,
      date,
      exercises: {
        sessions: sessions || {},
        readiness: state.readiness?.[date] ?? null
      },
      duration_minutes: exerciseCount ? Math.max(20, exerciseCount * 8) : null,
      notes: null,
      updated_at: new Date().toISOString()
    };
  });
}

function buildRunRows(state, userId){
  return (state.runs || [])
    .filter(run=>run?.date && Number(run.km) > 0 && Number(run.min) > 0)
    .map(run=>({
      id: isUuid(run.id) ? run.id : undefined,
      user_id: userId,
      date: run.date,
      distance_km: Number(run.km),
      duration_min: Math.round(Number(run.min)),
      run_type: run.type || 'Easy Run',
      is_pr: !!run.pr,
      notes: run.notes || null
    }));
}

function isUuid(value){
  return /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(String(value || ''));
}

function genClientId(prefix='id'){
  return `${prefix}_${Date.now()}_${Math.random().toString(36).slice(2,9)}`;
}

function stateTime(state, fallback=null){
  return Date.parse(state?._sync?.updatedAt || state?.updatedAt || fallback || 0) || 0;
}

function sessionUserId(session=authSession){
  return session?.user?.id || null;
}

function beginHydration(session=authSession){
  const userId = sessionUserId(session);
  if(!userId) return;
  if(_activeHydratedUserId !== userId){
    _activeHydratedUserId = userId;
    _appHydrated = false;
  }
}

function markHydrated(session=authSession){
  const userId = sessionUserId(session);
  if(!userId) return;
  _activeHydratedUserId = userId;
  _appHydrated = true;
  renderSyncDebug();
}

function isHydratedForSession(session=authSession){
  const userId = sessionUserId(session);
  return !!(userId && _appHydrated && _activeHydratedUserId === userId);
}

function hasOwnKeys(value){
  return !!(value && typeof value === 'object' && Object.keys(value).length);
}

function hasMeaningfulUserState(state){
  if(!state || typeof state !== 'object') return false;
  const p = state.profile || {};
  if(String(p.name || p.username || p.avatarUrl || '').trim()) return true;
  if([p.weightKg,p.stepGoal,p.kcalGoal,p.waterGoal,p.proteinMin,p.proteinMax].some(v=>v != null && String(v) !== '')) return true;
  if(Object.values(state.hydration || {}).some(v=>Number(v) > 0)) return true;
  if(Object.values(state.steps || {}).some(v=>Number(v) > 0)) return true;
  if(Object.values(state.dailyExerciseLogs || {}).some(day=>hasOwnKeys(day) && Object.values(day).some(v=>Number(v) > 0))) return true;
  if(Object.values(state.habits || {}).some(day=>hasOwnKeys(day) && Object.values(day).some(Boolean))) return true;
  if(Object.values(state.sessions || {}).some(day=>hasOwnKeys(day))) return true;
  if(Object.values(state.meals || {}).some(day=>Array.isArray(day) && day.length > 0)) return true;
  if(Array.isArray(state.userHabits) && state.userHabits.length > 0) return true;
  if(Array.isArray(state.runs) && state.runs.length > 0) return true;
  if(hasOwnKeys(state.readiness)) return true;
  if(hasOwnKeys(state.muscles) || hasOwnKeys(state.exercises)) return true;
  const settings = state.settings || {};
  if(settings.theme && settings.theme !== 'dark') return true;
  if(settings.notificationsEnabled === false) return true;
  if(settings.language && settings.language !== 'de') return true;
  if(settings.notifications){
    try{
      if(JSON.stringify(settings.notifications) !== JSON.stringify(defaultNotificationSettings())) return true;
    }catch(_){}
  }
  const plan = state.trainingPlan;
  if(String(plan?.name || '').trim() || plan?.endDate || plan?.weekMode === 'AB') return true;
  if(plan?.weeks && Object.values(plan.weeks).some(week=>Object.values(week?.days || {}).some(day=>
    (day?.label && day.label !== 'Trainingstag') ||
    day?.isRest ||
    (Array.isArray(day?.dailyExercises) && day.dailyExercises.some(ex=>!ex?.isArchived)) ||
    (Array.isArray(day?.exercises) && day.exercises.length > 0) ||
    (Array.isArray(day?.muscleGroups) && day.muscleGroups.length > 0) ||
    (Array.isArray(day?.muscles) && day.muscles.length > 0)
  ))) return true;
  return false;
}

function renderLocalUserState(session=authSession){
  beginHydration(session);
  const localBackup = loadLocalUserState(session);
  if(!localBackup) return false;
  S = localBackup;
  normalizeState();
  updateAuthUI();
  renderAll();
  setSyncStatus('ok','// lokal geladen');
  markHydrated(session);
  return true;
}

async function loadUserData(userId, session=authSession){
  if(!forgeSupabase || !userId) return;
  beginHydration(session);
  const localRecord = loadLocalUserStateRecord(session);
  const localBackup = localRecord?.state || null;
  if(localBackup){
    S = localBackup;
    normalizeState();
    updateAuthUI();
    renderAll();
    setSyncStatus('ok','// lokal geladen');
  }

  const pendingLocalWrite = readPendingState();
  let appState = {data:null, error:null};
  try{
    appState = await withTimeout(
      safeSupabaseQuery('app state load', forgeSupabase.from('user_app_state').select('state,updated_at').eq('user_id', userId).maybeSingle()),
      5000,
      'app state load'
    );
  }catch(error){
    console.warn('App state load timed out or failed; keeping local state.', error);
    if(localBackup) setSyncStatus('offline','// offline gespeichert');
    if(localBackup) markHydrated(session);
    return;
  }

  if(appState.error){
    if(localBackup) setSyncStatus('offline','// offline gespeichert');
    if(localBackup) markHydrated(session);
    return;
  }

  const cloudState = appState.data?.state && typeof appState.data.state === 'object' ? appState.data.state : null;
  const cloudTime = stateTime(cloudState, appState.data?.updated_at);
  const localTime = Math.max(stateTime(localBackup), Date.parse(localRecord?.savedAt || 0) || 0);
  const pendingTime = stateTime(pendingLocalWrite?.state, pendingLocalWrite?.savedAt);
  const cloudHasUserData = hasMeaningfulUserState(cloudState);
  const localHasUserData = hasMeaningfulUserState(localBackup);
  const shouldKeepLocal = !!(localBackup && (
    !cloudState ||
    (localHasUserData && !cloudHasUserData) ||
    pendingLocalWrite?.state ||
    localTime > cloudTime ||
    pendingTime > cloudTime
  ));

  if(shouldKeepLocal){
    S = localBackup;
    normalizeState();
    saveLocalUserState(S, session);
    renderAll();
    markHydrated(session);
    if(hasMeaningfulUserState(S)) queueImmediateCloudSync(S);
    _pendingSignupProfile = null;
    return;
  }

  if(cloudState){
    S = cloudState;
  }else if(_pendingSignupProfile){
    S.profile = Object.assign({}, S.profile || {}, _pendingSignupProfile);
    S.updatedAt = new Date().toISOString();
  }
  normalizeState();
  saveLocalUserState(S, session);
  renderAll();
  markHydrated(session);
  if((_pendingSignupProfile || !cloudState) && hasMeaningfulUserState(S)) queueImmediateCloudSync(S);
  _pendingSignupProfile = null;
}

async function syncStructuredUserData(state, userId){
  if(!forgeSupabase || !userId) return;
  const p = state.profile || {};
  const now = new Date().toISOString();
  const operations = [
    safeSupabaseQuery('profile sync', forgeSupabase.from('profiles').upsert({
      id: userId,
      username: p.username || null,
      avatar_url: p.avatarUrl || null,
      display_name: p.name || 'Champion',
    weight_kg: p.weightKg ?? null,
    step_goal: p.stepGoal ?? null,
    kcal_goal: p.kcalGoal ?? null,
    water_goal: p.waterGoal ?? null,
    protein_min: p.proteinMin ?? null,
    protein_max: p.proteinMax ?? null,
      updated_at: now
    }, {onConflict:'id'})),
    safeSupabaseQuery('settings sync', forgeSupabase.from('user_settings').upsert({
      user_id: userId,
      theme: state.settings?.theme || 'dark',
      notifications_enabled: state.settings?.notificationsEnabled ?? true,
      preferences: {
        profile: p,
        planConfig: state.planConfig || {},
        trainingPlan: state.trainingPlan || null
      },
      updated_at: now
    }, {onConflict:'user_id'}))
  ];

  const nutritionRows = buildNutritionRows(state, userId);
  if(nutritionRows.length){
    operations.push(safeSupabaseQuery('nutrition sync', forgeSupabase.from('nutrition_logs').upsert(nutritionRows, {onConflict:'user_id,date'})));
  }
  const trainingRows = buildTrainingSessionRows(state, userId);
  if(trainingRows.length){
    operations.push(safeSupabaseQuery('training sessions sync', forgeSupabase.from('training_sessions').upsert(trainingRows, {onConflict:'user_id,date'})));
  }
  const habitRows = buildHabitRows(state, userId);
  if(habitRows.length){
    operations.push(safeSupabaseQuery('habits sync', forgeSupabase.from('habits').upsert(habitRows, {onConflict:'user_id,client_id'})));
  }
  const runRows = buildRunRows(state, userId);
  if(runRows.length){
    operations.push(safeSupabaseQuery('runs sync', forgeSupabase.from('runs').upsert(runRows, {onConflict:'id'})));
  }
  const results = await Promise.all(operations);
  throwIfSyncFailed(results);
}

async function loadRemoteProfile(session){
  if(!forgeSupabase || !session?.user) return;
  try{
    const {data, error} = await forgeSupabase
      .from('profiles')
      .select('display_name,weight_kg,step_goal,kcal_goal,water_goal,protein_min,protein_max')
      .eq('id', session.user.id)
      .maybeSingle();
    if(error){
      console.warn('Profile load failed', error);
      return;
    }
    if(!data) return;
    S.profile = Object.assign({}, S.profile || {}, {
      name: data.display_name || S.profile?.name || '',
      weightKg: data.weight_kg != null ? Number(data.weight_kg) : null,
      stepGoal: data.step_goal != null ? Number(data.step_goal) : null,
      kcalGoal: data.kcal_goal != null ? Number(data.kcal_goal) : null,
      waterGoal: data.water_goal != null ? Number(data.water_goal) : null,
      proteinMin: data.protein_min != null ? Number(data.protein_min) : null,
      proteinMax: data.protein_max != null ? Number(data.protein_max) : null
    });
  } catch(error) {
    console.warn('Profile load failed', error);
  }
}

function parseNumberInput(value){
  if(value === '' || value == null) return null;
  const n = parseFloat(String(value).replace(',','.'));
  return Number.isFinite(n) ? n : null;
}

function parseIntegerInput(value){
  if(value === '' || value == null) return null;
  const n = parseInt(value, 10);
  return Number.isFinite(n) ? n : null;
}

async function syncWorkoutExercise(ex, dateStr=selectedDateStr){
  if(!forgeSupabase || !authSession?.user || !ex) return;
  const userId = authSession.user.id;
  const rows = buildTrainingSessionRows(S, userId).filter(row=>row.date === dateStr);
  if(!rows.length) return;
  const {error} = await forgeSupabase
    .from('training_sessions')
    .upsert(rows, {onConflict:'user_id,date'});
  if(error) console.warn('Training session sync failed', error);
}

function normalizeState(){
  S.profile = Object.assign({
    name:'',
    weightKg: null,
    stepGoal: null,
    kcalGoal: null,
    waterGoal: null,
    proteinMin: null,
    proteinMax: null
  }, S.profile || {});
  if(!S.hydration) S.hydration = {};
  if(!S.steps) S.steps = {};
  if(!S.dailyExerciseLogs) S.dailyExerciseLogs = {};
  if(!S.habits) S.habits = {};
  if(!S.sessions) S.sessions = {};
  if(!S.readiness) S.readiness = {};
  if(!S.meals) S.meals = {};
  if(!S.runs) S.runs = [];
  S.runs = (S.runs || []).map(run=>({
    id: run.id || genClientId('run'),
    date: run.date || todayStr,
    km: Number(run.km ?? run.distance_km ?? 0) || 0,
    min: Number(run.min ?? run.duration_min ?? 0) || 0,
    type: run.type || run.run_type || 'Easy Run',
    pr: !!(run.pr ?? run.is_pr),
    pauses: Math.max(0, parseInt(run.pauses ?? run.pauseCount ?? 0) || 0),
    proofImages: normalizeRunProofImages(run.proofImages || run.proofs || run.images || []),
    notes: run.notes || '',
    createdAt: run.createdAt || run.created_at || new Date().toISOString()
  })).filter(run=>run.date && run.km > 0 && run.min > 0);
  if(!S.runTracker) S.runTracker = {};
  S.runTracker = Object.assign({chartMode:'km', monthOffset:0, formOpen:false}, S.runTracker || {});
  if(!S.userHabits) S.userHabits = [];
  S.userHabits = S.userHabits.map(h=>Object.assign({scope:'daily', activeDates:[], reminder:{enabled:false,time:'20:30'}}, h, {
    reminder: Object.assign({enabled:false,time:'20:30'}, h.reminder || {})
  }));
  if(!S.settings) S.settings = {};
  S.settings = Object.assign({theme:'dark', notificationsEnabled:true, language:_storedLanguage || 'de'}, S.settings || {});
  if(S.settings.language !== 'en') S.settings.language = 'de';
  try{ localStorage.setItem('kasai.language', S.settings.language); }catch(_){}
  normalizeNotificationSettings();
  if(!S.muscles) S.muscles = {};
  if(!S.exercises) S.exercises = {};
  if(!S.acceptedProgressions) S.acceptedProgressions = {};
  if(!S.archivedExercises) S.archivedExercises = {};
  if(!S.archivedMuscleGroups) S.archivedMuscleGroups = {};
  if(!S.exerciseRenameHistory) S.exerciseRenameHistory = {};
  if(!S.exerciseMuscleHistory) S.exerciseMuscleHistory = {};
  if(!S.planConfig) S.planConfig = {};
  S.planConfig = Object.assign({
    startDate: todayStr,
    weekIds: ['A','B'],
    singleWeekMode: false,
    expired: false
  }, S.planConfig || {});
  if(S.streak == null) S.streak = 0;
  if(S.freeze == null) S.freeze = 2;
  if(S.hydration[todayStr] == null) S.hydration[todayStr] = 0;
  if(S.steps[todayStr] == null) S.steps[todayStr] = 0;
  if(!S.dailyExerciseLogs[todayStr]) S.dailyExerciseLogs[todayStr] = {};
  if(!S.habits[todayStr]) S.habits[todayStr] = {};
  if(!S.sessions[todayStr]) S.sessions[todayStr] = {};
  if(!S.meals[todayStr]) S.meals[todayStr] = [];
  // Training Plan Editor state
  if(!S.trainingPlan) S.trainingPlan = initEmptyTrainingPlan(todayStr);
  syncTrainingPlanFromPlanConfig();
  ensureTrainingPlanWeeks();
  syncPlanConfigFromTrainingPlan();
}

async function loadRemoteAppState(session){
  if(!forgeSupabase || !session?.user) return;
  const localRecord = loadLocalUserStateRecord(session);
  const localBackup = localRecord?.state || null;
  let shouldPushLocalBackup = false;
  try{
    const {data, error} = await forgeSupabase
      .from('user_app_state')
      .select('state,updated_at')
      .eq('user_id', session.user.id)
      .maybeSingle();
    if(error){
      console.warn('App state load failed', error);
      if(localBackup) S = localBackup;
      else await loadRemoteProfile(session);
      normalizeState();
      return;
    }
    if(data?.state && typeof data.state === 'object'){
      const cloudTime = Date.parse(data.updated_at || data.state.updatedAt || 0) || 0;
      const localTime = Date.parse(localRecord?.savedAt || localBackup?.updatedAt || 0) || 0;
      shouldPushLocalBackup = !!(localBackup && readPendingState()?.state && localTime > cloudTime);
      S = shouldPushLocalBackup ? localBackup : data.state;
      saveLocalUserState(S, session);
    }
    else if(localBackup){
      S = localBackup;
      shouldPushLocalBackup = true;
    }
    else await loadRemoteProfile(session);
  } catch(error) {
    console.warn('App state load failed', error);
    if(localBackup) S = localBackup;
  }
  normalizeState();
  if(shouldPushLocalBackup) queueImmediateCloudSync(S);
}

async function syncAppState(state=S, area=guessSyncArea()){
  const session = authSession?.user ? authSession : await ensureActiveSession('sync-app-state');
  if(!forgeSupabase || !session?.user) throw new Error('Keine aktive Supabase-Session');
  if(!isHydratedForSession(session)) throw new Error('App-Daten werden noch geladen');
  if(!hasMeaningfulUserState(state)){
    console.warn('Skipped empty app state cloud write.');
    return;
  }
  const userId = session.user.id;
  const payload = JSON.parse(JSON.stringify(state));
  const now = new Date().toISOString();
  payload.updatedAt = now;
  payload._sync = Object.assign({}, payload._sync || {}, {
    updatedByDevice: getDeviceId(),
    revision: _stateSyncRevision,
    updatedAt: now
  });
  const {error} = await withTimeout(
    forgeSupabase.from('user_app_state').upsert({
      user_id: userId,
      state: payload,
      updated_at: now
    }, {onConflict:'user_id'}),
    5000,
    'user_app_state sync'
  );
  if(error){
    console.warn('App state sync failed. Run supabase-schema.sql if this table or its grants are missing.', error);
    throw error;
  }
  _lastSuccessfulSyncAt = new Date().toISOString();
  _lastSyncArea = area || 'app';
  saveLocalUserState(payload, session);
  renderSyncDebug();
}

function isMissingAppStateTable(error){
  const msg = String(error?.message || error?.details || error || '').toLowerCase();
  return msg.includes('user_app_state') && (
    msg.includes('schema cache') ||
    msg.includes('could not find') ||
    msg.includes('does not exist') ||
    error?.code === 'PGRST205' ||
    error?.code === '42P01'
  );
}

function isSupabasePermissionError(error){
  const msg = String(error?.message || error?.details || error?.hint || error || '').toLowerCase();
  return error?.code === '42501' ||
    msg.includes('permission denied') ||
    msg.includes('grant the required privileges') ||
    msg.includes('insufficient privilege');
}
