// RENDER: EXERCISE DETAIL
// ---------------------------------------------------
function renderExercise(ex){
  currentExercise = ex;
  if(!ex) return;

  const todayPlan = getTodayPlan().plan;
  const todayExs = getExercisesForType(todayPlan.type);
  const muscleExs = todayExs.filter(e=>e.muscle===ex.muscle);
  const exIdx = Math.max(0, muscleExs.findIndex(e=>e.id===ex.id));
  const renames = S.exerciseRenameHistory?.[ex.id] || [];
  const renameNote = renames.length ? ` · umbenannt von: ${renames[renames.length-1].from}` : '';
  document.getElementById('ex-kicker').textContent = `// ${ex.muscle.toLowerCase()} · übung ${String(exIdx+1).padStart(2,'0')} von ${String(Math.max(muscleExs.length,1)).padStart(2,'0')}${renameNote}`;
  document.getElementById('ex-title').textContent = ex.archived ? 'Gelöschte Übung' : ex.name;
  document.getElementById('ex-tags').innerHTML = `
    <span class="tag tag-pink">${ex.eq}</span>
    <span class="tag tag-purple">${ex.type}</span>
    <span class="tag tag-amber">${ex.sets} × ${ex.rMin}-${ex.rMax}</span>`;

  const pr = ex.pr;
  document.getElementById('pr-text').textContent = pr ? `${pr.date} · ${pr.r} Wdh.` : '-';
  document.getElementById('pr-value').innerHTML = pr ? `${pr.w}<span style="font-size:.65rem;color:var(--text-muted)">kg</span>` : '-';
  document.getElementById('pr-card').style.display = (ex.type==='Cardio')?'none':'flex';

  renderHistoryChart(ex);
  renderSetRows(ex);
  renderProgressionHint(ex);
}

function renderHistoryChart(ex){
  const chart = document.getElementById('history-chart');
  chart.innerHTML = '';
  const sessionHist = Object.keys(S.sessions || {})
    .filter(d=>S.sessions[d]?.[ex.id]?.sets?.some(set=>set.done))
    .sort()
    .map(d=>{
      const completed = getCompletedSetsForSession(ex.id, d);
      const best = completed
        .map(set=>({w:parseNumberInput(set.weight) || 0, r:parseIntegerInput(set.reps) || 0}))
        .sort((a,b)=>epley(b.w,b.r)-epley(a.w,a.r))[0];
      return best ? {d:d.slice(5).replace('-','.'), w:best.w, r:best.r, source:'session'} : null;
    })
    .filter(Boolean);
  const hist = sessionHist.length ? sessionHist : (ex.history || []);
  document.getElementById('chart-sub').textContent = `letzte ${hist.length} sessions`;

  if(!hist.length || ex.type==='Cardio'){ chart.innerHTML='<div style="color:var(--text-muted);font-size:.78rem;">Noch keine Daten.</div>'; return; }

  const maxW = Math.max(...hist.map(h=>h.w));
  const minW = Math.min(...hist.map(h=>h.w)) * 0.85;
  const isPeak = i => hist[i].w === maxW;

  hist.forEach((h,i)=>{
    const pct = maxW>0 ? 20 + ((h.w-minW)/(maxW-minW||1))*75 : 20;
    const bar = document.createElement('div');
    bar.className = 'bar' + (isPeak(i)?' peak':'');
    bar.style.height = pct+'%';
    bar.innerHTML = `<span class="bar-val">${h.w}</span><span class="bar-lbl">${h.d}</span>`;
    chart.appendChild(bar);
  });
}

function getCompletedSetsForSession(exerciseId, dateStr){
  const sets = S.sessions?.[dateStr]?.[exerciseId]?.sets || [];
  return sets.filter(set=>set.done && parseIntegerInput(set.reps) != null);
}

function findLastLoggedSession(exerciseId, beforeDateStr=selectedDateStr){
  const dates = Object.keys(S.sessions || {})
    .filter(d=>d < beforeDateStr && S.sessions[d]?.[exerciseId]?.sets?.length)
    .sort()
    .reverse();
  for(const d of dates){
    const completed = getCompletedSetsForSession(exerciseId, d);
    if(completed.length){
      return {dateStr:d, sets:S.sessions[d][exerciseId].sets, completed};
    }
  }
  return null;
}

function getLastKnownWeight(ex){
  const logged = findLastLoggedSession(ex.id);
  const completed = logged?.completed || [];
  const lastLoggedWeight = [...completed].reverse().map(set=>parseNumberInput(set.weight)).find(v=>v != null);
  if(lastLoggedWeight != null) return {weight:lastLoggedWeight, dateStr:logged.dateStr, source:'session'};
  const hist = ex.history || [];
  const lastHistory = hist[hist.length - 1];
  if(lastHistory) return {weight:lastHistory.w, dateStr:lastHistory.d, source:'history'};
  return {weight:'', dateStr:null, source:'none'};
}

function ensureSessionSnapshot(ex, dateStr=selectedDateStr){
  const sess = S.sessions?.[dateStr]?.[ex.id];
  if(!sess) return;
  sess.exerciseSnapshot = Object.assign({
    id: ex.id,
    name: ex.name,
    muscle: ex.muscle,
    type: ex.type,
    eq: ex.eq
  }, sess.exerciseSnapshot || {});
}

function renderSetRows(ex){
  const container = document.getElementById('set-rows');
  container.innerHTML = '';
  const lastKnown = getLastKnownWeight(ex);
  const lastW = lastKnown.weight ?? '';
  const lastHint = document.getElementById('last-session-hint');
  if(lastKnown.source === 'session') lastHint.textContent = `letzte Session: ${lastKnown.dateStr} · ${lastW} kg`;
  else if(lastKnown.source === 'history') lastHint.textContent = `letzter Eintrag: ${lastKnown.dateStr} · ${lastW} kg`;
  else lastHint.textContent = 'Erster Eintrag heute!';

  ensureDailyState(selectedDateStr);
  if(!S.sessions[selectedDateStr][ex.id]){
    S.sessions[selectedDateStr][ex.id] = {
      startedAt: new Date().toISOString(),
      incompleteFrom: null,
      exerciseSnapshot: {id:ex.id,name:ex.name,muscle:ex.muscle,type:ex.type,eq:ex.eq},
      sets: Array.from({length:ex.sets},(_,i)=>({
        weight: i===0 ? lastW : null,
        reps:   '',
        done:   false
      }))
    };
    saveState(S);
  }

  const sess = S.sessions[selectedDateStr][ex.id];
  ensureSessionSnapshot(ex);

  sess.sets.forEach((set,i)=>{
    const row = document.createElement('div');
    row.className = 'set-row';
    row.innerHTML = `
      <div class="set-num">${i+1}</div>
      <input class="set-input" type="number" inputmode="decimal" placeholder="${lastW !== '' && lastW != null ? lastW : '-'}" value="${set.weight ?? ''}" data-set="${i}" data-field="weight">
      <input class="set-input" type="number" inputmode="numeric" placeholder="-" value="${set.reps ?? ''}" data-set="${i}" data-field="reps">
      <div class="set-check ${set.done?'done':''}" data-set="${i}">${set.done?'-':''}</div>`;
    container.appendChild(row);
  });

  // EIN Listener für Inputs
  container.querySelectorAll('.set-input').forEach(inp=>{
    inp.addEventListener('change', e=>{
      const i = +e.target.dataset.set;
      const f = e.target.dataset.field;
      S.sessions[selectedDateStr][ex.id].sets[i][f] = e.target.value === '' ? null : e.target.value;
      ensureSessionSnapshot(ex);
      saveState(S);
      syncWorkoutExercise(ex);
    });
  });

  // EIN Listener für Set-Checks (toggle + save + rest-timer + PR + konfetti)
  container.querySelectorAll('.set-check').forEach(btn=>{
    btn.addEventListener('click', e=>{
      const i       = +e.currentTarget.dataset.set;
      const setData = S.sessions[selectedDateStr][ex.id].sets[i];
      const wasDone = setData.done;
      if(!wasDone && ex.eq !== 'Körpergewicht' && parseNumberInput(setData.weight) == null){
        setData.weight = null;
        alert('Gewicht eingeben, auch wenn es 0 ist.');
        saveState(S);
        return;
      }
      setData.done  = !wasDone;

      e.currentTarget.classList.toggle('done', setData.done);
      e.currentTarget.textContent = setData.done ? '-' : '';

      if(setData.done && !wasDone){
        // Rest-Timer starten
        startRest(smartRest(ex.rMin, ex.rMax) || ex.rest || 90);
        if(navigator.vibrate) navigator.vibrate(40);

        // PR-Check (Epley 1RM)
        const w = parseFloat(String(setData.weight).replace(',','.'));
        const r = parseInt(setData.reps);
        if(checkPR(ex, w, r)){
          if(!S.prs) S.prs = {};
          S.prs[ex.id] = ex.pr;
          setData.is_pr = true;
          fireKonfetti();
          document.getElementById('pr-text').textContent  = `${ex.pr.date} · ${ex.pr.r} Wdh.`;
          document.getElementById('pr-value').innerHTML   = `${ex.pr.w}<span style="font-size:.65rem;color:var(--text-muted)">kg</span>`;
        }
      }
      saveState(S);
      syncWorkoutExercise(ex);
    });
  });
}

function renderProgressionHint(ex){
  const hint = document.getElementById('progression-hint');
  const text = document.getElementById('progression-text');
  if(ex.type==='Cardio'||ex.type==='Isolation'||!ex.pr){ hint.style.display='none'; return; }
  hint.style.display='flex';
  text.innerHTML = `Nächste Session: <span style="color:var(--purple-300)">+2,5 kg</span> vorgeschlagen`;
}

// ---------------------------------------------------
// RENDER: NUTRITION
// ---------------------------------------------------
function renderNutrition(){
  ensureDailyState(selectedDateStr);
  const dateStr = getActiveDateLabel(selectedDate);
  document.getElementById('nutr-kicker').textContent = `// ${dateStr}`;

  const meals = S.meals[selectedDateStr] || [];
  const eaten = meals.filter(m=>!m.planned);
  const totalKcal    = eaten.reduce((a,m)=>a+(m.kcal||0),0);
  const totalProtein = eaten.reduce((a,m)=>a+(m.protein||0),0);
  const totalCarbs   = eaten.reduce((a,m)=>a+(m.carbs||0),0);
  const totalFat     = eaten.reduce((a,m)=>a+(m.fat||0),0);

  const configuredKcal = parseIntegerInput(S.profile.kcalGoal);
  const goalKcal = configuredKcal || 2500;
  const pct = Math.min(totalKcal/goalKcal, 1);
  const circumference = 289;
  const offset = circumference - pct * circumference;

  document.getElementById('kcal-val').textContent  = totalKcal.toLocaleString('de');
  document.getElementById('kcal-goal').textContent = configuredKcal ? `/ ${goalKcal.toLocaleString('de')} KCAL` : '/ ZIEL OFFEN';
  document.getElementById('kcal-ring').style.strokeDashoffset = offset;

  // Makro-Goals: aus Profile/Standard ableiten (Protein - von Tracker, Carbs/Fat klassisch)
  const weightKg = parseNumberInput(S.profile.weightKg);
  const proteinMin = parseNumberInput(S.profile.proteinMin);
  const proteinMax = parseNumberInput(S.profile.proteinMax);
  const proteinGoalMid = weightKg && proteinMin && proteinMax
    ? Math.round(weightKg * ((proteinMin + proteinMax) / 2))
    : 0;
  const carbGoal = Math.round((goalKcal*0.50)/4);
  const fatGoal  = Math.round((goalKcal*0.28)/9);

  const macros = [
    {name:'Protein',     val:Math.round(totalProtein), goal:proteinGoalMid, color:'var(--purple-400)'},
    {name:'Kohlenhydrate',val:Math.round(totalCarbs),  goal:carbGoal,       color:'var(--pink)'},
    {name:'Fett',        val:Math.round(totalFat),     goal:fatGoal,        color:'var(--amber)'},
  ];
  const macroList = document.getElementById('macro-list');
  macroList.innerHTML = macros.map(m=>`
    <div class="macro-row">
      <div class="macro-dot" style="background:${m.color}"></div>
      <div style="flex:1">
        <div class="macro-name">${m.name}</div>
        <div class="macro-val">${m.val}g / ${m.goal || '-'}g</div>
        <div class="macro-bar-wrap"><div class="macro-bar" style="width:${m.goal ? Math.min(m.val/m.goal*100,100).toFixed(0) : 0}%;background:${m.color}"></div></div>
      </div>
    </div>`).join('');

  const mealsList = document.getElementById('meals-list');
  if(!meals.length){
    mealsList.innerHTML = '<div class="empty-hint">Noch keine Mahlzeiten - tippe auf <strong>+ Neu</strong></div>';
  } else
  mealsList.innerHTML = meals.map(m=>`
    <div class="meal-card" data-meal-id="${m.id}" style="${m.planned?'opacity:.5;border-style:dashed;':''}">
      <div class="meal-icon" style="background:${m.bg||'rgba(110,99,242,0.15)'}">${m.icon||'🍽️'}</div>
      <div style="flex:1;min-width:0">
        <div class="meal-name">${m.name}</div>
        <div class="meal-meta">${m.time||''}${m.items?' · '+m.items:''}</div>
      </div>
      <div class="meal-cal" style="${m.planned?'color:var(--text-muted)':''}">${m.kcal||0}</div>
    </div>`).join('');
  mealsList.querySelectorAll('.meal-card').forEach(card=>{
    card.onclick = ()=>openMealEdit(card.dataset.mealId);
  });

  renderHydration();
  renderProtein();
}

function renderHydration(){
  const ml   = S.hydration[selectedDateStr] || 0;
  const configuredGoal = parseIntegerInput(S.profile.waterGoal);
  const goal = configuredGoal || 3000;
  const L    = (ml/1000).toFixed(1).replace('.',',');
  const goalL= (goal/1000).toFixed(1).replace('.',',').replace(/,0$/,'');
  document.getElementById('hydration-val').innerHTML = `${L}<span style="font-size:.75rem;color:var(--text-muted)">L / ${configuredGoal ? goalL + 'L' : 'Ziel offen'}</span>`;
  document.getElementById('water-bar').style.width = Math.min(ml/goal*100,100)+'%';
}

KDOM.setClick('hydration-btn', ()=>{
  ensureDailyState(selectedDateStr);
  S.hydration[selectedDateStr] = (S.hydration[selectedDateStr]||0) + 250;
  saveState(S);
  renderHydration();
});

// ---------------------------------------------------
// RENDER: HABITS
// ---------------------------------------------------
function getActiveHabits(dayKey=selectedDateStr){
  return (S.userHabits || []).filter(h=>{
    if((h.scope || 'daily') === 'today') return (h.activeDates || []).includes(dayKey);
    return true;
  });
}

function removeHabitFromAllDays(habitId){
  Object.keys(S.habits || {}).forEach(dayKey=>{
    delete S.habits[dayKey][habitId];
  });
}

function renderHabits(){
  ensureDailyState(selectedDateStr);
  const dateStr = getActiveDateLabel(selectedDate);
  document.getElementById('habit-kicker').textContent = `// ${dateStr}`;
  document.getElementById('streak-num').textContent = S.streak;
  document.getElementById('freeze-val').textContent = `${S.freeze}`;

  const activeHabits = getActiveHabits(selectedDateStr);
  const done = activeHabits.filter(h=>S.habits[selectedDateStr][h.id]).length;
  const total = activeHabits.length;
  const pct = total ? Math.round(done/total*100) : 0;
  document.getElementById('habits-done-label').textContent = `${done} von ${total} erledigt`;
  document.getElementById('habits-pct').textContent = `${pct}%`;
  document.getElementById('habits-bar').style.width = pct+'%';

  const list = document.getElementById('habits-list');
  list.innerHTML = '';
  if(!activeHabits.length){
    list.innerHTML = '<div class="empty-hint">Noch keine Gewohnheiten - tippe auf <strong>+ Neu</strong>, um deine erste anzulegen</div>';
  }
  activeHabits.forEach(h=>{
    const isDone = !!S.habits[selectedDateStr][h.id];
    const streak = isDone ? (h.streak||0)+1 : (h.streak||0);

    // Swipe-Wrapper mit Lösch-Hintergrund
    const row = document.createElement('div');
    row.className = 'habit-row';
    row.innerHTML = `
      <div class="habit-del-bg"><button data-del="${h.id}">LOESCHEN</button></div>
      <div class="habit-card">
        <div class="habit-check ${isDone?'done':''}">${isDone?'OK':''}</div>
        <div style="flex:1">
          <div class="habit-name ${isDone?'done':''}">${cleanUiIcon(h.icon, '+')} ${h.name}</div>
          <div class="habit-streak">${streak>0?'SERIE '+streak+' TAGE':'streak: 0'}</div>
        </div>`;
    const card = row.querySelector('.habit-card');

    // Tap toggle (nur wenn nicht geswiped)
    card.addEventListener('click',e=>{
      if(card.classList.contains('swiped')){ card.classList.remove('swiped'); return; }
      S.habits[selectedDateStr][h.id] = !S.habits[selectedDateStr][h.id];
      saveState(S);
      renderHabits();
    });

    // Swipe-Logik
    let sx=0, sy=0, dx=0, dragging=false;
    card.addEventListener('touchstart',e=>{
      sx = e.touches[0].clientX; sy = e.touches[0].clientY; dx=0; dragging=true;
      card.style.transition='none';
    },{passive:true});
    card.addEventListener('touchmove',e=>{
      if(!dragging) return;
      dx = e.touches[0].clientX - sx;
      const dy = Math.abs(e.touches[0].clientY - sy);
      if(dy > Math.abs(dx)){ dragging=false; card.style.transform=''; return; }
      if(dx < 0) card.style.transform = `translateX(${Math.max(dx,-100)}px)`;
      else if(card.classList.contains('swiped')) card.style.transform = `translateX(${Math.min(-86+dx,0)}px)`;
    },{passive:true});
    card.addEventListener('touchend',()=>{
      dragging=false;
      card.style.transition='transform .25s var(--ease)';
      if(dx < -50){ card.classList.add('swiped'); card.style.transform=''; }
      else { card.classList.remove('swiped'); card.style.transform=''; }
    });

    // Long-press - edit (nur ohne Swipe)
    let pressT;
    card.addEventListener('touchstart',()=>{ pressT = setTimeout(()=>{ if(Math.abs(dx)<8) openHabitEdit(h.id); }, 600); }, {passive:true});
    card.addEventListener('touchend',()=>clearTimeout(pressT));
    card.addEventListener('touchmove',()=>clearTimeout(pressT));
    card.addEventListener('contextmenu',e=>{ e.preventDefault(); openHabitEdit(h.id); });

    // Delete-Button im Hintergrund
    row.querySelector('[data-del]').addEventListener('click',ev=>{
      ev.stopPropagation();
      S.userHabits = S.userHabits.filter(x=>x.id!==h.id);
      removeHabitFromAllDays(h.id);
      saveState(S);
      renderHabits();
    });

    list.appendChild(row);
  });
  renderSteps();
}

