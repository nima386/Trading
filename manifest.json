const NAV_D_COLORS = ['#ffca28','#ff9500','#ff6b00','#ff3d00','#ff2d55'];

function navScreenForItem(item){
  return item.dataset.screen || 'training';
}

function ensureNeonSlashNavs(){
  document.querySelectorAll('.bottom-nav').forEach(nav=>{
    if(!nav.querySelector('.kasai-nav-particles')){
      const particles = document.createElement('div');
      particles.className = 'kasai-nav-particles';
      nav.prepend(particles);
    }
    if(!nav.querySelector('.kasai-nav-slider')){
      const slider = document.createElement('div');
      slider.className = 'kasai-nav-slider';
      nav.prepend(slider);
    }
    nav.querySelectorAll('.nav-item').forEach(item=>{
      const icon = item.querySelector('.nav-icon');
      const key = navScreenForItem(item);
      if(icon && NAV_D_ICONS[key] && icon.dataset.variantD !== '1'){
        icon.innerHTML = NAV_D_ICONS[key];
        icon.dataset.variantD = '1';
      }
    });
  });
}

function burstNeonNav(nav, item){
  const field = nav.querySelector('.kasai-nav-particles');
  if(!field || !item) return;
  const ir = item.getBoundingClientRect();
  const fr = field.getBoundingClientRect();
  const x = ir.left - fr.left + ir.width / 2;
  const y = ir.top - fr.top + ir.height / 2;
  for(let i=0;i<10;i++){
    const dot = document.createElement('span');
    const size = Math.random() * 4 + 2;
    const angle = Math.random() * Math.PI * 2;
    const dist = 20 + Math.random() * 30;
    const color = NAV_D_COLORS[Math.floor(Math.random() * NAV_D_COLORS.length)];
    dot.className = 'kasai-nav-particle';
    dot.style.cssText = `width:${size}px;height:${size}px;left:${x}px;top:${y}px;background:${color};--px:${(Math.cos(angle)*dist).toFixed(1)}px;--py:${(Math.sin(angle)*dist-8).toFixed(1)}px;--pd:${(.35+Math.random()*.25).toFixed(2)}s;box-shadow:0 0 ${size*2}px ${color};animation-delay:${(i*.025).toFixed(3)}s;`;
    field.appendChild(dot);
    setTimeout(()=>dot.remove(), 760);
  }
}

function moveNeonSlider(nav, shouldBurst=false){
  const slider = nav.querySelector('.kasai-nav-slider');
  const active = nav.querySelector('.nav-item.active');
  if(!slider || !active) return;
  const nr = nav.getBoundingClientRect();
  const ar = active.getBoundingClientRect();
  slider.style.left = `${ar.left - nr.left + ar.width * 0.15}px`;
  slider.style.width = `${ar.width * 0.7}px`;
  if(shouldBurst) burstNeonNav(nav, active);
}

function updateBottomNav(screen){
  ensureNeonSlashNavs();
  document.querySelectorAll('.bottom-nav .nav-item').forEach(item=>{
    const isActive = item.dataset.screen === screen || (!item.dataset.screen && screen === 'training');
    if(isActive && !item.classList.contains('active')){
      item.classList.add('morphing');
      setTimeout(()=>item.classList.remove('morphing'), 460);
    }
    item.classList.toggle('active', isActive);
  });
  document.querySelectorAll('.bottom-nav').forEach(nav=>moveNeonSlider(nav, true));
}

function navigate(screen, data){
  const fromEl = document.getElementById('screen-'+currentScreen);
  const toEl   = document.getElementById('screen-'+screen);
  if(!toEl) return;
  if(currentScreen==='exercise' && screen!=='exercise') stopRest();

  activateScreen(screen);
  if(screen === 'exercise') fromEl?.classList.add('slide-left');

  prevScreen = currentScreen;
  currentScreen = screen;
  updateBottomNav(screen);

  if(screen === 'training')       renderTraining();
  if(screen === 'run')            renderRunTracker();
  if(screen === 'exercise')       renderExercise(data);
  if(screen === 'nutrition')      renderNutrition();
  if(screen === 'habits')         renderHabits();
  if(screen === 'profile')        renderProfile();
  if(screen === 'training-plan')  renderTrainingPlanScreen();
  if(screen === 'day-detail')     renderDayDetailScreen();
}

function renderAll(){
  if(currentScreen === 'training')      renderTraining();
  if(currentScreen === 'run')           renderRunTracker();
  if(currentScreen === 'exercise')      renderExercise(currentExercise);
  if(currentScreen === 'nutrition')     renderNutrition();
  if(currentScreen === 'habits')        renderHabits();
  if(currentScreen === 'profile')       renderProfile();
  if(currentScreen === 'training-plan') renderTrainingPlanScreen();
  if(currentScreen === 'day-detail')    renderDayDetailScreen();
  scheduleEncodingRepair();
  scheduleI18n();
}

