let _tpDailyEditId = null;

function openTpDailyModal(exId=null){
  _tpDailyEditId = exId;
  const day = getDayDetailDay();
  if(!day) return;
  const ex = exId ? ensureDailyExercisesForDay(day).find(item=>item.id===exId) : null;
  const isEdit = !!ex;
  document.getElementById('tp-daily-title').textContent = isEdit ? 'Tagesübung bearbeiten' : 'Tagesübung hinzufügen';
  document.getElementById('tp-daily-save').textContent = isEdit ? 'Änderungen speichern' : 'Tagesübung speichern';
  document.getElementById('tp-daily-name').value = ex?.name || '';
  document.getElementById('tp-daily-target').value = ex?.target || 50;
  document.getElementById('tp-daily-step').value = ex?.step || 5;
  document.getElementById('tp-daily-unit').value = ex?.unit || 'Wdh';
  selectTimePicker('tp-daily-time', ex?.timeOfDay || 'morning', 'morning');
  document.querySelectorAll('#tp-daily-icons .tp-emoji-pick').forEach(pick=>{
    pick.classList.toggle('active', pick.dataset.icon === (ex?.icon || '💪'));
  });
  document.getElementById('tp-daily-overlay').classList.add('open');
  document.getElementById('tp-daily-sheet').classList.add('open');
}

function closeTpDailyModal(){
  document.getElementById('tp-daily-overlay').classList.remove('open');
  document.getElementById('tp-daily-sheet').classList.remove('open');
}

function saveTpDailyModal(){
  const day = getDayDetailDay();
  if(!day) return;
  const name = document.getElementById('tp-daily-name').value.trim();
  if(!name){ document.getElementById('tp-daily-name').focus(); return; }
  const data = {
    name,
    icon: document.querySelector('#tp-daily-icons .tp-emoji-pick.active')?.dataset.icon || '💪',
    timeOfDay: readTimePicker('tp-daily-time', 'morning'),
    target: Math.max(1, parseInt(document.getElementById('tp-daily-target').value) || 50),
    step: Math.max(1, parseInt(document.getElementById('tp-daily-step').value) || 5),
    unit: document.getElementById('tp-daily-unit').value.trim() || 'Wdh'
  };
  const list = ensureDailyExercisesForDay(day);
  if(_tpDailyEditId){
    const ex = list.find(item=>item.id===_tpDailyEditId);
    if(ex) Object.assign(ex, data);
  } else {
    list.push(normalizeDailyExercise({
      id: genId(),
      ...data,
      sortOrder: list.length,
      isArchived: false
    }, list.length));
  }
  saveState(S);
  closeTpDailyModal();
  renderDayDetailScreen();
  if(currentScreen === 'training') renderTraining();
}

