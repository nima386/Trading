// READINESS OVERLAY
// ---------------------------------------------------
function calcReadiness(s,m,k){
  // Schlaf+Motivation hoch=gut, Muskelkater hoch=schlecht (invertiert)
  return ((s + m + (11-k)) / 3);
}
function readinessLabel(score){
  if(score >= 8) return 'Volle Power 🔥';
  if(score >= 6.5) return 'Gut bereit -';
  if(score >= 5) return 'Solide - leg los';
  return 'Heute leichter? -20% empfohlen';
}
function updateReadiness(){
  const s = +document.getElementById('rd-sleep').value;
  const m = +document.getElementById('rd-motiv').value;
  const k = +document.getElementById('rd-sore').value;
  document.getElementById('rd-sleep-val').textContent = s;
  document.getElementById('rd-motiv-val').textContent = m;
  document.getElementById('rd-sore-val').textContent  = k;
  const score = calcReadiness(s,m,k);
  document.getElementById('rd-result').textContent = `Score: ${score.toFixed(1)} - ${readinessLabel(score)}`;
}
['rd-sleep','rd-motiv','rd-sore'].forEach(id=>{
  KDOM.on(id, 'input', updateReadiness);
});

