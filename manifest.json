/* KASAI EMBER PULSE BUTTONS */
.kasai-btn{
  position:relative;
  width:100%;
  min-height:54px;
  border:none;
  border-radius:999px;
  font-family:'Outfit',sans-serif;
  font-size:15px;
  font-weight:700;
  letter-spacing:.04em;
  cursor:pointer;
  display:flex;
  align-items:center;
  justify-content:center;
  color:#fff;
  user-select:none;
  -webkit-tap-highlight-color:transparent;
  overflow:visible;
  transition:transform .15s ease,box-shadow .15s ease,background .2s ease,border-color .2s ease;
}
.kasai-btn:active{transform:scale(.96);}
.kasai-btn[disabled]{cursor:wait;opacity:.92;}
.kasai-btn-text{
  position:relative;z-index:5;
  display:flex;align-items:center;gap:8px;
  transition:opacity .2s ease;
  pointer-events:none;
}
.kasai-btn.loading .kasai-btn-text,
.kasai-btn.success .kasai-btn-text{opacity:0;}
.kasai-btn-dots{
  position:absolute;inset:0;z-index:5;
  display:flex;align-items:center;justify-content:center;
  gap:6px;opacity:0;pointer-events:none;
  transition:opacity .2s ease .1s;
}
.kasai-btn.loading .kasai-btn-dots{opacity:1;}
.kasai-dot{
  width:7px;height:7px;border-radius:50%;
  background:rgba(255,255,255,.9);
  animation:kasai-dot-breath 1.1s ease-in-out infinite;
}
.kasai-dot:nth-child(2){animation-delay:.18s;}
.kasai-dot:nth-child(3){animation-delay:.36s;}
@keyframes kasai-dot-breath{
  0%,100%{transform:scale(.5);opacity:.35;}
  50%{transform:scale(1);opacity:1;}
}
.kasai-btn-check{
  position:absolute;inset:0;z-index:5;
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;
}
.kasai-btn.success .kasai-btn-check{animation:kasai-check-in .5s cubic-bezier(.34,1.56,.64,1) forwards;}
@keyframes kasai-check-in{
  0%{opacity:0;transform:scale(.2) rotate(-30deg);}
  60%{opacity:1;transform:scale(1.2) rotate(4deg);}
  100%{opacity:1;transform:scale(1) rotate(0deg);}
}
.kasai-check-svg{width:24px;height:24px;stroke-dasharray:30;stroke-dashoffset:30;}
.kasai-btn.success .kasai-check-svg{animation:kasai-draw-check .4s ease forwards .1s;}
@keyframes kasai-draw-check{to{stroke-dashoffset:0;}}
.kasai-btn-login{
  background:linear-gradient(135deg,#ff8c00,#ff5500,#ff2055)!important;
  box-shadow:0 0 22px rgba(255,107,0,.40),0 6px 24px rgba(0,0,0,.5);
}
.kasai-btn-login:hover{
  box-shadow:0 0 34px rgba(255,107,0,.55),0 8px 28px rgba(0,0,0,.55);
  transform:translateY(-2px);
}
.kasai-btn-login.success{
  background:linear-gradient(135deg,#26d47c,#1ea862)!important;
  box-shadow:0 0 32px rgba(38,212,124,.55),0 6px 24px rgba(0,0,0,.5);
}
.ring-login{
  position:absolute;inset:0;border-radius:999px;
  border:2px solid rgba(255,107,0,.75);
  pointer-events:none;opacity:0;
}
.ring-login.r2{border-color:rgba(255,80,0,.55);}
.ring-login.r3{border-color:rgba(255,45,85,.40);}
.kasai-btn-login.loading .ring-login.r1{animation:kasai-fire-wave 2s ease-out infinite;}
.kasai-btn-login.loading .ring-login.r2{animation:kasai-fire-wave 2s ease-out .55s infinite;}
.kasai-btn-login.loading .ring-login.r3{animation:kasai-fire-wave 2s ease-out 1.1s infinite;}
@keyframes kasai-fire-wave{
  0%{opacity:.95;transform:scale(1);border-width:2.5px;box-shadow:inset 0 0 0 0 transparent,0 0 0 0 transparent;}
  40%{opacity:.55;border-width:1.5px;}
  100%{opacity:0;transform:scale(1.42);border-width:.5px;box-shadow:0 0 12px rgba(255,107,0,0);}
}
.login-core{
  position:absolute;inset:4px;border-radius:999px;
  background:radial-gradient(ellipse at 35% 40%,rgba(255,220,100,.25),transparent 60%);
  pointer-events:none;opacity:0;transition:opacity .4s ease;
}
.kasai-btn-login.loading .login-core{opacity:1;}
.kasai-btn-logout{
  width:100%;
  margin-top:10px;
  background:rgba(255,45,85,.08);
  border:1.5px solid rgba(255,45,85,.28);
  color:#ff5577;
  box-shadow:none;
}
.kasai-btn-logout:hover{
  background:rgba(255,45,85,.14);
  border-color:rgba(255,45,85,.45);
  transform:translateY(-2px);
}
.kasai-btn-logout.loading{
  background:rgba(255,45,85,.06);
  color:rgba(255,85,119,.7);
}
.kasai-btn-logout.success{
  background:linear-gradient(135deg,#26d47c,#1ea862);
  border-color:transparent;
  color:#fff;
  box-shadow:0 0 32px rgba(38,212,124,.55);
}
.ring-logout{
  position:absolute;inset:0;border-radius:999px;
  pointer-events:none;opacity:0;
  border:2px solid rgba(255,45,85,.8);
}
.ring-logout.r2{border-color:rgba(255,61,0,.55);}
.ring-logout.r3{border-color:rgba(255,107,0,.35);}
.kasai-btn-logout.loading .ring-logout.r1{animation:kasai-ember-wave 2.2s ease-out infinite;}
.kasai-btn-logout.loading .ring-logout.r2{animation:kasai-ember-wave 2.2s ease-out .6s infinite;}
.kasai-btn-logout.loading .ring-logout.r3{animation:kasai-ember-wave 2.2s ease-out 1.2s infinite;}
@keyframes kasai-ember-wave{
  0%{opacity:.9;transform:scale(1);border-width:2px;}
  35%{opacity:.5;border-width:1.5px;}
  100%{opacity:0;transform:scale(1.48);border-width:.5px;}
}
.power-icon{font-size:16px;transition:filter .3s ease;}
.kasai-btn-logout.loading .power-icon{animation:kasai-power-flicker 1.4s ease-in-out infinite;}
@keyframes kasai-power-flicker{
  0%,100%{filter:drop-shadow(0 0 3px rgba(255,45,85,.6));opacity:1;}
  50%{filter:drop-shadow(0 0 8px rgba(255,45,85,1));opacity:.8;}
}
.kasai-btn-halo{
  position:absolute;inset:-16px;border-radius:999px;
  pointer-events:none;opacity:0;transition:opacity .4s ease;z-index:-1;
}
.login-halo{background:radial-gradient(ellipse,rgba(255,107,0,.22),transparent 70%);}
.logout-halo{background:radial-gradient(ellipse,rgba(255,45,85,.18),transparent 70%);}
.kasai-btn.loading .kasai-btn-halo{opacity:1;}


.settings-profile{
  display:flex;align-items:center;gap:14px;
  background:linear-gradient(135deg,rgba(110,99,242,0.18),rgba(240,98,146,0.10));
  border:1px solid var(--border-glow);
  border-radius:var(--r-lg);padding:14px;margin-bottom:14px;
}
.settings-profile-avatar{
  width:48px;height:48px;border-radius:50%;flex-shrink:0;
  background:linear-gradient(135deg,var(--purple-500),var(--pink));
  display:flex;align-items:center;justify-content:center;
  font-weight:700;font-size:1rem;color:#fff;box-shadow:var(--shadow-glow);
}
.settings-profile-info{flex:1;min-width:0;}
.settings-profile-name{font-weight:700;font-size:1rem;letter-spacing:-0.01em;}
.settings-profile-email{font-family:'JetBrains Mono',monospace;font-size:.62rem;color:var(--text-muted);letter-spacing:.04em;margin-top:2px;word-break:break-word;}

/* Sync-Status Pill */
.settings-sync{
  display:flex;align-items:center;gap:8px;
  font-family:'JetBrains Mono',monospace;font-size:.58rem;
  color:var(--text-muted);letter-spacing:.1em;text-transform:uppercase;
  background:rgba(38,212,124,0.08);
  border:1px solid rgba(38,212,124,0.18);
  border-radius:var(--r-full);padding:6px 12px;
  margin-bottom:14px;
}
.settings-sync.ok{
  color:rgba(38,212,124,.95);
  background:rgba(38,212,124,0.12);
  border-color:rgba(38,212,124,0.32);
}
.settings-sync-dot{
  width:8px;height:8px;border-radius:50%;background:var(--green);
  box-shadow:0 0 8px var(--green);flex-shrink:0;
  animation:pulse 1.8s ease-in-out infinite;
}
.settings-sync.syncing .settings-sync-dot{background:var(--amber);box-shadow:0 0 8px var(--amber);}
.settings-sync.error  .settings-sync-dot{background:var(--red,#f06060);box-shadow:0 0 8px var(--red,#f06060);animation:none;}
.settings-sync.waiting .settings-sync-dot{background:var(--purple-400);box-shadow:0 0 8px var(--purple-400);}
.settings-sync.offline .settings-sync-dot{background:var(--text-muted);box-shadow:0 0 8px rgba(145,144,184,.35);animation:none;}
.settings-sync.sync-confirm{
  animation:syncConfirmPulse .58s cubic-bezier(.22,1,.36,1);
}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.4;}}
@keyframes syncConfirmPulse{
  0%{transform:scale(.98);box-shadow:0 0 0 rgba(38,212,124,0);}
  50%{transform:scale(1.02);box-shadow:0 0 22px rgba(38,212,124,.22);}
  100%{transform:scale(1);box-shadow:0 0 0 rgba(38,212,124,0);}
}

.sync-debug-card{
  display:none;
  margin:0 0 14px;
  padding:12px;
  border-radius:var(--r-md);
  background:rgba(255,255,255,0.035);
