const today = new Date();
const todayStr = dateKey(today);
let selectedDate = new Date(today.toDateString());
let selectedDateStr = dateKey(selectedDate);

function setSelectedDate(date){
  selectedDate = new Date(date.toDateString());
  selectedDateStr = dateKey(selectedDate);
  ensureDailyState(selectedDateStr);
  const strip = document.getElementById('calendar-strip');
  if(strip){
    strip.classList.add('is-morphing');
    clearTimeout(strip._morphTimer);
    strip._morphTimer = setTimeout(()=>strip.classList.remove('is-morphing'), 360);
  }
}

function ensureDailyState(dayKey=selectedDateStr){
  if(S.hydration?.[dayKey] == null) S.hydration[dayKey] = 0;
  if(S.steps?.[dayKey] == null) S.steps[dayKey] = 0;
  if(!S.dailyExerciseLogs) S.dailyExerciseLogs = {};
  if(!S.dailyExerciseLogs[dayKey]) S.dailyExerciseLogs[dayKey] = {};
  if(!S.habits?.[dayKey]) S.habits[dayKey] = {};
  if(!S.sessions?.[dayKey]) S.sessions[dayKey] = {};
  if(!S.meals?.[dayKey]) S.meals[dayKey] = [];
}

function getActiveDateLabel(date=selectedDate){
  return `${DE_DAYS_FULL[date.getDay()]} - ${date.getDate().toString().padStart(2,'0')} ${DE_MONTHS[date.getMonth()].toLowerCase()}`;
}

function isSelectedToday(){
  return selectedDateStr === todayStr;
}

function loadState(){
  return {};
}

function userStateKey(session=authSession){
  return session?.user?.id ? `forge_user_state_${session.user.id}` : null;
}

function saveLocalUserState(snapshot, session=authSession){
  const key = userStateKey(session);
  if(!key) return;
  try{
    const state = JSON.parse(JSON.stringify(snapshot));
    state.updatedAt = state.updatedAt || new Date().toISOString();
    localStorage.setItem(key, JSON.stringify({
      state,
      savedAt: new Date().toISOString()
    }));
  }catch(_){}
}

function loadLocalUserState(session=authSession){
  const saved = loadLocalUserStateRecord(session);
  return saved?.state && typeof saved.state === 'object' ? saved.state : null;
}

function loadLocalUserStateRecord(session=authSession){
  const key = userStateKey(session);
  if(!key) return null;
  try{
    const saved = JSON.parse(localStorage.getItem(key) || 'null');
    return saved?.state && typeof saved.state === 'object' ? saved : null;
  }catch(_){
    return null;
  }
}

// Sync-Status-Indikator im Settings-Overlay
function setSyncStatus(state, label){
  const el = document.getElementById('settings-sync-status');
  try{ window.KasaiUX?.setSaveStatus?.(state, label); }catch(_){}
  if(!el) return;
  const textEl = document.getElementById('settings-sync-text');
  el.classList.remove('ok','syncing','error','waiting','offline');
  if(state==='ok')      el.classList.add('ok');
  if(state==='syncing') el.classList.add('syncing');
  if(state==='error')   el.classList.add('error');
  if(state==='waiting') el.classList.add('waiting');
  if(state==='offline') el.classList.add('offline');
  if(textEl) textEl.textContent = label;
  if(state==='ok'){
    _lastSuccessfulSyncAt = new Date().toISOString();
    _lastSyncError = '';
    el.classList.remove('sync-confirm');
    void el.offsetWidth;
    el.classList.add('sync-confirm');
    setTimeout(()=>{ if(textEl) textEl.textContent = '// gespeichert'; }, 2000);
  }
  if(state==='error') _lastSyncError = label || 'sync error';
  renderSyncDebug();
}

// saveState: lokal sofort + Cloud sofort in Reihenfolge (nur wenn eingeloggt)
let _stateSyncQueue = Promise.resolve();
let _stateSyncPending = 0;
let _stateSyncRevision = 0;
let _stateSyncTimer = null;
let _stateSyncRetryTimer = null;
function schedulePendingSyncRetry(delay=5000){
  if(_stateSyncRetryTimer) return;
  _stateSyncRetryTimer = setTimeout(()=>{
    _stateSyncRetryTimer = null;
    const run = typeof resumeSession === 'function'
      ? resumeSession('sync-retry').then(()=>flushPendingState())
      : flushPendingState();
    Promise.resolve(run).catch(error=>console.warn('Pending sync retry failed', error));
  }, delay);
}
function pendingStateKey(){
  const session = authSession?.user ? authSession : readPersistedSupabaseSession();
  return session?.user?.id ? `forge_pending_state_${session.user.id}` : null;
}
function markPendingState(snapshot, revision, area='app'){
  const key = pendingStateKey();
  if(!key) return;
  try{
    localStorage.setItem(key, JSON.stringify({
      state: snapshot,
      revision,
      area,
      savedAt: new Date().toISOString()
    }));
    renderSyncDebug();
  }catch(_){}
}
function clearPendingState(revision=null){
  const key = pendingStateKey();
  if(!key) return;
  try{
    if(revision != null){
      const pending = JSON.parse(localStorage.getItem(key) || 'null');
      if(pending?.revision !== revision) return;
    }
    localStorage.removeItem(key);
    renderSyncDebug();
  }catch(_){}
}
function readPendingState(){
  const key = pendingStateKey();
  if(!key) return null;
  try{ return JSON.parse(localStorage.getItem(key) || 'null'); }
  catch(_){ return null; }
}
async function flushPendingState({keepalive=false}={}){
  const session = authSession?.user ? authSession : await ensureActiveSession('flush-pending');
  if(!session?.user) return;
  const pending = readPendingState();
  if(!pending?.state) return;
  if(!hasMeaningfulUserState(pending.state)){
    clearPendingState(pending.revision ?? null);
    return;
  }
  if(!isHydratedForSession(session)){
    setSyncStatus('waiting','// daten werden geladen');
    schedulePendingSyncRetry(1500);
    return;
  }
  const area = pending.area || 'app';
  const payload = JSON.parse(JSON.stringify(pending.state));
  payload.updatedAt = new Date().toISOString();

  if(keepalive && session.access_token){
    try{
      const res = await fetch(`${SUPABASE_CONFIG.url}/rest/v1/user_app_state?on_conflict=user_id`, {
        method:'POST',
        keepalive:true,
        headers:{
          apikey: SUPABASE_CONFIG.publishableKey,
          Authorization: `Bearer ${session.access_token}`,
          'Content-Type':'application/json',
          Prefer:'resolution=merge-duplicates'
        },
        body: JSON.stringify({
          user_id: session.user.id,
          state: payload,
          updated_at: new Date().toISOString()
        })
      });
      if(res.ok) {
        _lastSuccessfulSyncAt = new Date().toISOString();
        logUserSyncEvent({status:'success', area, metadata:{mode:'keepalive'}});
        clearPendingState(pending.revision ?? null);
      } else {
        logUserSyncEvent({status:'error', area, error:`keepalive ${res.status}`, metadata:{mode:'keepalive'}});
      }
    }catch(_){}
    return;
  }

  try{
    await syncAppState(pending.state, area);
    clearPendingState(pending.revision ?? null);
  }catch(error){
    if(isMissingAppStateTable(error)){
      setSyncStatus('error','// DB-Tabelle fehlt');
      console.warn('user_app_state table is missing. Run supabase-app-state.sql in Supabase SQL Editor.', error);
      return;
    }
    if(isSupabasePermissionError(error)){
      setSyncStatus('error','// DB-Rechte fehlen');
      console.warn('Supabase grants are missing. Run supabase-schema.sql in Supabase SQL Editor.', error);
      return;
    }
    throw error;
  }
  saveLocalUserState(payload);
}
function queueImmediateCloudSync(snapshot, area=guessSyncArea()){
  const session = authSession?.user ? authSession : readPersistedSupabaseSession();
  if(!session?.user) {
    setSyncStatus('waiting','// wartet auf login');
    return;
  }
  if(!hasMeaningfulUserState(snapshot)){
    setSyncStatus('ok','// lokal bereit');
    return;
  }
  if(!authSession?.user){
    authSession = session;
    authLoading = false;
    updateAuthUI();
  }
  const revision = ++_stateSyncRevision;
  _lastSyncArea = area || 'app';
  markPendingState(snapshot, revision, _lastSyncArea);
  if(!isHydratedForSession(session)){
    setSyncStatus('waiting','// lokal gespeichert');
    schedulePendingSyncRetry(1500);
    return;
  }
  if(!forgeSupabase){
    setSyncStatus('waiting','// speichert sobald online');
    schedulePendingSyncRetry();
    return;
  }
  if(_stateSyncTimer) clearTimeout(_stateSyncTimer);
  setSyncStatus('waiting','// speichert...');
  _stateSyncTimer = setTimeout(()=>{
    _stateSyncTimer = null;
    _stateSyncPending += 1;
    setSyncStatus('syncing','// speichert...');
  _stateSyncQueue = _stateSyncQueue
    .catch(()=>{})
    .then(async()=>{
      await withTimeout(syncAppState(snapshot, _lastSyncArea), 5500, 'cloud save');
      clearPendingState(revision);
      _stateSyncPending = Math.max(0, _stateSyncPending - 1);
      if(_stateSyncPending === 0) setSyncStatus('ok','// gespeichert');
    })
    .catch(error=>{
      _stateSyncPending = Math.max(0, _stateSyncPending - 1);
      console.warn('Immediate app state sync failed', error);
      logUserSyncEvent({status:'error', area:_lastSyncArea, error, metadata:{phase:'queue'}});
      if(isMissingAppStateTable(error)) setSyncStatus('error','// DB-Tabelle fehlt');
      else if(isSupabasePermissionError(error)) setSyncStatus('error','// DB-Rechte fehlen');
      else {
        setSyncStatus('offline','// offline gespeichert');
        schedulePendingSyncRetry();
      }
    });
  }, 550);
}
function saveState(s, area=guessSyncArea()){
  let snapshot = null;
  try{
    snapshot = window.KasaiState?.cloneWithUpdatedAt
      ? window.KasaiState.cloneWithUpdatedAt(s)
      : JSON.parse(JSON.stringify(s));
    snapshot.updatedAt = snapshot.updatedAt || new Date().toISOString();
    const session = authSession?.user ? authSession : readPersistedSupabaseSession();
    if(session?.user && (isHydratedForSession(session) || hasMeaningfulUserState(snapshot))) saveLocalUserState(snapshot, session);
  }catch(_){}
  if(snapshot && hasMeaningfulUserState(snapshot)){
    try{ window.KasaiUX?.markLocalSave?.(area); }catch(_){}
    queueImmediateCloudSync(snapshot, area);
  }
}

async function flushStateSync(){
  if(_stateSyncTimer){
    clearTimeout(_stateSyncTimer);
    _stateSyncTimer = null;
  }
  try{ await _stateSyncQueue; }catch(_){}
  await flushPendingState();
}

window.addEventListener('pagehide',()=>{
  if(authSession?.user) flushPendingState({keepalive:true});
});
window.addEventListener('beforeunload',()=>{
  if(authSession?.user) flushPendingState({keepalive:true});
});

const TIME_OF_DAY = {
  morning: {label:'Morgens', short:'Morgen', en:'Morning', icon:'☀', color:'#ffca28', notifyTime:'06:30', headline:'Morgens'},
  midday:  {label:'Mittags', short:'Mittag', en:'Midday',  icon:'◐', color:'#26c6da', notifyTime:'11:30', headline:'Mittags'},
  evening: {label:'Abends',  short:'Abend',  en:'Evening', icon:'◒', color:'#ff9500', notifyTime:'17:30', headline:'Abends'},
  night:   {label:'Nachts',  short:'Nacht',  en:'Night',   icon:'☾', color:'#8a80f8', notifyTime:'20:30', headline:'Nachts'}
};
const TIME_OF_DAY_ORDER = ['morning','midday','evening','night'];
function normalizeTimeOfDay(value, fallback='morning'){
  return TIME_OF_DAY[value] ? value : fallback;
}
function timeOfDayMeta(value){
  const base = TIME_OF_DAY[normalizeTimeOfDay(value)] || TIME_OF_DAY.morning;
  if(typeof currentLanguage === 'function' && currentLanguage() === 'en'){
    return Object.assign({}, base, {
      label: base.en || base.label,
      short: base.en || base.short,
      headline: (typeof KASAI_I18N !== 'undefined' && KASAI_I18N[base.headline]) || base.headline
    });
  }
  return base;
}
function selectTimePicker(id, value, fallback='morning'){
  const wrap = document.getElementById(id);
  if(!wrap) return;
  const safe = value === 'inherit' ? 'inherit' : normalizeTimeOfDay(value, fallback);
  wrap.querySelectorAll('.tp-time-pill').forEach(p=>p.classList.toggle('active', p.dataset.time === safe));
}
function readTimePicker(id, fallback='morning'){
  const value = document.querySelector(`#${id} .tp-time-pill.active`)?.dataset.time || fallback;
  return value === 'inherit' ? 'inherit' : normalizeTimeOfDay(value, fallback);
}

