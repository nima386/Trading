// ---------------------------------------------------
// PR DETECTION + KONFETTI
// ---------------------------------------------------
function epley(w, r){ return w * (1 + r/30); }

const KFETTI_COLORS = ['#6e63f2','#f06292','#26d47c','#ffca28','#26c6da','#a29bfe','#ff8a3d'];
function fireKonfetti(){
  const stage = document.getElementById('konfetti-stage');
  for(let i=0;i<60;i++){
    const k = document.createElement('div');
    k.className = 'konfetti';
    k.style.left = Math.random()*100 + '%';
    k.style.background = KFETTI_COLORS[i % KFETTI_COLORS.length];
    k.style.animationDelay = (Math.random()*0.4) + 's';
    k.style.animationDuration = (1.2 + Math.random()*0.9) + 's';
    k.style.transform = `rotate(${Math.random()*360}deg)`;
    stage.appendChild(k);
    setTimeout(()=>k.remove(), 2400);
  }
  if(navigator.vibrate) navigator.vibrate([60,40,80,40,120]);
}

function checkPR(ex, weight, reps){
  if(weight == null || Number.isNaN(weight) || !reps) return false;
  const cur = epley(weight, reps);
  const prW = ex.pr?.w || 0, prR = ex.pr?.r || 0;
  const prE = epley(prW, prR);
  const sameWeightRepsPR = weight === prW && reps > prR;
  if(cur > prE || sameWeightRepsPR){
    // update PR (in-memory copy on currentExercise so detail re-renders)
    ex.pr = {
      w: weight,
      r: reps,
      date: new Date().toLocaleDateString('de',{day:'2-digit',month:'long'}),
      detectedAt: new Date().toISOString(),
      kind: sameWeightRepsPR ? 'reps' : 'epley'
    };
    return true;
  }
  return false;
}

