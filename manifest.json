  // V3: Heartbeat / ECG
  `<svg width="180" height="160" viewBox="0 0 180 160" xmlns="http://www.w3.org/2000/svg" id="iconSvg">
    <defs>
      <linearGradient id="ecg-g" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#ff2d55"/>
        <stop offset="40%" stop-color="#ff6b00"/>
        <stop offset="100%" stop-color="#ffca28"/>
      </linearGradient>
      <filter id="ecg-glow">
        <feGaussianBlur stdDeviation="3" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
    </defs>
    <!-- heart shape behind -->
    <path d="M90,130 C40,100 10,75 10,50 C10,28 28,18 50,22 C64,24 76,34 90,48 C104,34 116,24 130,22 C152,18 170,28 170,50 C170,75 140,100 90,130Z"
      fill="rgba(255,45,85,0.08)" stroke="rgba(255,45,85,0.15)" stroke-width="1"/>
    <!-- ECG line -->
    <polyline id="ecgLine"
      points="0,80 25,80 35,80 42,30 50,120 58,60 66,80 90,80 100,80 110,80 117,30 125,120 133,60 141,80 180,80"
