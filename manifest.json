<script>

// -- TAGLINES --
const taglines = [
  "Run your limits · Into dust",
  "Strike first · Strike fast",
  "Heart of a champion · Every rep",
  "Reach the summit · Or die trying",
  "Iron sharpens iron · Be iron"
];

const vnames = ['Runner','Lightning','Heartbeat','Summit','Iron'];

// -- ICONS (inline SVG per variant) --
const icons = [

  // V1: Running figure
  `<svg width="160" height="180" viewBox="0 0 160 180" xmlns="http://www.w3.org/2000/svg" id="iconSvg">
    <defs>
      <linearGradient id="run-g" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#ffca28"/>
        <stop offset="50%" stop-color="#ff6b00"/>
        <stop offset="100%" stop-color="#ff2d55"/>
      </linearGradient>
      <filter id="run-glow">
        <feGaussianBlur stdDeviation="3" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
    </defs>
    <!-- ground line -->
    <line x1="10" y1="158" x2="150" y2="158" stroke="rgba(255,107,0,0.2)" stroke-width="1"/>
