const KDOM = window.KasaiDOM || {
  byId: id => document.getElementById(id),
  query: selector => document.querySelector(selector),
  all: selector => Array.from(document.querySelectorAll(selector)),
  on(target, type, handler, options){
    const el = typeof target === 'string' ? document.getElementById(target) : target;
    if(!el) {
      console.warn('[KASAI DOM] Missing element for event binding', {target, type});
      return null;
    }
    el.addEventListener(type, handler, options);
    return el;
  },
  onQuery(selector, type, handler, options){
    const el = document.querySelector(selector);
    if(!el) {
      console.warn('[KASAI DOM] Missing selector for event binding', {selector, type});
      return null;
    }
    el.addEventListener(type, handler, options);
    return el;
  },
  onAll(selector, type, handler, options){
    const nodes = Array.from(document.querySelectorAll(selector));
    nodes.forEach(el=>el.addEventListener(type, handler, options));
    return nodes;
  },
  setClick(id, handler, options){
    return this.on(id, 'click', handler, options);
  }
};

