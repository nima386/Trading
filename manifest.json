let _tpMgEditId = null;

function openTpMgModal(mgId=null){
  _tpMgEditId = mgId;
  const isEdit = !!mgId;
  const mg = isEdit ? getDayDetailMuscle(mgId) : null;

  document.getElementById('tp-mg-title').textContent = isEdit ? 'Muskelgruppe bearbeiten' : 'Muskelgruppe hinzufügen';
  document.getElementById('tp-mg-save').textContent  = isEdit ? 'Änderungen speichern' : 'Muskelgruppe anlegen';
  document.getElementById('tp-mg-name').value = mg?.name||'';
  selectTimePicker('tp-mg-time', mg?.timeOfDay || 'morning', 'morning');

  // Reset pickers
  document.querySelectorAll('#tp-mg-emojis .tp-emoji-pick').forEach(e=>{
    e.classList.toggle('active', e.dataset.icon===(mg?.icon||'💪'));
  });
  document.querySelectorAll('.tp-color-dot').forEach(d=>{
    d.classList.toggle('active', d.dataset.color===(mg?.color||'#FF6B00'));
  });

  const overlay = document.getElementById('tp-mg-overlay');
  const sheet   = document.getElementById('tp-mg-sheet');
  overlay.classList.add('open');
  sheet.classList.add('open');
}
function closeTpMgModal(){
  document.getElementById('tp-mg-overlay').classList.remove('open');
  document.getElementById('tp-mg-sheet').classList.remove('open');
}
function saveTpMgModal(){
  const name  = document.getElementById('tp-mg-name').value.trim();
  if(!name){ document.getElementById('tp-mg-name').focus(); return; }
  const icon  = document.querySelector('#tp-mg-emojis .tp-emoji-pick.active')?.dataset.icon||'💪';
  const color = document.querySelector('.tp-color-dot.active')?.dataset.color||'#FF6B00';
  const day   = getDayDetailDay();
  if(!day) return;
  if(_tpMgEditId){
    const mg = getDayDetailMuscle(_tpMgEditId);
    if(mg){ mg.name=name; mg.icon=icon; mg.color=color; mg.timeOfDay = readTimePicker('tp-mg-time', 'morning'); }
  } else {
    if(!day.muscleGroups) day.muscleGroups=[];
    day.muscleGroups.push({ id:genId(), name, icon, color, timeOfDay:readTimePicker('tp-mg-time', 'morning'), sortOrder:day.muscleGroups.length, exercises:[], isArchived:false });
  }
  saveState(S);
  closeTpMgModal();
  renderDayDetailScreen();
}

