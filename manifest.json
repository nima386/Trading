function resetScreenGeometry(){
  document.documentElement.scrollLeft = 0;
  document.body.scrollLeft = 0;
  window.scrollTo(0, window.scrollY || 0);
  const app = document.getElementById('app');
  if(app) app.scrollLeft = 0;
  document.querySelectorAll('.screen').forEach(el=>{
    el.classList.remove('active','slide-left');
    el.style.transform = '';
    el.style.opacity = '';
    el.style.pointerEvents = '';
    el.style.visibility = '';
    el.scrollLeft = 0;
  });
}

function activateScreen(screen){
  resetScreenGeometry();
  const toEl = document.getElementById('screen-'+screen);
  if(!toEl) return null;
  toEl.classList.add('active');
  toEl.classList.remove('slide-left');
  toEl.style.transform = '';
  toEl.style.opacity = '';
  toEl.style.pointerEvents = '';
  toEl.style.visibility = '';
  toEl.classList.add('screen-entering');
  setTimeout(()=>toEl.classList.remove('screen-entering'), 360);
  return toEl;
}

