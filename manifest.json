// -- HELPER: Logout -- schnell abmelden, letzter Sync nur best-effort
async function performLogout(btn){
  setButtonLoading(btn, true);
  setSyncStatus('syncing','// abmelden...');
  try{ saveState(S, 'settings'); }catch(error){ console.warn('Best-effort save before logout failed', error); }
  try{ void flushPendingState({keepalive:true}).catch(error=>console.warn('Best-effort pending save before logout failed', error)); }catch(_){}
  _manualLogoutInProgress = true;
  await releaseDeviceLock();
  clearSupabaseSessionBackup();
  if(forgeSupabase) {
    try{
      await Promise.race([
        forgeSupabase.auth.signOut({scope:'local'}),
        new Promise(resolve=>setTimeout(resolve, 700))
      ]);
    }catch(error){
      console.warn('Supabase logout failed locally, clearing client cache anyway', error);
    }
  }
  authSession = null;
  clearAllUserData();
  updateAuthUI();
  setAuthStatus('Du bist abgemeldet.', 'success');
  renderAll();
  await setButtonSuccess(btn, 520);
  setTimeout(()=>{ _manualLogoutInProgress = false; }, 2500);
}

