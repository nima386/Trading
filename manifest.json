window.__kasaiAuthMainReady = true;

async function initAuthFlow(){
  const client = await ensureForgeSupabaseClient();
  if(!client){
    authLoading = false;
    updateAuthUI();
    return;
  }
  if(_authBootstrapped) return;
  _authBootstrapped = true;
  updateAuthUI();
  const {data} = client.auth.onAuthStateChange(async(_event, session)=>{
    authSession = session;
    if(session?.user) rememberSupabaseSession(session);
    if(session?.user) {
      await acquireExclusiveDevice(session);
      renderLocalUserState(session);
      try{
        await loadUserData(session.user.id, session);
        await flushPendingState();
        subscribeToUserRealtime(session.user.id);
        scheduleNotifications();
      }catch(error){
        console.warn('Auth state sync failed, continuing with local state.', error);
        const localBackup = loadLocalUserState(session);
        if(localBackup) {
          S = localBackup;
          normalizeState();
        }
      }
    } else if(_event === 'SIGNED_OUT') {
      if(_manualLogoutInProgress){
        clearAllUserData();
        updateAuthUI();
        return;
      }
      const persisted = readPersistedSupabaseSession();
      if(persisted?.user){
        authSession = persisted;
        ensureActiveSession('signed-out-recover').then(active=>{
          if(active?.user) refreshAuthSession();
        });
        return;
      }
      clearAllUserData();
    }
    updateAuthUI();
    if(session?.user) renderAll();
  });
  _authSubscription = data?.subscription || null;
  refreshAuthSession();
}
initAuthFlow();
scheduleEncodingRepair();
async function resumeSession(reason='resume'){
  const session = await ensureActiveSession(reason);
  if(session?.user){
    await acquireExclusiveDevice(session);
    try{ await withTimeout(flushPendingState(), 9000, 'resume pending sync'); }catch(error){ console.warn('Resume pending sync failed', error); }
    renderSyncDebug();
  }
  return session;
}
window.addEventListener('pageshow',e=>{
  if(e.persisted) _refreshAuthPromise = null;
  resumeSession('pageshow').then(()=>refreshAuthSession());
});
window.addEventListener('focus',()=>{ resumeSession('focus').then(()=>refreshAuthSession()); });
window.addEventListener('online',()=>{ resumeSession('online').then(()=>flushPendingState()); });
document.addEventListener('visibilitychange',()=>{
  if(document.visibilityState === 'visible') {
    resumeSession('visible').then(()=>refreshAuthSession());
  }
});

