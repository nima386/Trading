// ---------------------------------------------------
// AMOUNT OVERLAY (Hydration / Steps Set & Reset)
// ---------------------------------------------------
let _amountTarget = null; // 'water' | 'steps' | 'dailyExercise'
let _amountDailyExerciseId = null;

function openAmount(target){
  _amountTarget = target;
  _amountDailyExerciseId = null;
  const cur = target==='water' ? (S.hydration[selectedDateStr]||0) : (S.steps[selectedDateStr]||0);
  const goal = target==='water' ? parseIntegerInput(S.profile.waterGoal) : parseIntegerInput(S.profile.stepGoal);
  const unit = target==='water' ? 'ml' : 'Schritte';

  document.getElementById('am-kicker').textContent = target==='water' ? '// wasser setzen' : '// schritte setzen';
  document.getElementById('am-title').textContent  = target==='water' ? 'Wasserstand setzen' : 'Schritte setzen';
  document.getElementById('am-label').textContent  = `Aktuell - ${cur} ${unit} (Ziel ${goal ?? 'offen'})`;
  document.getElementById('am-input').value = cur;

  const quick = document.getElementById('am-quick');
  const opts = target==='water'
    ? [{lbl:'+250',v:250},{lbl:'+500',v:500},{lbl:'+1000',v:1000},{lbl:'-250',v:-250}]
    : [{lbl:'+500',v:500},{lbl:'+1000',v:1000},{lbl:'+2500',v:2500},{lbl:'-500',v:-500}];
  quick.innerHTML = opts.map(o=>`<button data-add="${o.v}">${o.lbl}</button>`).join('');
  quick.querySelectorAll('button').forEach(b=>{
    b.addEventListener('click',()=>{
      const inp = document.getElementById('am-input');
      const val = Math.max(0, (parseInt(inp.value)||0) + parseInt(b.dataset.add));
      inp.value = val;
    });
  });
  showOverlay('amount-overlay');
}

function openDailyExerciseAmount(exId){
  const ex = findDailyExerciseForSelectedDay(exId);
  if(!ex) return;
  _amountTarget = 'dailyExercise';
  _amountDailyExerciseId = ex.id;
  const cur = getDailyExerciseCount(ex.id);
  const goal = Math.max(1, parseInt(ex.target) || 1);
  const step = Math.max(1, parseInt(ex.step) || 1);
  document.getElementById('am-kicker').textContent = '// tagesübung setzen';
  document.getElementById('am-title').textContent = ex.name;
  document.getElementById('am-label').textContent = `Aktuell - ${cur} ${ex.unit} (Ziel ${goal})`;
  document.getElementById('am-input').value = cur;
  const quick = document.getElementById('am-quick');
  const opts = [
    {lbl:`+${step}`,v:step},
    {lbl:`+${step*2}`,v:step*2},
    {lbl:`+${step*5}`,v:step*5},
    {lbl:`-${step}`,v:-step}
  ];
  quick.innerHTML = opts.map(o=>`<button data-add="${o.v}">${o.lbl}</button>`).join('');
  quick.querySelectorAll('button').forEach(b=>{
    b.addEventListener('click',()=>{
      const inp = document.getElementById('am-input');
      inp.value = Math.max(0, (parseInt(inp.value)||0) + parseInt(b.dataset.add));
    });
  });
  showOverlay('amount-overlay');
}

KDOM.setClick('am-save', ()=>{
  const v = Math.max(0, parseInt(document.getElementById('am-input').value)||0);
  ensureDailyState(selectedDateStr);
  if(_amountTarget==='water'){ S.hydration[selectedDateStr] = v; }
  else if(_amountTarget==='steps'){ S.steps[selectedDateStr] = v; }
  else if(_amountTarget==='dailyExercise' && _amountDailyExerciseId){ setDailyExerciseCount(_amountDailyExerciseId, v); }
  saveState(S);
  hideOverlay('amount-overlay');
  if(_amountTarget==='water' && currentScreen==='nutrition') renderHydration();
  if(_amountTarget==='steps' && currentScreen==='habits')    renderSteps();
  if(_amountTarget==='dailyExercise' && currentScreen==='training') renderDailyExerciseTrackers();
});
KDOM.setClick('am-reset', ()=>{
  if(_amountTarget==='water') S.hydration[selectedDateStr] = 0;
  if(_amountTarget==='steps') S.steps[selectedDateStr]     = 0;
  if(_amountTarget==='dailyExercise' && _amountDailyExerciseId) setDailyExerciseCount(_amountDailyExerciseId, 0);
  saveState(S);
  hideOverlay('amount-overlay');
  if(_amountTarget==='water' && currentScreen==='nutrition') renderHydration();
  if(_amountTarget==='steps' && currentScreen==='habits')    renderSteps();
  if(_amountTarget==='dailyExercise' && currentScreen==='training') renderDailyExerciseTrackers();
});

KDOM.setClick('hydration-menu', e=>{ e.stopPropagation(); openAmount('water'); });
KDOM.setClick('steps-menu', e=>{ e.stopPropagation(); openAmount('steps'); });
document.getElementById('profile-open-settings')?.addEventListener('click',openTrainingPlanScreen);
document.querySelector('.concept-profile-card')?.addEventListener('click',openSettings);
document.getElementById('profile-plan-start')?.addEventListener('change',e=>{
  const value = e.target.value || todayStr;
  if(!S.planConfig) S.planConfig = {};
  S.planConfig.startDate = value;
  if(S.trainingPlan) S.trainingPlan.startDate = value;
  if(S.trainingPlan?.weekMode === 'rolling') ensureRollingPlan(true).startDate = value;
  syncPlanConfigFromTrainingPlan();
  saveState(S);
  renderAll();
});
document.querySelectorAll('#profile-plan-status .plan-status-pill').forEach(pill=>{
  pill.addEventListener('click',()=>{
    if(!S.planConfig) S.planConfig = {};
    S.planConfig.expired = pill.dataset.val === 'expired';
    saveState(S);
    renderAll();
  });
});

document.querySelectorAll('.run-mode-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    if(!S.runTracker) S.runTracker = {};
    S.runTracker.chartMode = btn.dataset.runMode || 'km';
    saveState(S);
    renderRunTracker();
  });
});
document.getElementById('run-prev-month')?.addEventListener('click',()=>{
  if(!S.runTracker) S.runTracker = {};
  S.runTracker.monthOffset = (S.runTracker.monthOffset || 0) - 1;
  saveState(S);
  renderRunTracker();
});
document.getElementById('run-next-month')?.addEventListener('click',()=>{
  if(!S.runTracker) S.runTracker = {};
  S.runTracker.monthOffset = (S.runTracker.monthOffset || 0) + 1;
  saveState(S);
  renderRunTracker();
});
document.getElementById('run-show-all')?.addEventListener('click',()=>{
  if(!S.runTracker) S.runTracker = {};
  S.runTracker.showAllRuns = !S.runTracker.showAllRuns;
  saveState(S);
  renderRunTracker();
});
document.getElementById('run-log-toggle')?.addEventListener('click',()=>{
  if(!S.runTracker) S.runTracker = {};
  S.runTracker.formOpen = !S.runTracker.formOpen;
  if(S.runTracker.formOpen) resetRunForm();
  saveState(S);
  renderRunTracker();
});
document.getElementById('run-cancel')?.addEventListener('click',()=>{
  if(!S.runTracker) S.runTracker = {};
  S.runTracker.formOpen = false;
  resetRunForm();
  saveState(S);
  renderRunTracker();
});
document.getElementById('run-save')?.addEventListener('click',saveRunEntry);
document.getElementById('run-input-proof')?.addEventListener('change',event=>handleRunProofFiles(event.target.files));
document.getElementById('run-list')?.addEventListener('click',event=>{
  const item = event.target.closest('[data-run-detail]');
  if(item) openRunDetail(item.dataset.runDetail);
});

initTpListeners();
moveRunSectionToScreen();
setupRunFormViewportGuards();
updateBottomNav(currentScreen);
window.addEventListener('resize',()=>document.querySelectorAll('.bottom-nav').forEach(nav=>moveNeonSlider(nav)));
renderTraining();
</script>
</body>
</html>
