let _tpExMgId  = null;
let _tpExEditId= null;
let _tpExState = { sets:4, rmin:6, rmax:12, rest:90 };

function openTpExModal(mgId, exId=null){
  _tpExMgId   = mgId;
  _tpExEditId = exId;
  const isEdit = !!exId;
  const ex = isEdit ? getDayDetailExercise(mgId, exId) : null;

  document.getElementById('tp-ex-title').textContent = isEdit ? 'Übung bearbeiten' : 'Übung hinzufügen';
  document.getElementById('tp-ex-save').textContent  = isEdit ? 'Änderungen speichern' : 'Übung hinzufügen';
  document.getElementById('tp-ex-name').value  = ex?.name||'';
  document.getElementById('tp-ex-notes').value = ex?.notes||'';
  document.getElementById('tp-ex-notes-ctr').textContent = (ex?.notes||'').length;
  document.getElementById('tp-ex-ac').style.display='none';
  selectTimePicker('tp-ex-time', ex?.timeOfDay || 'inherit', 'inherit');

  _tpExState = {
    sets: ex?.targetSets||4,
    rmin: ex?.repsMin||6,
    rmax: ex?.repsMax||12,
    rest: ex?.restSeconds||90
  };
  updateTpExSteppers();

  document.querySelectorAll('.tp-eq-pill').forEach(p=>p.classList.toggle('active', p.dataset.val===(ex?.equipment||'')));
  document.querySelectorAll('.tp-type-pill').forEach(p=>p.classList.toggle('active', p.dataset.val===(ex?.type||'')));

  document.getElementById('tp-ex-overlay').classList.add('open');
  document.getElementById('tp-ex-sheet').classList.add('open');
}
function closeTpExModal(){
  document.getElementById('tp-ex-overlay').classList.remove('open');
  document.getElementById('tp-ex-sheet').classList.remove('open');
  document.getElementById('tp-ex-ac').style.display='none';
}
function updateTpExSteppers(){
  document.getElementById('tp-ex-sets-val').textContent = _tpExState.sets;
  document.getElementById('tp-ex-rmin-val').textContent = _tpExState.rmin;
  document.getElementById('tp-ex-rmax-val').textContent = _tpExState.rmax;
  document.getElementById('tp-ex-rest-val').textContent = _tpExState.rest+'s';
  const avg = (_tpExState.rmin+_tpExState.rmax)/2;
  document.getElementById('tp-ex-rest-hint').textContent = restHint(avg);
}
function saveTpExModal(){
  const name = document.getElementById('tp-ex-name').value.trim();
  if(!name){ document.getElementById('tp-ex-name').focus(); return; }
  const eq    = document.querySelector('.tp-eq-pill.active')?.dataset.val||'';
  const type  = document.querySelector('.tp-type-pill.active')?.dataset.val||'';
  const notes = document.getElementById('tp-ex-notes').value.trim();
  const mg = getDayDetailMuscle(_tpExMgId);
  if(!mg) return;
  if(_tpExEditId){
    const ex = getDayDetailExercise(_tpExMgId, _tpExEditId);
    if(ex){
      if(ex.name!==name){
        if(!S.exerciseRenameHistory) S.exerciseRenameHistory={};
        if(!S.exerciseRenameHistory[ex.id]) S.exerciseRenameHistory[ex.id]=[];
        S.exerciseRenameHistory[ex.id].push({from:ex.name,to:name,at:todayStr});
      }
      Object.assign(ex,{name,equipment:eq,type,timeOfDay:readTimePicker('tp-ex-time','inherit'),targetSets:_tpExState.sets,repsMin:_tpExState.rmin,repsMax:_tpExState.rmax,restSeconds:_tpExState.rest,notes});
    }
  } else {
    if(!mg.exercises) mg.exercises=[];
    mg.exercises.push({id:genId(),name,equipment:eq,type,timeOfDay:readTimePicker('tp-ex-time','inherit'),targetSets:_tpExState.sets,repsMin:_tpExState.rmin,repsMax:_tpExState.rmax,restSeconds:_tpExState.rest,notes,sortOrder:mg.exercises.length,isArchived:false});
  }
  saveState(S);
  closeTpExModal();
  renderDayDetailScreen();
}

// ---------------------------------------------------------------
// CONFIRM DIALOG HELPER
// ---------------------------------------------------------------
function showConfirm(title, text, buttons){
  const el = document.getElementById('tp-confirm');
  document.getElementById('tp-confirm-title').textContent = title;
  document.getElementById('tp-confirm-text').textContent  = text;
  const btnsEl = document.getElementById('tp-confirm-btns');
  btnsEl.innerHTML = '';
  buttons.forEach(b=>{
    const btn = document.createElement('button');
    btn.className = `tp-cbtn ${b.cls||'ghost'}`;
    btn.textContent = b.label;
    btn.addEventListener('click',()=>{
      el.classList.remove('open');
      b.cb();
    });
    btnsEl.appendChild(btn);
  });
  el.classList.add('open');
}

// ---------------------------------------------------------------
// TRAINING PLAN - EVENT LISTENERS (init once)
// ---------------------------------------------------------------
function initTpListeners(){
  // Back buttons
  document.getElementById('tp-back-btn')?.addEventListener('click', closeTrainingPlanScreen);
  document.getElementById('dd-back-btn')?.addEventListener('click', closeDayDetailScreen);

  // MG modal
  document.getElementById('tp-mg-overlay')?.addEventListener('click', closeTpMgModal);
  document.getElementById('tp-mg-close')?.addEventListener('click',  closeTpMgModal);
  document.getElementById('tp-mg-save')?.addEventListener('click',   saveTpMgModal);
  document.querySelectorAll('#tp-mg-emojis .tp-emoji-pick').forEach(e=>{
    e.addEventListener('click',()=>{ document.querySelectorAll('#tp-mg-emojis .tp-emoji-pick').forEach(x=>x.classList.remove('active')); e.classList.add('active'); });
  });
  document.querySelectorAll('#tp-mg-colors .tp-color-dot').forEach(d=>{
    d.addEventListener('click',()=>{ document.querySelectorAll('#tp-mg-colors .tp-color-dot').forEach(x=>x.classList.remove('active')); d.classList.add('active'); });
  });
  document.querySelectorAll('.tp-time-picker .tp-time-pill').forEach(p=>{
    p.addEventListener('click',()=>{
      p.parentElement?.querySelectorAll('.tp-time-pill').forEach(x=>x.classList.remove('active'));
      p.classList.add('active');
    });
  });
  document.querySelectorAll('#tp-mg-name-chips .mg-name-chip').forEach(c=>{
    c.addEventListener('click',()=>{ document.getElementById('tp-mg-name').value=c.dataset.val; });
  });

  // Daily exercise modal
  document.getElementById('tp-daily-overlay')?.addEventListener('click', closeTpDailyModal);
  document.getElementById('tp-daily-close')?.addEventListener('click', closeTpDailyModal);
  document.getElementById('tp-daily-save')?.addEventListener('click', saveTpDailyModal);
  document.querySelectorAll('#tp-daily-icons .tp-emoji-pick').forEach(e=>{
    e.addEventListener('click',()=>{ document.querySelectorAll('#tp-daily-icons .tp-emoji-pick').forEach(x=>x.classList.remove('active')); e.classList.add('active'); });
  });
  document.querySelectorAll('#tp-daily-name-chips .mg-name-chip').forEach(c=>{
    c.addEventListener('click',()=>{ document.getElementById('tp-daily-name').value=c.dataset.val; });
  });

  // EX modal
  document.getElementById('tp-ex-overlay')?.addEventListener('click', closeTpExModal);
  document.getElementById('tp-ex-close')?.addEventListener('click',  closeTpExModal);
  document.getElementById('tp-ex-save')?.addEventListener('click',   saveTpExModal);

  // Equipment pills
  document.querySelectorAll('#tp-ex-eq .tp-eq-pill').forEach(p=>{
    p.addEventListener('click',()=>{ document.querySelectorAll('#tp-ex-eq .tp-eq-pill').forEach(x=>x.classList.remove('active')); p.classList.add('active'); });
  });
  // Type pills
  document.querySelectorAll('#tp-ex-type .tp-type-pill').forEach(p=>{
    p.addEventListener('click',()=>{ document.querySelectorAll('#tp-ex-type .tp-type-pill').forEach(x=>x.classList.remove('active')); p.classList.add('active'); });
  });

  // Steppers
  document.querySelectorAll('.tp-step-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const t = btn.dataset.target;
      const dir = btn.dataset.action==='inc'?1:-1;
      if(t==='sets'){ _tpExState.sets=Math.max(1,Math.min(10,_tpExState.sets+dir)); }
      if(t==='rmin'){ _tpExState.rmin=Math.max(1,Math.min(50,_tpExState.rmin+dir));
        if(_tpExState.rmin>_tpExState.rmax) _tpExState.rmax=_tpExState.rmin+2; }
      if(t==='rmax'){ _tpExState.rmax=Math.max(1,Math.min(50,_tpExState.rmax+dir));
        if(_tpExState.rmax<_tpExState.rmin) _tpExState.rmin=Math.max(1,_tpExState.rmax-2); }
      if(t==='rest'){ _tpExState.rest=Math.max(15,Math.min(600,_tpExState.rest+dir*15)); }
      // Suggest rest based on reps
      if(t==='rmin'||t==='rmax'){
        const avg=(_tpExState.rmin+_tpExState.rmax)/2;
        _tpExState.rest=restDefault(avg);
      }
      updateTpExSteppers();
    });
  });

  // Notes counter
  document.getElementById('tp-ex-notes')?.addEventListener('input',function(){
    document.getElementById('tp-ex-notes-ctr').textContent=this.value.length;
  });

  // Autocomplete
  const nameIn = document.getElementById('tp-ex-name');
  const acList = document.getElementById('tp-ex-ac');
  nameIn?.addEventListener('input',()=>{
    const q = nameIn.value.toLowerCase();
    if(!q){ acList.style.display='none'; return; }
    const matches = TP_EXERCISE_LIBRARY.filter(e=>e.name.toLowerCase().includes(q)).slice(0,8);
    if(!matches.length){ acList.style.display='none'; return; }
    acList.innerHTML = matches.map(e=>`<div class="tp-ac-item" data-name="${e.name}" data-eq="${e.eq}" data-type="${e.type}">${e.name}</div>`).join('');
    acList.style.display='block';
    acList.querySelectorAll('.tp-ac-item').forEach(item=>{
      item.addEventListener('click',()=>{
        nameIn.value=item.dataset.name;
        document.querySelectorAll('#tp-ex-eq .tp-eq-pill').forEach(p=>p.classList.toggle('active',p.dataset.val===item.dataset.eq));
        document.querySelectorAll('#tp-ex-type .tp-type-pill').forEach(p=>p.classList.toggle('active',p.dataset.val===item.dataset.type));
        acList.style.display='none';
      });
    });
  });
  nameIn?.addEventListener('blur',()=>setTimeout(()=>{ acList.style.display='none'; },150));

  // Close confirm on bg tap
  document.getElementById('tp-confirm')?.addEventListener('click',function(e){
    if(e.target===this) this.classList.remove('open');
  });
}

function renderProfile(){
  ensureTrainingPlanWeeks();
  syncPlanConfigFromTrainingPlan();
  const displayName = S.profile?.name || authSession?.user?.email?.split('@')[0] || 'Champion';
  const email = authSession?.user?.email || '';
  const initials = getInitials(displayName);
  document.getElementById('profile-screen-avatar').textContent = initials;
  document.getElementById('profile-screen-name').textContent = displayName;
  document.getElementById('profile-screen-email').textContent = email || '// lokaler modus';
  const weight = parseNumberInput(S.profile?.weightKg);
  const stepGoal = parseIntegerInput(S.profile?.stepGoal);
  const kcalGoal = parseIntegerInput(S.profile?.kcalGoal);
  document.getElementById('profile-screen-weight').textContent = weight != null ? Math.round(weight) : '-';
  document.getElementById('profile-screen-steps').textContent = stepGoal != null ? `${Math.round(stepGoal / 1000)}k` : '-';
  document.getElementById('profile-screen-kcal').textContent = kcalGoal != null ? kcalGoal : '-';

  const isRollingMode = S.trainingPlan?.weekMode === 'rolling';
  const rolling = isRollingMode ? ensureRollingPlan(true) : null;
  const weekLabels = tpWeekList();
  if(!weekLabels.includes(profileActiveWeek)) profileActiveWeek = weekLabels[0] || 'A';
  const tabs = document.querySelector('#screen-profile .week-tabs');
  if(tabs){
    tabs.innerHTML = '';
    if(isRollingMode){
      const tab = document.createElement('div');
      tab.className = 'wtab active';
      tab.textContent = 'Fortlaufend';
      tabs.appendChild(tab);
    } else {
      weekLabels.forEach(wk=>{
        const tab = document.createElement('div');
        tab.className = 'wtab' + (wk === profileActiveWeek ? ' active' : '');
        tab.textContent = `Woche ${wk}`;
        tab.addEventListener('click',()=>{
          profileActiveWeek = wk;
          tpActiveWeek = wk;
          renderProfile();
        });
        tabs.appendChild(tab);
      });
      const addTab = document.createElement('div');
      addTab.className = 'wtab add';
      addTab.textContent = '+ Woche';
      addTab.addEventListener('click',()=>{
        const nextLabel = String.fromCharCode(65 + weekLabels.length);
        handleAddWeek(nextLabel);
      });
      tabs.appendChild(addTab);
    }
  }

  const startInput = document.getElementById('profile-plan-start');
  if(startInput) startInput.value = activePlanStartDate();
  const rotation = document.getElementById('profile-week-rotation');
  if(rotation) rotation.textContent = isRollingMode ? `${rolling?.days?.length || 0} Tage` : (weekLabels.join('/') || 'A');
  document.querySelectorAll('#profile-plan-status .plan-status-pill').forEach(pill=>{
    const active = S.planConfig?.expired ? 'expired' : 'active';
    pill.classList.toggle('active', pill.dataset.val === active);
  });

  const rows = document.getElementById('profile-plan-rows');
  rows.innerHTML = '';
  const profileDays = isRollingMode
    ? (rolling?.days || []).map((day,index)=>({day,index,abbr:TP_DAY_ABBR[(getRollingDisplayDate(index).getDay()+6)%7]}))
    : Array.from({length:7},(_,d)=>({day:tpDay(profileActiveWeek, d),index:d,abbr:TP_DAY_ABBR[d]}));
  profileDays.forEach(({day,index,abbr})=>{
    if(!day) return;
    const mgs = (day.muscleGroups || []).filter(m=>!m.isArchived);
    const exCount = mgs.reduce((sum, mg)=>sum + (mg.exercises || []).filter(ex=>!ex.isArchived).length, 0);
    const row = document.createElement('div');
    row.className = 'day-row' + (day.isRest ? ' is-rest' : '');
    row.innerHTML = `
      <div class="day-name">${abbr}</div>
      <div class="day-type">${isRollingMode ? `Tag ${index + 1} · ` : ''}${escapeHtml(day.label || (day.isRest ? 'Ruhetag' : 'Trainingstag'))}</div>
      <span class="concept-pill">${day.isRest ? 'Rest' : `${mgs.length} MG · ${exCount} EX`}</span>
      <div class="day-edit">›</div>`;
    row.addEventListener('click',()=>{
      openTrainingPlanScreen();
      if(isRollingMode) requestAnimationFrame(()=>openRollingDayDetailScreen(index));
      else {
        tpActiveWeek = profileActiveWeek;
        requestAnimationFrame(()=>openDayDetailScreen(profileActiveWeek, index));
      }
    });
    rows.appendChild(row);
  });
}

