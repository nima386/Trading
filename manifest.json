function updateAuthUI(){
  const effectiveUser = authSession?.user || null;
  const email = effectiveUser?.email || effectiveUser?.phone || '';
  const signedIn = !!authSession?.user;
  const checkingSession = authLoading && !signedIn;
  // Auth-Gate nur zeigen wenn nicht eingeloggt
  document.body.classList.toggle('auth-locked', !signedIn);
  document.body.classList.toggle('auth-checking', checkingSession);

  if(checkingSession){
    setAuthStatus('Session wird geprüft...');
    return;
  }

  if(signedIn){
    setAuthStatus('');
    const displayName = S.profile?.name || email.split('@')[0] || 'Champion';
    const initials   = getInitials(displayName);

    // App-Avatare & Header aktualisieren
    document.querySelectorAll('.avatar').forEach(av=>{ av.textContent = initials; });
    document.querySelectorAll('.header-title').forEach(t=>{
      if(t.textContent.startsWith('Hey')) t.textContent = `Hey ${displayName.split(' ')[0]} 👊`;
    });

    // Profile-Panel im Gate (für späteren Bedarf)
    document.getElementById('gate-profile-name').textContent  = displayName;
    document.getElementById('gate-profile-email').textContent = email;
    document.getElementById('gate-profile-avatar').textContent = initials;

    // Settings-Profilbereich aktualisieren
    document.getElementById('settings-profile-card').style.display = 'flex';
    document.getElementById('settings-profile-avatar').textContent = initials;
    document.getElementById('settings-profile-name').textContent  = displayName;
    document.getElementById('settings-profile-email').textContent = email;
    document.getElementById('settings-sync-status').style.display = 'flex';
    document.getElementById('settings-account-actions').style.display = 'block';
    document.getElementById('settings-account-login').style.display   = 'none';
  } else {
    document.querySelectorAll('.avatar').forEach(av=>{ av.textContent = 'JM'; });
    document.getElementById('settings-profile-card').style.display = 'none';
    document.getElementById('settings-sync-status').style.display = 'none';
    document.getElementById('settings-account-actions').style.display = 'none';
    document.getElementById('settings-account-login').style.display   = 'block';
    const hasActiveAuthPanel = !!document.querySelector('#auth-gate .auth-gate-panel.active');
    if(!hasActiveAuthPanel) setGateMode('welcome');
  }
  renderSyncDebug();
  scheduleI18n();
}
