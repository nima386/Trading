// -- UTILS --
const $ = id => document.getElementById(id);
const sleep = ms => new Promise(r => setTimeout(r, ms));
function easeOut(t) { return 1 - Math.pow(1-t,3); }
function getSplashVersionLabel(){
  const version = typeof KASAI_APP_VERSION !== 'undefined' ? KASAI_APP_VERSION : 'kasai-v43-timepush-i18n3';
  return `${version} · KASAI`;
}
function updateSplashVersionTag(){
  const tag = $('versionTag');
  if(tag) tag.textContent = getSplashVersionLabel();
}

// -- EMBERS --
let emberTimer = null;
function spawnEmber(cx, cy, spread=80) {
  const field = $('particleField');
  const em = document.createElement('div');
  em.className = 'ember';
  const sz = Math.random()*5+2;
  const sx = cx + (Math.random()-0.5)*spread;
  const colors = ['#ffca28','#ff9500','#ff6b00','#ff3d00','#ff2d55'];
  const col = colors[Math.floor(Math.random()*colors.length)];
  em.style.cssText = `width:${sz}px;height:${sz}px;left:${sx}px;top:${cy}px;background:${col};box-shadow:0 0 ${sz*2}px ${col};animation:ember-float ${1.4+Math.random()*2}s ease-out ${Math.random()*0.4}s forwards;`;
  field.appendChild(em);
  setTimeout(()=>em.remove(), 4000);
}
function burstEmbers(cx,cy,n,spread=110){
  for(let i=0;i<n;i++) spawnEmber(cx,cy,spread);
}
function startEmberStream(cx,cy){
  emberTimer = setInterval(()=>spawnEmber(cx,cy,70),180);
}
function stopEmbers(){ clearInterval(emberTimer); emberTimer=null; }

function finishSplash(){
  stopEmbers();
  const splash = $('splash');
  if(splash){
    splash.classList.remove('splash-playing','splash-booting');
    splash.style.opacity='0';
    splash.style.pointerEvents='none';
  }
  document.body.classList.add('splash-done');
}

// -- SPEED LINES (V1) --
function runSpeedLines(){
  const lines = document.querySelectorAll('.speed-line');
  lines.forEach((l,i)=>{
    function sweep(){
      l.style.transition='none'; l.style.opacity='0'; l.style.transform='translateX(40px)';
      setTimeout(()=>{
        l.style.transition=`transform ${0.35+i*0.08}s linear, opacity 0.15s`;
        l.style.opacity='0.7'; l.style.transform='translateX(-90px)';
        setTimeout(()=>{ l.style.opacity='0'; setTimeout(sweep, 600+i*200+Math.random()*400); }, 300+i*60);
      }, 40);
    }
    setTimeout(sweep, i*120);
  });
}

// -- BOLT FLASH (V2) --
function runBoltFlash(){
  const bolt = document.getElementById('boltMain');
  if(!bolt) return;
  let flashes = 0;
  function flash(){
    bolt.style.opacity='1';
    setTimeout(()=>{ bolt.style.opacity='0.4'; }, 80);
    setTimeout(()=>{ bolt.style.opacity='0.9'; }, 140);
    setTimeout(()=>{ bolt.style.opacity='0.2'; }, 200);
    setTimeout(()=>{ bolt.style.opacity='1'; flashes++; if(flashes<3) setTimeout(flash, 500+Math.random()*600); }, 280);
  }
  flash();
}

// -- ECG PULSE (V3) --
function runEcgPulse(){
  setTimeout(()=>{
    ['ecgDot1','ecgDot2'].forEach((id,i)=>{
      const el=$(id);
      if(!el) return;
      function pulse(){
        el.style.transition='none'; el.style.transform='scale(0.5)'; el.style.opacity='0.9';
        setTimeout(()=>{
          el.style.transition='transform 1.2s ease-out, opacity 1.2s ease-out';
          el.style.transform='scale(3.5)'; el.style.opacity='0';
          setTimeout(()=>{ setTimeout(pulse, 400+i*200); }, 1200);
        }, 50);
      }
      setTimeout(pulse, i*300+200);
    });
  }, 800);
}

// -- CLIMBER REVEAL (V4) --
function revealClimber(){
  const c=$('climberFig');
  if(!c) return;
  setTimeout(()=>{
    c.style.transition='opacity 0.5s ease, transform 0.6s cubic-bezier(0.34,1.56,0.64,1)';
    c.style.opacity='1'; c.style.transform='scale(1) translateY(0)';
  }, 900);
}

// -- IMPACT RINGS (V5) --
function runImpactRings(){
  const rings = document.querySelectorAll('.imp-ring');
  const sparks = $('dbSparks');
  setTimeout(()=>{
    if(sparks){ sparks.style.transition='opacity 0.2s'; sparks.style.opacity='1'; }
    rings.forEach((r,i)=>{
      r.style.transition='none'; r.style.transform='scale(0.5)'; r.style.opacity='1';
      setTimeout(()=>{
        r.style.transition=`transform ${0.8+i*0.3}s ease-out, opacity ${0.8+i*0.3}s ease-out`;
        r.style.transform='scale(3)'; r.style.opacity='0';
      }, i*100+50);
    });
  }, 700);
}

// -- RESET --
function resetExternalSplash(){
  const frame = $('externalSplashFrame');
  if(frame){
    frame.removeAttribute('src');
    frame.style.display = 'none';
    frame.style.opacity = '';
    frame.style.visibility = '';
  }
  const splash = $('splash');
  if(splash) splash.classList.remove('external-splash-active','external-splash-loading','external-splash-ready');
}

function resetAll(){
  updateSplashVersionTag();
  resetExternalSplash();
  $('iconWrap').style.opacity='0'; $('iconWrap').style.transition='none';
  $('iconGlow').style.opacity='0'; $('iconGlow').style.animation='none';
  $('bgBurst').style.opacity='0'; $('bgBurst').style.background='';
  $('gridOverlay').style.opacity='0';
  $('loaderWrap').style.opacity='0'; $('loaderWrap').style.transform='translateX(-50%) translateY(14px)';
  $('loaderFill').style.width='0%'; $('loaderLbl').textContent='Igniting...';
  $('versionTag').style.opacity='0';
  $('exitOverlay').style.opacity='0'; $('exitOverlay').style.transition='none';
  $('kanjiSub').style.opacity='0'; $('kanjiSub').style.transform='translateY(10px)'; $('kanjiSub').style.transition='none';
  $('taglineSub').style.opacity='0'; $('taglineSub').style.transform='translateY(8px)'; $('taglineSub').style.transition='none';
  document.querySelectorAll('.kasai-letter').forEach(l=>{
    l.style.opacity='0'; l.style.transform='translateY(38px) scale(0.78)'; l.style.transition='none';
  });
  $('particleField').innerHTML='';
  $('splash').style.opacity='1'; $('splash').style.pointerEvents='all';
  $('variantBadge').style.opacity='0';
  stopEmbers();
}

// -- LOADER --
const LBLS=['Igniting...','Loading...','Almost ready...','Ready 🔥'];
let lblIdx=0;
function runLoader(onDone){
  const fill=$('loaderFill'), lbl=$('loaderLbl');
  const dur=1800; const t0=performance.now();
  function tick(now){
    const p=Math.min((now-t0)/dur,1);
    fill.style.width=(easeOut(p)*100)+'%';
    const li=Math.floor(p*(LBLS.length-1));
    if(li!==lblIdx){ lblIdx=li; lbl.textContent=LBLS[li]; lbl.style.color=li>1?'rgba(255,149,0,0.6)':'rgba(255,107,0,0.3)'; }
    if(p<1) requestAnimationFrame(tick);
    else { lbl.textContent=LBLS[3]; lbl.style.color='rgba(255,200,60,0.8)'; setTimeout(onDone,250); }
  }
  requestAnimationFrame(tick);
}

// -- MAIN PLAY --
async function playSplash(variant){
  updateSplashVersionTag();
  $('taglineSub').textContent = taglines[variant];
  $('variantBadge').textContent = `// v${variant+1} · ${vnames[variant]}`;

  // Inject icon SVG
  $('iconWrap').innerHTML = `<div class="icon-glow" id="iconGlow"></div>` + icons[variant];

  // Adjust wrap size per variant
  const sizes = ['180px,200px','160px,200px','200px,180px','200px,200px','200px,160px'];
  const [w,h] = sizes[variant].split(',');
  $('iconWrap').style.width=w; $('iconWrap').style.height=h;

  // Re-init climber style for V4
  if(variant===3){
    const c=$('climberFig');
    if(c){ c.style.opacity='0'; c.style.transform='scale(0.6) translateY(12px)'; }
  }

  const W=window.innerWidth, H=window.innerHeight;
  const cx=W/2, cy=H*0.42;

  // Phase 0: bg warm-up
  await sleep(80);
  $('gridOverlay').style.transition='opacity 0.7s ease'; $('gridOverlay').style.opacity='0.45';
  $('bgBurst').style.transition='opacity 0.4s ease';
  $('bgBurst').style.opacity='0.2';
  $('bgBurst').style.background=`radial-gradient(ellipse 55% 45% at 50% 55%, rgba(80,20,0,0.35), transparent 70%)`;

  await sleep(300);

  // Phase 1: ICON ERUPTS
  const iw=$('iconWrap');
  iw.style.transition='opacity 0.07s, transform 0.7s cubic-bezier(0.34,1.56,0.64,1)';
  iw.style.opacity='1'; iw.style.transform='scale(1) translateY(0)';

  // Shockwave
  setTimeout(()=>{
    $('bgBurst').style.transition='opacity 0.12s, background 0.12s';
    $('bgBurst').style.opacity='1';
    $('bgBurst').style.background=`radial-gradient(ellipse 90% 80% at 50% 46%, rgba(255,100,0,0.25), transparent 68%)`;
    setTimeout(()=>{
      $('bgBurst').style.transition='opacity 0.9s, background 1.2s';
      $('bgBurst').style.opacity='0.5';
      $('bgBurst').style.background=`radial-gradient(ellipse 70% 60% at 50% 50%, rgba(255,80,0,0.12), transparent 75%)`;
    },160);
  },50);

  // Glow pulse
  setTimeout(()=>{
    const ig=$('iconGlow');
    if(ig){ ig.style.opacity='0.75'; ig.style.animation='glow-pulse 2.2s ease-in-out infinite'; }
  },350);

  // Embers
  setTimeout(()=>{
    burstEmbers(cx, cy+80, 18, 110);
    startEmberStream(cx, cy+70);
  },400);

  // Variant extras
  if(variant===0) setTimeout(runSpeedLines, 500);
  if(variant===1) setTimeout(runBoltFlash, 500);
  if(variant===2) runEcgPulse();
  if(variant===3) revealClimber();
  if(variant===4) runImpactRings();

  await sleep(260);
  $('variantBadge').style.transition='opacity 0.5s ease 2s'; $('variantBadge').style.opacity='1';

  // Phase 2: LETTERS
  await sleep(660);
  document.querySelectorAll('.kasai-letter').forEach((l,i)=>{
    setTimeout(()=>{
      l.style.transition='opacity 0.5s cubic-bezier(0.34,1.56,0.64,1), transform 0.6s cubic-bezier(0.34,1.56,0.64,1)';
      l.style.opacity='1'; l.style.transform='translateY(0) scale(1)';
      burstEmbers(cx-100+i*55, cy+160, 3, 30);
    }, i*75);
  });

  // Phase 3: subtext
  await sleep(1100);
  $('kanjiSub').style.transition='opacity 0.6s ease, transform 0.6s ease';
  $('kanjiSub').style.opacity='1'; $('kanjiSub').style.transform='translateY(0)';
  await sleep(260);
  $('taglineSub').style.transition='opacity 0.6s ease, transform 0.6s ease';
  $('taglineSub').style.opacity='1'; $('taglineSub').style.transform='translateY(0)';

  // Phase 4: loader
  await sleep(350);
  $('loaderWrap').style.transition='opacity 0.4s ease, transform 0.4s ease';
  $('loaderWrap').style.opacity='1'; $('loaderWrap').style.transform='translateX(-50%) translateY(0)';
  $('versionTag').style.transition='opacity 0.5s ease'; $('versionTag').style.opacity='1';
  lblIdx=0;
  await sleep(80);
  await new Promise(res=>runLoader(res));

  // Phase 5: burst finale
  await sleep(160);
  $('bgBurst').style.transition='opacity 0.25s, background 0.25s';
  $('bgBurst').style.opacity='1';
  $('bgBurst').style.background=`radial-gradient(ellipse 80% 70% at 50% 46%, rgba(255,120,0,0.35), rgba(255,55,0,0.15) 42%, transparent 72%)`;
  burstEmbers(cx, cy+75, 30, 130);

  // Phase 6: exit
  await sleep(360);
  stopEmbers();
  $('exitOverlay').style.transition='opacity 0.6s cubic-bezier(0.4,0,0.2,1)';
  $('exitOverlay').style.opacity='1';
  await sleep(640);
  finishSplash();
}

async function playExternalSplash(index){
  const splash = $('splash');
  let frame = $('externalSplashFrame');
  if(!splash || !frame || !externalSplashFiles[index]){
    finishSplash();
    return;
  }
  updateSplashVersionTag();
  const freshFrame = frame.cloneNode(false);
  freshFrame.removeAttribute('src');
  freshFrame.style.display = 'block';
  freshFrame.style.opacity = '';
  freshFrame.style.visibility = '';
  frame.replaceWith(freshFrame);
  frame = freshFrame;
  const frameReady = new Promise(resolve=>{
    let done = false;
    const finish = () => {
      if(done) return;
      done = true;
      resolve();
    };
    frame.addEventListener('load', finish, {once:true});
    setTimeout(finish, 900);
  });
  frame.src = `${externalSplashFiles[index]}?v=${encodeURIComponent(KASAI_APP_VERSION)}`;
  await frameReady;
  splash.classList.remove('splash-booting');
  splash.classList.add('external-splash-active','external-splash-ready');
  const tag = $('versionTag');
  if(tag){
    tag.style.transition = 'opacity 0.45s ease';
    tag.style.opacity = '1';
  }
  await sleep(4700);
  $('exitOverlay').style.transition='opacity 0.55s cubic-bezier(0.4,0,0.2,1)';
  $('exitOverlay').style.opacity='1';
  await sleep(520);
  finishSplash();
}

function pickSplashVariant(){
  const total = icons.length + externalSplashFiles.length;
  if(total <= 1) return 0;
  let picked = Math.floor(Math.random() * total);
  try{
    const last = Number(localStorage.getItem('kasai.lastSplashVariant'));
    if(Number.isFinite(last) && picked === last){
      picked = (picked + 1 + Math.floor(Math.random() * (total - 1))) % total;
    }
    localStorage.setItem('kasai.lastSplashVariant', String(picked));
  }catch(_){}
  return picked;
}

// -- RANDOM VARIANT STATE --
let currentVariant=-1;
function playVariantOnce(v){
  currentVariant=v;
  resetAll();
  const splash = $('splash');
  const externalIndex = v - icons.length;
  if(splash && externalIndex < 0){
    splash.classList.remove('splash-booting');
    splash.classList.add('splash-playing');
  }
  setTimeout(()=>{
    const play = externalIndex >= 0 ? playExternalSplash(externalIndex) : playSplash(v);
    play.catch(error=>{
      console.warn('Splash animation failed, continuing to app.', error);
      finishSplash();
    });
  },20);
}

// -- ICONS need initial transform --
function prepIconWrap(){
  const iw=$('iconWrap');
  iw.style.opacity='0'; iw.style.transform='scale(0.1) translateY(70px)';
}

// -- AUTO START --
let _splashStarted = false;
function startSplashOnce(){
  if(_splashStarted) return;
  _splashStarted = true;
  setTimeout(()=>{
    if(!document.body.classList.contains('splash-done')) finishSplash();
  },9000);
  updateSplashVersionTag();
  prepIconWrap();
  const v=pickSplashVariant();
  currentVariant=v;
  playVariantOnce(v);
}
if(document.readyState === 'loading'){
  document.addEventListener('DOMContentLoaded', startSplashOnce, {once:true});
} else {
  startSplashOnce();
}
window.addEventListener('load', startSplashOnce);

// CSS animation referenced by icon glow
const style=document.createElement('style');
style.textContent=`@keyframes glow-pulse{0%,100%{opacity:0.65;transform:scale(1);}50%{opacity:1;transform:scale(1.12);}}`;
document.head.appendChild(style);

